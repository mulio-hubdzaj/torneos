        'entity',
        row_to_json(CASE WHEN TG_OP = 'DELETE' THEN OLD ELSE NEW END),
        COALESCE(NEW.entity_id, OLD.entity_id),
        NOW()
    );

    RETURN NEW;
END;
$$;


