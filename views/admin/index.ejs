<!DOCTYPE html>
<html>
<head>
  <title>Panel de Administración</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="container mt-4">
  <h1 class="mb-4">Panel de Administración</h1>

<!-- Bloque de mensajes flash -->
<% if (messages) { %>
  <% if (messages.success && messages.success.length > 0) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages.danger && messages.danger.length > 0) { %>
    <div class="alert alert-danger"><%= messages.danger[0] %></div>
  <% } %>
  <% if (messages.info && messages.info.length > 0) { %>
    <div class="alert alert-info"><%= messages.info[0] %></div>
  <% } %>
<% } %>





  <!-- Tabla de entidades -->
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Código</th>
        <th>Descripción</th>
        <th>Activo</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% entidades.forEach(entidad => { %>
        <tr>
          <td><%= entidad.codigo %></td>
          <td><%= entidad.descripcion %></td>
          <td>
            <form action="/admin/entidades/toggle/<%= entidad.entity_id %>" method="POST">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="activo" 
                       onchange="this.form.submit()" <%= entidad.activo ? 'checked' : '' %>>
              </div>
            </form>
          </td>
          <td>
  <a href="/admin/editar/<%= entidad.entity_id %>" class="btn btn-sm btn-warning">Editar</a>
  
  <% if (entidad.activo) { %>
  <a href="/entidad/gestionar/<%= entidad.entity_id %>" class="btn btn-sm btn-primary ms-2">Administrar</a>
<% } else { %>
  <button class="btn btn-sm btn-secondary ms-2" disabled>Administrar</button>
<% } %>

</td>

          
        </tr>
      <% }) %>
    </tbody>
  </table>

  <a href="/admin/nueva" class="btn btn-success">Crear nueva entidad</a>
</body>
</html>
