// Función para guardar horarios comunes a toda una fecha
async function guardarHorariosComunes(numeroFecha) {
  const form = document.getElementById(`formFechaComun-${numeroFecha}`);
  const formData = new FormData(form);

  const fechaComun = formData.get('fecha_comun');
  const horaInicial = formData.get('hora_inicial');
  const intervaloMinutos = parseInt(formData.get('intervalo_minutos'));

  if (!fechaComun) {
    mostrarAvisoApp('Por favor selecciona una fecha común.', 'Horarios');
    return;
  }
  if (!horaInicial) {
    mostrarAvisoApp('Por favor ingresa una hora inicial.', 'Horarios');
    return;
  }
  if (!intervaloMinutos || intervaloMinutos < 5) {
    mostrarAvisoApp('Por favor ingresa un intervalo válido (mínimo 5 minutos).', 'Horarios');
    return;
  }

  try {
    const response = await fetch(`/partidos/actualizar-horarios-fecha`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        numero_fecha: numeroFecha,
        torneo_id: formData.get('torneo_id'),
        grupo_id: formData.get('grupo_id') || '',
        fecha_comun: fechaComun,
        hora_inicial: horaInicial,
        intervalo_minutos: intervaloMinutos
      })
    });

    const data = await response.json();

  if (data.success) {
    mostrarAvisoApp(data.message || 'Horarios actualizados correctamente.', 'Horarios');
    const fechaDisplay = fechaComun.split('-').reverse().join('/');
    const fechaPane = document.getElementById(`fecha-${numeroFecha}`);
    if (fechaPane) {
      let horaActual = horaInicial;
      fechaPane.querySelectorAll('tbody tr').forEach(row => {
        const celdas = row.querySelectorAll('td');
        if (celdas[4]) celdas[4].textContent = fechaDisplay;
        if (celdas[5]) celdas[5].textContent = horaActual;

        const btnEditar = row.querySelector('.editar-horario-btn');
        if (btnEditar) {
          btnEditar.dataset.fecha = fechaComun;
          btnEditar.dataset.hora = horaActual;
        }

        horaActual = sumarMinutosHora(horaActual, intervaloMinutos);
      });
    }
  } else {
    mostrarAvisoApp(data.message || 'No se pudieron actualizar los horarios.', 'Horarios');
  }
  } catch (error) {
    console.error('Error:', error);
    mostrarAvisoApp('Error al actualizar los horarios.', 'Horarios');
  }
}

function poblarCruceManualGrupo(grupoId) {
  const selectGrupo = document.getElementById('manualGrupoId');
  const selectEquipoA = document.getElementById('manualEquipoA');
  const selectEquipoB = document.getElementById('manualEquipoB');

  if (!selectGrupo || !selectEquipoA || !selectEquipoB) return;

  selectGrupo.value = grupoId || '';
  actualizarOpcionesCruceManual();
}

function abrirModalCruceManual(numeroFecha, grupoId = '') {
  const inputFecha = document.getElementById('manualNumeroFecha');
  const selectGrupo = document.getElementById('manualGrupoId');
  const redirectInput = document.getElementById('manualRedirectUrl');
  if (inputFecha) inputFecha.value = numeroFecha;
  if (redirectInput) {
    const params = new URLSearchParams(window.location.search);
    params.set('fecha', numeroFecha);
    redirectInput.value = `${window.location.pathname}?${params.toString()}#partidos`;
  }
  if (selectGrupo) {
    if (grupoId) {
      selectGrupo.value = grupoId;
      poblarCruceManualGrupo(grupoId);
    } else if (selectGrupo.options.length > 0) {
      const primerGrupo = selectGrupo.options[0].value || selectGrupo.options[1]?.value || '';
      selectGrupo.value = primerGrupo;
      poblarCruceManualGrupo(primerGrupo);
    }
  }
  const modal = new bootstrap.Modal(document.getElementById('modalCruceManual'));
  modal.show();
}

// Cambiar estado de un partido
async function cambiarEstado(selectElement) {
  const partidoId = selectElement.dataset.id;
  const nuevoEstado = selectElement.value;

  try {
    const response = await fetch(`/partidos/${partidoId}/estado`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        partido_id: partidoId,
        nuevoEstado: nuevoEstado
      })
    });

    const data = await response.json();
    if (!data.success) {
      mostrarAvisoApp(data.message || 'No se pudo actualizar el estado del partido.', 'Partidos');
    } else {
      const marcador = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a-id]`);
      if (marcador) marcador.dataset.estado = nuevoEstado;
      recalcularEstadisticasCliente();
    }
  } catch (error) {
    console.error('Error:', error);
  }
}

// Guardar marcador
async function guardarMarcador() {
  const partidoId = document.getElementById('marcadorPartidoId').value;
  const golesA = document.getElementById('marcadorGolesA').value;
  const golesB = document.getElementById('marcadorGolesB').value;
  const selectEstadoActual = document.querySelector(`.estado-select[data-id="${partidoId}"]`);
  const estadoActual = selectEstadoActual ? selectEstadoActual.value : '';
  const estadoMarcador = estadoActual === 'en_curso' ? 'en_curso' : 'finalizado';

  if (golesA === '' || golesB === '') {
    mostrarAvisoApp('Por favor ingresa ambos marcadores.', 'Marcador');
    return;
  }

  if (!marcadorValido(golesA) || !marcadorValido(golesB)) {
    mostrarAvisoApp('El marcador debe ser un número entero entre 0 y 99, sin negativos ni ceros a la izquierda.', 'Marcador');
    return;
  }

  try {
    const response = await fetch(`/partidos/${partidoId}/marcador`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        partido_id: partidoId,
        goles_a: golesA,
        goles_b: golesB,
        estado: estadoMarcador
      })
    });

    const data = await response.json();
    if (data.success) {
      const resultCell = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a]`);
      if (resultCell) {
        resultCell.setAttribute('data-goles-a', golesA);
        resultCell.setAttribute('data-goles-b', golesB);
        resultCell.setAttribute('data-estado', estadoMarcador);
        const span = resultCell.querySelector('span');
        if (span) {
          span.textContent = `${golesA} - ${golesB}`;
        }
      }
      const selectEstado = document.querySelector(`.estado-select[data-id="${partidoId}"]`);
      if (selectEstado) {
        selectEstado.value = estadoMarcador;
      }
      actualizarAccionesPartido(partidoId, estadoMarcador);
      recalcularEstadisticasCliente();
      cerrarModalBootstrapSeguro('modalEditarMarcador');
    } else {
      mostrarAvisoApp(data.message || 'No se pudo actualizar el marcador.', 'Marcador');
    }
  } catch (error) {
    console.error('Error:', error);
    mostrarAvisoApp('Error al actualizar marcador.', 'Marcador');
  }
}

async function guardarEstadoPartido(pidoId, nuevoEstado) {
  try {
    const res = await fetch(`/partidos/${pidoId}/estado`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ partido_id: pidoId, nuevoEstado: nuevoEstado })
    });
    const data = await res.json();
    if (data.success) {
      const selectEl = document.querySelector(`.estado-select[data-id="${pidoId}"]`);
      if (selectEl) selectEl.value = nuevoEstado;
      const marcador = document.querySelector(`td[data-id="${pidoId}"][data-equipo-a-id]`);
      if (marcador) marcador.dataset.estado = nuevoEstado;
      actualizarAccionesPartido(pidoId, nuevoEstado);
      recalcularEstadisticasCliente();
      return true;
    } else {
      mostrarAvisoApp(data.message || 'No se pudo actualizar el estado del partido.', 'Partidos');
      return false;
    }
  } catch (e) {
    console.error(e);
    return false;
  }
}

