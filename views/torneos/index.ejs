});

let cargaEquipoPartidoActual = null;
let cargaItemsDisponibles = [];
let cargaJugadoresCambio = [];
let cargaEquipoPartidoBotonActual = null;
let cargaReglaTarjetasActual = { acumula_amarillas: false };

function formatoMonto(valor) {
  const numero = Number(valor || 0);
  return Math.round(numero).toLocaleString('es-PY');
}

function escaparHtml(valor) {
  return String(valor ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function renderTarjetasMini(cantidad, tipo) {
  const total = Number(cantidad || 0);
  if (total <= 0) return '';
  const clase = tipo === 'roja' ? 'tarjeta-mini-roja' : 'tarjeta-mini-amarilla';
  if (total <= 3) {
    return Array.from({ length: total }, () => `<span class="tarjeta-mini ${clase}" aria-label="Tarjeta ${tipo}"></span>`).join('');
  }
  return `<span class="d-inline-flex align-items-center gap-1"><span class="tarjeta-mini ${clase}" aria-label="Tarjeta ${tipo}"></span><small>x${total}</small></span>`;
}

function renderDetalleEstadisticaJugador(jugador) {
  const goles = Number(jugador.goles || 0);
  const amarillas = Number(jugador.tarjetas_amarillas || 0);
  const rojas = Number(jugador.tarjetas_rojas || 0);
  const eventos = [];

  if (goles > 0) eventos.push(`<span>${goles} ${goles === 1 ? 'gol' : 'goles'}</span>`);
  if (amarillas > 0) eventos.push(renderTarjetasMini(amarillas, 'amarilla'));
  if (rojas > 0) eventos.push(renderTarjetasMini(rojas, 'roja'));

  return `
    <div class="encuentro-stats-jugador">
      <span>${escaparHtml([jugador.nombre, jugador.apellido].filter(Boolean).join(' ') || 'Jugador')}</span>
      <span class="encuentro-stats-eventos">${eventos.join('')}</span>
    </div>
  `;
}

function renderColumnaEstadisticasEquipo(titulo, jugadores) {
  const contenido = jugadores.length
    ? jugadores.map(renderDetalleEstadisticaJugador).join('')
    : '<div class="encuentro-stats-vacio">Sin goles ni tarjetas.</div>';

  return `
    <div class="encuentro-stats-columna">
      <div class="encuentro-stats-columna-titulo">${escaparHtml(titulo)}</div>
      <div class="encuentro-stats-lista">${contenido}</div>
    </div>
  `;
}

function formatearJugadorCambio(nombre, numeroCamiseta, jugadorId) {
  const nombreSeguro = nombre || `Jugador ${jugadorId || '-'}`;
  const numeroSeguro = String(numeroCamiseta || '').trim();
  return numeroSeguro ? `${numeroSeguro} - ${nombreSeguro}` : nombreSeguro;
}

function renderCambioJugador(cambio) {
  const sale = formatearJugadorCambio(cambio.jugador_sale_nombre, cambio.jugador_sale_numero_camiseta, cambio.jugador_sale_id);
  const entra = formatearJugadorCambio(cambio.jugador_entra_nombre, cambio.jugador_entra_numero_camiseta, cambio.jugador_entra_id);
  const minuto = cambio.minuto ? `<span class="encuentro-cambio-minuto">${escaparHtml(cambio.minuto)}</span>` : '';
  return `
    <div class="encuentro-stats-cambio">
      ${minuto}
      <span><i class="bi bi-arrow-down-left text-danger"></i> ${escaparHtml(sale)}</span>
      <span><i class="bi bi-arrow-up-right text-success"></i> ${escaparHtml(entra)}</span>
