<%
  const tabsInicialesPermitidos = ['torneos', 'items', 'grupos', 'jugadores', 'equipos', 'partidos', 'estadisticas', 'finanzas', 'usuarios', 'auditoria', 'usoapp'];
  const tabInicial = tabsInicialesPermitidos.includes(typeof tabActivaInicial !== 'undefined' ? tabActivaInicial : '') ? tabActivaInicial : 'torneos';
  const navActiva = id => id === tabInicial ? ' active' : '';
  const paneActiva = id => id === tabInicial ? ' show active' : '';
%>


<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=0.45, maximum-scale=3, user-scalable=yes, viewport-fit=cover">
  <title>Gestión de Torneos</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const paramsIniciales = new URLSearchParams(window.location.search);
      const tabQuery = paramsIniciales.get('tab');
      const hash = window.location.hash || (tabQuery ? `#${tabQuery}` : '');
      const rolId = Number(<%= Number(rol_id || 0) %>);
      const hashesBloqueados = rolId === 0
        ? ['#grupos', '#jugadores', '#equipos', '#items', '#usuarios', '#auditoria', '#usoapp', '#finanzas']
        : (rolId === 1
        ? ['#grupos', '#equipos', '#items', '#usuarios', '#auditoria', '#usoapp', '#finanzas']
        : (rolId === 2 ? ['#grupos', '#items', '#usuarios', '#auditoria', '#usoapp'] : (rolId === 3 ? ['#auditoria', '#usoapp'] : [])));

      if (hashesBloqueados.includes(hash)) {
        window.location.hash = '#torneos';
        return;
      }

      if (hash) {
        const triggerEl = document.querySelector(`a[href="${hash}"]`);
        if (triggerEl) {
          const tab = new bootstrap.Tab(triggerEl);
          tab.show();
        }
      }

      const fechaActiva = paramsIniciales.get('fecha');
      if (fechaActiva) {
        const fechaTrigger = document.getElementById(`fecha-${fechaActiva}-tab`);
        if (fechaTrigger) {
          const fechaTab = new bootstrap.Tab(fechaTrigger);
          fechaTab.show();
        }
      }
    });
  </script>
</head>

<body class="bg-stadium torneos-page">
  <% const esVistaPublica = Boolean(typeof vistaPublica !== 'undefined' && vistaPublica); %>
  <div id="pullRefreshIndicator" class="pull-refresh-indicator" aria-live="polite">
    <i class="bi bi-arrow-clockwise"></i>
    <span>Desliza para actualizar</span>
  </div>

  <!-- Barra superior fija -->
