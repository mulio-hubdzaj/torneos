<!-- Modal item -->
<div class="modal fade" id="modalReglaTarjetas" tabindex="-1" aria-labelledby="modalReglaTarjetasTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form action="/torneos/<%= torneo.id_torneo %>/regla-tarjetas" method="POST">
        <div class="modal-header bg-dark text-white">
          <h5 class="modal-title" id="modalReglaTarjetasTitulo">Regla de tarjetas</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <% const regla = reglaTarjetas || {}; %>
          <% if (!regla.tabla_configurada) { %>
            <div class="alert alert-warning py-2">
              Falta aplicar la tabla de configuracion para guardar esta regla.
            </div>
          <% } %>

          <div class="regla-tarjeta-opcion">
            <div>
              <label class="form-label fw-bold mb-0" for="reglaAcumulaAmarillas">Suspension automatica por acumulacion</label>
              <div class="form-text">Si un jugador llega al limite de amarillas, el sistema propondra deshabilitarlo/suspenderlo.</div>
            </div>
            <div class="form-check form-switch m-0">
              <input type="hidden" name="acumula_amarillas" value="0">
              <input class="form-check-input" type="checkbox" id="reglaAcumulaAmarillas" name="acumula_amarillas" value="1" <%= regla.acumula_amarillas ? 'checked' : '' %>>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label for="reglaAmarillasSuspension" class="form-label text-dark">Amarillas para suspender</label>
              <input type="number" class="form-control" id="reglaAmarillasSuspension" name="amarillas_para_suspension" min="1" step="1" value="<%= regla.amarillas_para_suspension || 5 %>" required>
            </div>
            <div class="col-md-6">
              <label for="reglaFechasSuspension" class="form-label text-dark">Fechas de suspension</label>
              <input type="number" class="form-control" id="reglaFechasSuspension" name="fechas_suspension_acumulacion" min="1" step="1" value="<%= regla.fechas_suspension_acumulacion || 1 %>" required>
            </div>
          </div>

          <div class="regla-tarjeta-opcion mt-3">
            <div>
              <label class="form-label fw-bold mb-0" for="reglaReiniciar">Reiniciar conteo</label>
              <div class="form-text">Vuelve a contar desde cero despues de registrar la sancion por acumulacion.</div>
            </div>
            <div class="form-check form-switch m-0">
              <input type="hidden" name="reiniciar_al_sancionar" value="0">
              <input class="form-check-input" type="checkbox" id="reglaReiniciar" name="reiniciar_al_sancionar" value="1" <%= regla.reiniciar_al_sancionar !== false ? 'checked' : '' %>>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-dark">Guardar regla</button>
        </div>
      </form>
    </div>
  </div>
</div>

