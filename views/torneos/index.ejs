const appNavToggle = document.getElementById('appNavToggle');
const appNavActions = document.getElementById('appNavActions');
let appNavCloseTimer = null;

function cerrarMenuAppNav() {
  if (!appNavActions || !appNavToggle) return;
  appNavActions.classList.remove('is-open');
  appNavToggle.setAttribute('aria-expanded', 'false');
  if (appNavCloseTimer) {
    clearTimeout(appNavCloseTimer);
    appNavCloseTimer = null;
  }
}

function programarCierreMenuAppNav() {
  if (appNavCloseTimer) clearTimeout(appNavCloseTimer);
  appNavCloseTimer = setTimeout(cerrarMenuAppNav, 3000);
}

appNavToggle?.addEventListener('click', event => {
  event.preventDefault();
  event.stopPropagation();
  const menuAbierto = appNavActions?.classList.toggle('is-open');
  appNavToggle.setAttribute('aria-expanded', menuAbierto ? 'true' : 'false');
  if (menuAbierto) {
    programarCierreMenuAppNav();
  } else {
    cerrarMenuAppNav();
  }
});

appNavActions?.addEventListener('click', event => {
  if (event.target.closest('a')) cerrarMenuAppNav();
});

document.addEventListener('click', event => {
  if (!appNavActions?.classList.contains('is-open')) return;
  if (event.target.closest('#appNavActions') || event.target.closest('#appNavToggle')) return;
  cerrarMenuAppNav();
});

document.querySelectorAll('.navbar [data-bs-toggle="tab"]').forEach(tab => {
  tab.addEventListener('shown.bs.tab', event => {
    cerrarMenuAppNav();
    const href = event.target?.getAttribute('href');
    if (!href) return;

    const urlTab = new URL(window.location.href);
    urlTab.searchParams.set('tab', href.replace('#', ''));
    urlTab.hash = href;
    history.replaceState(null, '', urlTab.toString());

    if (href !== '#partidos') {
      sessionStorage.removeItem('partidosModoAdmin');
      activarVistaPublicaPartidos();
    } else if (sessionStorage.getItem('partidosModoAdmin') !== '1') {
      activarVistaPublicaPartidos();
    }

    if (href !== '#jugadores') {
      sessionStorage.removeItem('jugadoresModoAdmin');
      sessionStorage.removeItem('jugadoresFiltroBusqueda');
      activarVistaPublicaJugadores();
    } else if (sessionStorage.getItem('jugadoresModoAdmin') !== '1') {
      activarVistaPublicaJugadores();
    }

    if (href !== '#usuarios') {
      sessionStorage.removeItem('usuariosModoAdmin');
      activarVistaPublicaUsuarios();
    } else if (sessionStorage.getItem('usuariosModoAdmin') !== '1') {
      activarVistaPublicaUsuarios();
    }

    if (href === '#torneos') {
      refrescarDashboardInicioSiNecesario();
    }

    if (href === '#finanzas') {
      sincronizarFinanzasDesdeServidor();
    }

    if (href === '#estadisticas') {
      recalcularEstadisticasCliente();
    }

    if (href === '#usuarios') {
      aplicarFiltrosUsuariosAdmin();
    }

    if (href === '#auditoria') {
      refrescarAuditoria();
    }
  });
});

