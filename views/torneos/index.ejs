  <script>
    async function confirmarPermisoAgregarJugadores(input) {
      const activar = input.checked;
      const mensaje = activar
        ? 'Si activa esta opcion, permitira que los delegados puedan ingresar nuevos jugadores a sus equipos.'
        : 'Si desactiva esta opcion, los delegados ya no podran agregar jugadores a sus equipos.';

      const confirmado = await confirmarApp(mensaje, 'Confirmar permiso', {
        aceptar: 'Aceptar',
        cancelar: 'Cancelar'
      });

      if (!confirmado) {
        input.checked = !activar;
        return;
      }

      input.closest('form').submit();
    }

    async function confirmarPermisoModificarIconos(input) {
      const activar = input.checked;
      const mensaje = activar
        ? 'Si activa esta opcion, permitira que los delegados cambien el icono de sus propios equipos.'
        : 'Si desactiva esta opcion, los delegados ya no podran cambiar iconos de sus equipos.';

      const confirmado = await confirmarApp(mensaje, 'Confirmar permiso', {
        aceptar: 'Aceptar',
        cancelar: 'Cancelar'
      });

      if (!confirmado) {
        input.checked = !activar;
        return;
      }

      input.closest('form').submit();
    }

    async function confirmarPermisoEstadoFinanzas(input) {
      const activar = input.checked;
      const mensaje = activar
        ? 'Si activa esta opcion, los delegados podran ver si otros equipos estan al dia o adeudan, sin ver importes ni detalles.'
        : 'Si desactiva esta opcion, los delegados solo veran el estado financiero de sus propios equipos.';

      const confirmado = await confirmarApp(mensaje, 'Confirmar permiso', {
        aceptar: 'Aceptar',
        cancelar: 'Cancelar'
      });

      if (!confirmado) {
        input.checked = !activar;
        return;
      }

      input.closest('form').submit();
    }
  </script>

