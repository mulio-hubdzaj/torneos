function actualizarHorarioPartidoEnVista(partidoId, partido = {}) {
  const row = document.querySelector(`tr[data-partido-row="${partidoId}"]`);
  const detalle = document.querySelector(`.partido-detalle[data-partido-id="${partidoId}"]`);
  const publicCard = document.querySelector(`[data-public-partido-card="${partidoId}"]`);
  const fechaDisplay = partido.fecha_formateada || '-';
  const horaDisplay = partido.hora || '-';
  const canchaNombre = String(partido.nombre_cancha || '').trim();

  const fechaCell = row?.querySelector('.fixture-fecha-cell');
  const horaCell = row?.querySelector('.fixture-hora-cell');
  if (fechaCell) fechaCell.textContent = fechaDisplay;
  if (horaCell) horaCell.textContent = horaDisplay;

  const fechaDetalle = detalle?.querySelector('.partido-detalle-fecha');
  const horaDetalle = detalle?.querySelector('.partido-detalle-hora');
  if (fechaDetalle) fechaDetalle.textContent = fechaDisplay;
  if (horaDetalle) horaDetalle.textContent = horaDisplay;

  let canchaWrap = detalle?.querySelector('.partido-detalle-cancha-wrap');
  if (canchaNombre && detalle && !canchaWrap) {
    canchaWrap = document.createElement('span');
    canchaWrap.className = 'partido-detalle-cancha-wrap';
    canchaWrap.innerHTML = '<i class="bi bi-geo-alt"></i> Cancha: <strong class="partido-detalle-cancha"></strong>';
    detalle.appendChild(canchaWrap);
  }

  const detalleRow = detalle?.closest('.partido-detalle-row');
  detalleRow?.classList.toggle('partido-detalle-row-cancha', Boolean(canchaNombre));

  if (canchaWrap) {
    canchaWrap.classList.toggle('d-none', !canchaNombre);
    const canchaDetalle = canchaWrap.querySelector('.partido-detalle-cancha');
    if (canchaDetalle) canchaDetalle.textContent = canchaNombre;
  }

  const publicFecha = publicCard?.querySelector('.fixture-public-fecha');
  const publicHora = publicCard?.querySelector('.fixture-public-hora');
  const publicCanchaWrap = publicCard?.querySelector('.fixture-public-cancha-wrap');
  const publicCancha = publicCard?.querySelector('.fixture-public-cancha');
  if (publicFecha) publicFecha.textContent = fechaDisplay;
  if (publicHora) publicHora.textContent = horaDisplay;
  if (publicCanchaWrap) publicCanchaWrap.classList.toggle('d-none', !canchaNombre);
  if (publicCancha) publicCancha.textContent = canchaNombre;

  const btnEditar = row?.querySelector('.editar-horario-btn');
  if (btnEditar) {
    btnEditar.dataset.fecha = partido.fecha || '';
    btnEditar.dataset.hora = partido.hora || '';
    btnEditar.dataset.canchaId = partido.id_cancha || '';
  }
}

function sumarMinutosHora(hora, minutos) {
  if (!hora) return '';
  const [hh, mm] = hora.split(':').map(Number);
  const base = new Date(2000, 0, 1, hh || 0, mm || 0, 0, 0);
  base.setMinutes(base.getMinutes() + Number(minutos || 0));
  return `${String(base.getHours()).padStart(2, '0')}:${String(base.getMinutes()).padStart(2, '0')}`;
}

function recargarManteniendoPestana(hash = '#partidos') {
  const url = new URL(window.location.href);
  url.searchParams.set('tab', hash.replace('#', ''));
  url.hash = hash;
  window.location.href = url.toString();
}

function obtenerEquiposGrupo(grupoId) {
