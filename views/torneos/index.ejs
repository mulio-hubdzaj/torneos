                  <i class="bi bi-search"></i>
                </button>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table table-sm table-hover carga-partido-table">
                <thead class="table-light">
                  <tr>
                    <th>Jugador</th>
                    <th>Goles</th>
                    <th>Amarillas</th>
                    <th>Rojas</th>
                    <th>Susp. Fechas</th>
                    <th>Motivo suspension</th>
                  </tr>
                </thead>
                <tbody id="cargaJugadoresTbody"></tbody>
              </table>
            </div>
          </div>

          <div class="tab-pane fade" id="cargaItemsTab" role="tabpanel">
            <div class="d-flex justify-content-between align-items-center mb-2">
