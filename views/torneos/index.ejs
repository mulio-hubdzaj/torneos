                      <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- pestaña Equipos -->
  <% if (rol_id == 3 || rol_id == 99) { %>
  <div class="tab-pane fade<%= paneActiva('usuarios') %>" id="usuarios">
    <div class="p-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-white mb-0">Usuarios</h3>
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-light" id="btnVistaPublicaUsuarios" title="Vista usuario">
            <i class="bi bi-eye"></i> Vista usuario
          </button>
          <button type="button" class="btn btn-outline-warning d-none" id="btnVistaAdminUsuarios" title="Habilitar administracion">
            <i class="bi bi-tools"></i> Habilitar admin
          </button>
        </div>
      </div>

      <div class="row g-2 align-items-end mb-3">
        <div class="col-md-4">
          <label class="form-label text-dark fw-bold mb-1" for="buscarUsuariosAdmin">Buscar</label>
          <div class="input-group">
            <input type="text" class="form-control text-uppercase" id="buscarUsuariosAdmin" placeholder="nombre - equipo - documento">
            <button type="button" class="btn btn-outline-light btn-buscar-gris" id="btnBuscarUsuariosAdmin" title="Buscar usuarios">
              <i class="bi bi-search"></i>
            </button>
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label text-dark fw-bold mb-1" for="filtroUsuariosRol">Rol</label>
          <select class="form-select" id="filtroUsuariosRol">
            <option value="">Todos los roles</option>
            <option value="1">Espectador</option>
            <option value="2">Delegado</option>
            <option value="3">Admin</option>
            <% if (rol_id == 99) { %>
              <option value="99">Super admin</option>
            <% } %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label text-dark fw-bold mb-1" for="filtroUsuariosEstado">Estado</label>
          <select class="form-select" id="filtroUsuariosEstado">
            <option value="" selected>Todos</option>
            <option value="1">Activos</option>
            <option value="0">Inactivos / pendientes</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label text-dark fw-bold mb-1" for="filtroUsuariosTorneo">Torneo</label>
          <select class="form-select" id="filtroUsuariosTorneo">
            <option value="">Todos los torneos</option>
            <% (torneosUsuarios || []).forEach(t => { %>
              <option value="<%= t.id_torneo %>"><%= t.nombre_torneo %> - <%= t.temporada || '' %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="text-dark fw-bold small mb-2">
        Usuarios visibles: <strong id="usuariosAdminVisibles">0</strong> / <span id="usuariosAdminTotal"><%= (usuariosAdmin || []).length %></span>
      </div>

      <div class="table-responsive usuarios-table-responsive">
        <table class="table table-sm table-striped table-hover align-middle bg-white usuarios-table" id="tablaUsuariosAdmin">
          <thead class="table-dark">
            <tr>
              <th style="width: 56px;">#</th>
              <th>Usuario</th>
              <th>Documento</th>
              <th>Rol</th>
              <th>Estado</th>
              <th>Torneo</th>
              <th>Equipo</th>
              <th class="usuarios-admin-only" style="width: 360px;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% (usuariosAdmin || []).forEach(u => { %>
              <% const vinculosUsuario = Array.isArray(u.vinculos) ? u.vinculos : []; %>
              <% const torneosUsuario = vinculosUsuario.map(v => v.id_torneo).filter(Boolean).join(','); %>
              <% const textoTorneosUsuario = vinculosUsuario.map(v => v.torneo).filter(Boolean).join(' '); %>
              <% const textoEquiposUsuario = vinculosUsuario.map(v => v.equipo).filter(Boolean).join(' '); %>
              <tr data-nombre="<%= u.nombre || '' %>"
                  data-documento="<%= u.documento || '' %>"
                  data-rol="<%= Number(u.rol_id || 0) %>"
                  data-estado="<%= u.estado ? '1' : '0' %>"
                  data-equipos="<%= textoEquiposUsuario %>"
                  data-torneos-texto="<%= textoTorneosUsuario %>"
                  data-torneos="<%= torneosUsuario %>">
                <td class="usuarios-admin-indice" data-label="#"></td>
                <td data-label="Usuario">
                  <strong><%= u.nombre %></strong>
                  <% if (u.correo) { %>
                    <br><small class="text-muted"><%= u.correo %></small>
                  <% } %>
                </td>
                <td data-label="Documento"><%= u.documento %></td>
                <td data-label="Rol">
                  <span class="badge <%= Number(u.rol_id) === 99 ? 'text-bg-danger' : (Number(u.rol_id) === 3 ? 'text-bg-primary' : 'text-bg-secondary') %>">
                    <%= u.rol_nombre %>
                  </span>
                </td>
                <td data-label="Estado">
                  <span class="badge <%= u.estado ? 'text-bg-success' : 'text-bg-secondary' %>">
                    <%= u.estado ? 'Activo' : 'Inactivo' %>
                  </span>
                </td>
                <td data-label="Torneo">
                  <% if (vinculosUsuario.length > 0) { %>
                    <% vinculosUsuario.forEach(v => { %>
                      <span class="badge text-bg-light border me-1 mb-1"><%= v.torneo || 'Sin torneo' %></span>
                    <% }) %>
                  <% } else { %>
                    <span class="text-muted">Sin vinculo</span>
                  <% } %>
                </td>
                <td data-label="Equipo">
                  <% if (vinculosUsuario.length > 0) { %>
                    <% vinculosUsuario.forEach(v => { %>
                      <div>
                        <strong><%= v.equipo || 'Sin equipo' %></strong>
                        <small class="text-muted">(<%= v.rol_equipo || 'delegado' %><%= v.estado_vinculo ? '' : ', inactivo' %>)</small>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <span class="text-muted">Sin equipo</span>
                  <% } %>
                </td>
                <td class="usuarios-admin-only">
                  <div class="d-flex flex-wrap gap-1">
                    <form action="/torneos/<%= torneo.id_torneo %>/usuarios/<%= u.id_usuario %>/toggle" method="POST">
                      <button type="submit" class="btn btn-sm <%= u.estado ? 'btn-outline-warning' : 'btn-outline-success' %>">
                        <i class="bi <%= u.estado ? 'bi-person-slash' : 'bi-person-check' %>"></i>
                        <%= u.estado ? 'Desactivar' : 'Aprobar / activar' %>
                      </button>
                    </form>
                    <% if (rol_id == 99 || Number(u.rol_id) !== 99) { %>
                      <form action="/torneos/<%= torneo.id_torneo %>/usuarios/<%= u.id_usuario %>/permisos" method="POST"
                            class="d-flex gap-1"
                            onsubmit="confirmarCambioPermisosUsuario(event)">
                        <select name="rol_id" class="form-select form-select-sm" aria-label="Cambiar permisos">
                          <option value="1" <%= Number(u.rol_id) === 1 ? 'selected' : '' %>>Espectador</option>
                          <option value="3" <%= Number(u.rol_id) === 3 ? 'selected' : '' %>>Admin</option>
                          <% if (rol_id == 99) { %>
                            <option value="99" <%= Number(u.rol_id) === 99 ? 'selected' : '' %>>Super admin</option>
                          <% } %>
                        </select>
                        <button type="submit" class="btn btn-sm btn-outline-primary">
                          <i class="bi bi-shield-check"></i> Cambiar permisos
                        </button>
                      </form>
                    <% } else { %>
                      <span class="text-muted small">Super admin protegido</span>
                    <% } %>
                    <% if (rol_id == 99 || Number(u.rol_id) !== 99) { %>
                      <form action="/torneos/<%= torneo.id_torneo %>/usuarios/<%= u.id_usuario %>/reset-password" method="POST"
                            onsubmit="confirmarResetPassword(event)">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-key"></i> Resetear clave
                        </button>
                      </form>
                    <% } %>
                    <% if (rol_id == 99) { %>
                      <button type="button"
                              class="btn btn-sm btn-outline-dark btn-editar-usuario-admin"
                              data-id="<%= u.id_usuario %>"
                              data-nombre="<%= u.nombre || '' %>"
                              data-documento="<%= u.documento || '' %>"
                              data-correo="<%= u.correo || '' %>">
                        <i class="bi bi-pencil-square"></i> Editar datos
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

  <% if (rol_id == 99) { %>
