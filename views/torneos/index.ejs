// Actualizar validación en tiempo real
function actualizarValidacion() {
  const tipo = document.querySelector('input[name="tipo"]:checked').value;
  const numFechas = document.getElementById('numFechas');
  const grupNumFechas = document.getElementById('grupNumFechas');
  const alertaValidacion = document.getElementById('alertaValidacion');
  const textNumFechasInfo = document.getElementById('textNumFechasInfo');

  // Mostrar/ocultar campo de fechas
  if (tipo === 'fijo') {
    grupNumFechas.style.display = 'block';
    textNumFechasInfo.textContent = `Ingrese un número entre 1 y ${numEquiposActual * 2}`;
  } else {
    grupNumFechas.style.display = 'none';
  }

  // Calcular fechas automáticamente
  let fechas = 0;
  const maxSimple = numEquiposActual % 2 === 1 ? numEquiposActual : numEquiposActual - 1;
  if (tipo === 'simple') {
    fechas = maxSimple;
  } else if (tipo === 'ida_vuelta') {
    fechas = maxSimple * 2;
  } else if (tipo === 'fijo') {
    fechas = parseInt(numFechas.value) || 0;
  }

  // Actualizar resumen
  actualizarResumen(tipo, fechas);

  // Validar si es fijo
  if (tipo === 'fijo' && numFechas.value) {
    const validacion = validarFechas(numEquiposActual, fechas);
    alertaValidacion.innerHTML = validacion.mensaje;
    alertaValidacion.className = `alert alert-${validacion.tipo} mt-3`;
    alertaValidacion.style.display = 'block';
  } else {
    alertaValidacion.style.display = 'none';
  }
}

// Actualizar resumen de estadísticas
function actualizarResumen(tipo, fechas) {
  const maxPartidosPorEquipo = (numEquiposActual - 1) * 2;
  const partidosPorEquipo = Math.min(maxPartidosPorEquipo, fechas);
  const totalPartidos = Math.floor((numEquiposActual * partidosPorEquipo) / 2);

  document.getElementById('resumenEquipos').textContent = numEquiposActual;
  document.getElementById('resumenFechas').textContent = fechas || '-';
  document.getElementById('resumenPartidosEquipo').textContent = partidosPorEquipo || '-';
  document.getElementById('resumenTotalPartidos').textContent = totalPartidos || '-';
}

// Confirmar y ejecutar sorteo
async function confirmarSorteo() {
  const tipo = document.querySelector('input[name="tipo"]:checked').value;
  let numFechas = 0;

  const maxSimple = numEquiposActual % 2 === 1 ? numEquiposActual : numEquiposActual - 1;
  if (tipo === 'simple') {
    numFechas = maxSimple;
  } else if (tipo === 'ida_vuelta') {
    numFechas = maxSimple * 2;
  } else if (tipo === 'fijo') {
    numFechas = parseInt(document.getElementById('numFechas').value);
  }

  if (!numFechas || numFechas <= 0) {
    mostrarAvisoApp('Por favor, ingrese un número válido de fechas.', 'Sorteo');
    return;
  }

  const btnConfirmar = document.getElementById('btnConfirmarSorteo');
  btnConfirmar.disabled = true;
  btnConfirmar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

  try {
    const response = await fetch(`/partidos/torneos/${torneoActual}/grupos/${grupoActual}/sortear`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        tipo: tipo,
        numFechas: numFechas
      })
    });

    const data = await response.json();

    if (data.success) {
      // Mostrar mensaje de éxito
      const modal = bootstrap.Modal.getInstance(document.getElementById('modalSorteoFase2'));
      modal.hide();
      
      setTimeout(() => {
        mostrarAvisoApp(data.message || 'Sorteo generado correctamente.', 'Sorteo');
        document.getElementById('modalAvisoApp')?.addEventListener('hidden.bs.modal', () => {
          recargarManteniendoPestana('#partidos');
        }, { once: true });
      }, 300);
    } else {
      mostrarAvisoApp(data.message || 'No se pudo generar el sorteo.', 'Sorteo');
      btnConfirmar.disabled = false;
      btnConfirmar.innerHTML = '<i class="fas fa-check"></i> Confirmar Sorteo';
    }
  } catch (error) {
    console.error('Error:', error);
    mostrarAvisoApp('Error al procesar el sorteo.', 'Sorteo');
    btnConfirmar.disabled = false;
    btnConfirmar.innerHTML = '<i class="fas fa-check"></i> Confirmar Sorteo';
  }
}

function obtenerGruposCombinadosSeleccionados() {
  return Array.from(document.querySelectorAll('.sorteo-combinado-grupo:checked')).map(input => ({
    id: input.value,
    nombre: input.dataset.nombre || 'Grupo',
    equipos: parseInt(input.dataset.equipos || '0', 10) || 0
  }));
}

function calcularMaxFechasSorteoCombinado(gruposSeleccionados, tipo) {
  if (!gruposSeleccionados.length) return 0;
  const maxSimple = Math.max(...gruposSeleccionados.map(grupo => (
    grupo.equipos % 2 === 1 ? grupo.equipos : grupo.equipos - 1
  )));
  return tipo === 'ida_vuelta' ? maxSimple * 2 : maxSimple;
}

function evaluarEquilibrioSorteoCombinado(gruposSeleccionados, fechas) {
  if (!gruposSeleccionados.length || !fechas) {
    return { equilibrado: false, detalle: 'Seleccione grupos y cantidad de fechas.' };
  }

  const gruposImpares = gruposSeleccionados.filter(grupo => grupo.equipos % 2 === 1);
  if (gruposImpares.length % 2 === 0) {
    return {
      equilibrado: true,
      detalle: `Todos los equipos jugaran ${fechas} encuentros. Los libres se cruzaran como CONV.`
    };
  }

  const nombresImpares = gruposImpares.map(grupo => grupo.nombre).join(', ');
  return {
    equilibrado: false,
    detalle: `Atencion: hay una cantidad impar de grupos con equipos impares (${nombresImpares}). En cada fecha quedara al menos un libre sin cruce CONV, por lo que no todos jugaran la misma cantidad de encuentros.`
  };
}

function reiniciarFechasSorteoCombinado() {
  const inputFechas = document.getElementById('numFechasCombinado');
  if (inputFechas) {
    inputFechas.dataset.editado = '0';
    inputFechas.value = '';
  }
  actualizarResumenSorteoCombinado();
}

function alternarFechasExactasCombinado() {
  const inputFechas = document.getElementById('numFechasCombinado');
  const usarExactas = document.getElementById('usarFechasExactasCombinado')?.checked;
  if (!inputFechas) return;

  inputFechas.readOnly = !usarExactas;
  inputFechas.dataset.editado = usarExactas ? '1' : '0';
  if (!usarExactas) inputFechas.value = '';
  actualizarResumenSorteoCombinado();
  if (usarExactas) inputFechas.focus();
}

function actualizarResumenSorteoCombinado() {
  const gruposSeleccionados = obtenerGruposCombinadosSeleccionados();
  const tipo = document.querySelector('input[name="tipoCombinado"]:checked')?.value || 'simple';
  const inputFechas = document.getElementById('numFechasCombinado');
  const resumen = document.getElementById('resumenSorteoCombinado');
  const btnConfirmar = document.getElementById('btnConfirmarSorteoCombinado');
  const usarExactas = document.getElementById('usarFechasExactasCombinado')?.checked;

  if (!resumen || !btnConfirmar || !inputFechas) return;

  const fechasSugeridas = calcularMaxFechasSorteoCombinado(gruposSeleccionados, tipo);
  inputFechas.readOnly = !usarExactas;
  if ((!inputFechas.value || !usarExactas) && fechasSugeridas > 0 && inputFechas.dataset.editado !== '1') {
    inputFechas.value = fechasSugeridas;
  }

  const fechas = parseInt(inputFechas.value || '0', 10);
  btnConfirmar.disabled = gruposSeleccionados.length < 2 || !fechas || fechas <= 0;

  if (gruposSeleccionados.length < 2) {
    resumen.className = 'alert alert-info mb-0';
    resumen.textContent = 'Seleccione al menos dos grupos.';
    return;
  }

  const nombres = gruposSeleccionados.map(grupo => `${grupo.nombre} (${grupo.equipos})`).join(', ');
  const modalidad = tipo === 'ida_vuelta' ? 'ida y vuelta' : 'solo ida';
  const fechasCompletas = calcularMaxFechasSorteoCombinado(gruposSeleccionados, tipo);
  const esCantidadCompleta = fechas === fechasCompletas;
  const equilibrio = evaluarEquilibrioSorteoCombinado(gruposSeleccionados, fechas);
  resumen.className = `alert alert-${equilibrio.equilibrado ? 'success' : 'danger'} mb-0`;
  resumen.innerHTML = `Se sortearan <strong>${nombres}</strong> en modalidad <strong>${modalidad}</strong>, con <strong>${fechas || '-'}</strong> fechas. `
    + `Cantidad sugerida: <strong>${fechasCompletas}</strong>. `
    + (usarExactas && !esCantidadCompleta ? 'La cantidad exacta puede repetir parte del calendario interno. ' : '')
    + `<strong>${equilibrio.equilibrado ? 'Equilibrado:' : 'Revisar:'}</strong> ${equilibrio.detalle} `
    + 'Los libres coincidentes se cruzaran como <strong>CONV</strong>.';
}

async function confirmarSorteoCombinado() {
  const gruposSeleccionados = obtenerGruposCombinadosSeleccionados();
  const tipo = document.querySelector('input[name="tipoCombinado"]:checked')?.value || 'simple';
  const numFechas = parseInt(document.getElementById('numFechasCombinado')?.value || '0', 10);

  if (gruposSeleccionados.length < 2) {
    mostrarAvisoApp('Seleccione al menos dos grupos sin sorteo.', 'Sorteos combinados');
    return;
  }

  if (!numFechas || numFechas <= 0) {
    mostrarAvisoApp('Ingrese una cantidad valida de fechas.', 'Sorteos combinados');
    return;
  }

  const confirmado = await confirmarApp(
    'Se generara el fixture de cada grupo seleccionado y se cruzaran los equipos libres como CONV. Esta accion no debe repetirse sobre grupos ya sorteados.',
    'Confirmar sorteo combinado',
    {
      aceptar: 'Si, sortear',
      cancelar: 'Cancelar',
      destacar: true
    }
  );
  if (!confirmado) return;

  const btnConfirmar = document.getElementById('btnConfirmarSorteoCombinado');
  btnConfirmar.disabled = true;
  btnConfirmar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

  try {
    const response = await fetch('/partidos/torneos/<%= torneo.id_torneo %>/sortear-combinado', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        grupos: gruposSeleccionados.map(grupo => grupo.id),
        tipo,
        numFechas
      })
    });

    const data = await response.json();
    if (!response.ok || !data.success) {
      mostrarAvisoApp(data.message || 'No se pudo generar el sorteo combinado.', 'Sorteos combinados');
      btnConfirmar.disabled = false;
      btnConfirmar.innerHTML = '<i class="bi bi-check2"></i> Confirmar sorteo';
      return;
    }

    bootstrap.Modal.getInstance(document.getElementById('modalSorteoCombinado'))?.hide();
    setTimeout(() => {
      mostrarAvisoApp(data.message || 'Sorteo combinado generado correctamente.', 'Sorteos combinados');
      document.getElementById('modalAvisoApp')?.addEventListener('hidden.bs.modal', () => {
        recargarManteniendoPestana('#partidos');
      }, { once: true });
    }, 300);
  } catch (error) {
    console.error(error);
    mostrarAvisoApp('Error al procesar el sorteo combinado.', 'Sorteos combinados');
    btnConfirmar.disabled = false;
    btnConfirmar.innerHTML = '<i class="bi bi-check2"></i> Confirmar sorteo';
  }
}

