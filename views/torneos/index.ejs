function aplicarFiltrosAuditoria() {
  const filtros = {};
  document.querySelectorAll('.audit-filter').forEach(input => {
    filtros[input.dataset.col] = (input.value || '').trim().toUpperCase();
  });

  document.querySelectorAll('#tablaAuditoria tbody tr').forEach(row => {
    if (!row.dataset.pantalla) return;
    const visible = Object.entries(filtros).every(([col, valor]) => {
      if (!valor) return true;
      return String(row.dataset[col] || '').toUpperCase().includes(valor);
    });
    row.classList.toggle('d-none', !visible);
  });
}

document.querySelectorAll('.audit-filter').forEach(input => {
  input.addEventListener('input', aplicarFiltrosAuditoria);
});

document.querySelectorAll('.dashboard-tab-link').forEach(btn => {
  btn.addEventListener('click', () => {
    const targetTab = btn.dataset.targetTab;
    const targetSubtab = btn.dataset.targetSubtab;
    const trigger = document.querySelector(`.navbar [href="${targetTab}"]`);

    if (trigger) {
      bootstrap.Tab.getOrCreateInstance(trigger).show();
      window.location.hash = targetTab;
    }

    if (targetSubtab) {
      setTimeout(() => {
        const subtrigger = document.querySelector(`[data-bs-target="${targetSubtab}"]`);
        if (subtrigger) bootstrap.Tab.getOrCreateInstance(subtrigger).show();
      }, 60);
    }
  });
});

function claseAccionAuditoria(accion) {
  if (accion === 'DELETE') return 'text-bg-danger';
  if (accion === 'UPDATE') return 'text-bg-primary';
  if (accion === 'INGRESO') return 'text-bg-dark';
  return 'text-bg-success';
}

function formatoFechaAuditoria(valor) {
  const fecha = valor ? new Date(valor) : null;
  return fecha && !Number.isNaN(fecha.getTime())
    ? fecha.toLocaleString('es-PY', { dateStyle: 'short', timeStyle: 'short' })
    : '-';
}

async function refrescarAuditoria() {
  const tbody = document.getElementById('auditoriaTbody');
  if (!tbody) return;

  try {
    const response = await fetch('/torneos/<%= torneo.id_torneo %>/auditoria/resumen');
    const data = await response.json();
    if (!data.success) return;

    const registros = data.auditoria || [];
    if (!registros.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">No hay movimientos de auditoría para este contexto.</td></tr>';
      return;
    }

    tbody.innerHTML = registros.map(registro => `
      <tr data-pantalla="${escaparHtml(registro.pantalla || '')}"
          data-afectado="${escaparHtml(registro.afectado || '')}"
          data-accion="${escaparHtml(registro.accion || '')}"
          data-usuario="${escaparHtml([registro.usuario_display, registro.usuario_documento_display].filter(Boolean).join(' '))}"
          data-detalle="${escaparHtml(registro.detalle_legible || '')}">
        <td><small>${formatoFechaAuditoria(registro.fecha_hora)}</small></td>
        <td>${escaparHtml(registro.pantalla || '-')}</td>
        <td>${escaparHtml(registro.afectado || '-')}</td>
        <td><span class="badge ${claseAccionAuditoria(registro.accion)}">${escaparHtml(registro.accion || '-')}</span></td>
        <td>
          <strong>${escaparHtml(registro.usuario_display || 'Sistema')}</strong>
          ${registro.usuario_documento_display ? `<br><small class="text-muted">${escaparHtml(registro.usuario_documento_display)}</small>` : ''}
        </td>
        <td>${escaparHtml(registro.detalle_legible || '-')}</td>
      </tr>
    `).join('');
    aplicarFiltrosAuditoria();
  } catch (error) {
    console.error('Error al refrescar auditoria:', error);
  }
}

function inicializarNavegadorFechasFixture() {
  const contenedor = document.getElementById('fechasTab');
  const tabActual = document.getElementById('fechaActualTab');
  const btnAnterior = document.getElementById('btnFechaAnterior');
  const btnSiguiente = document.getElementById('btnFechaSiguiente');
  const tabsOcultos = Array.from(document.querySelectorAll('#fechasTabOculto .fixture-fecha-tab'));
  if (!contenedor || !tabActual || !btnAnterior || !btnSiguiente || !tabsOcultos.length) return;

  const limpiarTextoFecha = texto => (texto || '').replace(/\s+/g, ' ').trim();
  let indiceActivo = Number.parseInt(contenedor.dataset.fechaActivaIndex || '0', 10);
  if (!Number.isFinite(indiceActivo) || indiceActivo < 0) indiceActivo = 0;

  function sincronizarNavegador(indice) {
    indiceActivo = Math.max(0, Math.min(indice, tabsOcultos.length - 1));
    const tabDestino = tabsOcultos[indiceActivo];
    if (!tabDestino) return;

    bootstrap.Tab.getOrCreateInstance(tabDestino).show();
    tabActual.textContent = limpiarTextoFecha(tabDestino.textContent);
    tabActual.dataset.bsTarget = tabDestino.dataset.bsTarget || '';
    tabActual.setAttribute('aria-controls', tabDestino.getAttribute('aria-controls') || '');
    btnAnterior.disabled = indiceActivo <= 0;
    btnSiguiente.disabled = indiceActivo >= tabsOcultos.length - 1;
    contenedor.dataset.fechaActivaIndex = String(indiceActivo);

    const numeroFecha = (tabDestino.id || '').replace('fecha-', '').replace('-tab', '');
    if (numeroFecha) {
      const url = new URL(window.location.href);
      url.searchParams.set('fecha', numeroFecha);
      url.searchParams.set('tab', 'partidos');
      url.searchParams.delete('fecha_calendario');
      history.replaceState(null, '', `${url.pathname}${url.search}#partidos`);
    }
  }

  btnAnterior.addEventListener('click', () => sincronizarNavegador(indiceActivo - 1));
  btnSiguiente.addEventListener('click', () => sincronizarNavegador(indiceActivo + 1));
  tabActual.addEventListener('click', () => sincronizarNavegador(indiceActivo));
}

inicializarNavegadorFechasFixture();

