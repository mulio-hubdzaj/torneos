                  <tr>
                    <th>Item</th>
                    <th>Monto</th>
                    <th>Cant.</th>
                    <th>Observacion</th>
                    <th class="text-end">Total</th>
                    <th>Agregado</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="cargaItemsTbody"></tbody>
              </table>
            </div>
            <div class="carga-resumen small">
              El saldo se calcula como deuda anterior + items del encuentro - entrega del delegado.
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="cerrarModalBootstrapSeguro('modalCargaEquipoPartido')">Cancelar</button>
        <button type="button" class="btn btn-success" onclick="guardarCargaEquipoPartido()">
