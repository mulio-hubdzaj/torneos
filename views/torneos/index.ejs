let dashboardEnCursoRefrescoActivo = false;

async function refrescarDashboardEnCurso(opciones = {}) {
  const forzar = Boolean(opciones.forzar);
  if (!document.querySelector('[data-dashboard-en-curso-partido]')) return;
  if (!forzar && document.hidden) return;
  if (dashboardEnCursoRefrescoActivo) return;

  dashboardEnCursoRefrescoActivo = true;
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 8000);
  try {
    const response = await fetch(dashboardEnCursoResumenUrl, {
      headers: { 'Accept': 'application/json' },
      cache: 'no-store',
      signal: controller.signal
    });
    const data = await response.json();
    if (!data.success) return;

    const partidos = data.partidos || [];
    partidos.forEach(partido => {
      const row = document.querySelector(`[data-dashboard-en-curso-partido="${partido.id_partido}"]`);
      if (!row) return;

      const titulo = row.querySelector('strong.d-block');
      if (titulo) {
        titulo.innerHTML = `
          <span class="dashboard-score-team">${escaparHtml(partido.nombre_equipo_a || 'Equipo A')}</span>
          <span class="dashboard-score-box">${Number(partido.goles_a || 0)} - ${Number(partido.goles_b || 0)}</span>
          <span class="dashboard-score-team">${escaparHtml(partido.nombre_equipo_b || 'Equipo B')}</span>
        `;
      }
      renderDashboardEnCursoStats(partido);
    });
  } catch (error) {
    if (error.name !== 'AbortError') {
      console.warn('No se pudo actualizar En curso:', error);
    }
  } finally {
    clearTimeout(timeout);
    dashboardEnCursoRefrescoActivo = false;
  }
}

document.addEventListener('DOMContentLoaded', () => {
  refrescarDashboardEnCurso({ forzar: true });
});

function mostrarAvisoApp(mensaje, titulo = 'Atencion') {
  const modalEl = document.getElementById('modalAvisoApp');
  if (!modalEl) {
    console.warn(mensaje);
    return;
  }

  limpiarBotonesExtraModalAviso();
  document.getElementById('modalAvisoAppTitulo').textContent = titulo;
  const mensajeEl = document.getElementById('modalAvisoAppMensaje');
  mensajeEl.textContent = mensaje;
  const esAvisoAcumulacion = String(mensaje || '').includes('El jugador alcanzo el limite de amarillas');
  mensajeEl.classList.toggle('text-dark', !esAvisoAcumulacion);
  mensajeEl.classList.toggle('text-danger', esAvisoAcumulacion);
  mensajeEl.classList.toggle('fw-bold', esAvisoAcumulacion);
  document.getElementById('modalAvisoAppCancelar').classList.add('d-none');
  const btnAceptarAviso = document.getElementById('modalAvisoAppAceptar');
  btnAceptarAviso.textContent = 'Aceptar';
  btnAceptarAviso.className = 'btn btn-success';
  btnAceptarAviso.onclick = () => {
    bootstrap.Modal.getOrCreateInstance(modalEl).hide();
  };

  bootstrap.Modal.getOrCreateInstance(modalEl).show();
}

function esMensajeAcumulacionTarjetas(mensaje = '', titulo = '') {
  const texto = `${titulo} ${mensaje}`.toLowerCase();
  return texto.includes('limite de amarillas') ||
    texto.includes('acumulacion de amarillas') ||
    texto.includes('confirmar suspension');
}

function confirmarApp(mensaje, titulo = 'Confirmar', opciones = {}) {
  const modalEl = document.getElementById('modalAvisoApp');
  if (!modalEl) {
    console.warn(mensaje);
    return Promise.resolve(false);
  }

  limpiarBotonesExtraModalAviso();
  return new Promise(resolve => {
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    const btnCancelar = document.getElementById('modalAvisoAppCancelar');
    const btnAceptar = document.getElementById('modalAvisoAppAceptar');
    let respondido = false;

    document.getElementById('modalAvisoAppTitulo').textContent = titulo;
    const mensajeEl = document.getElementById('modalAvisoAppMensaje');
    mensajeEl.textContent = mensaje;
    const destacarMensaje = opciones.destacar === true || esMensajeAcumulacionTarjetas(mensaje, titulo);
    mensajeEl.classList.toggle('text-dark', !destacarMensaje);
    mensajeEl.classList.toggle('text-danger', destacarMensaje);
    mensajeEl.classList.toggle('fw-bold', destacarMensaje);
    btnCancelar.classList.remove('d-none');
    btnCancelar.textContent = opciones.cancelar || 'Cancelar';
    btnCancelar.className = 'btn btn-outline-primary';
    btnAceptar.textContent = opciones.aceptar || 'Continuar';
    btnAceptar.className = 'btn btn-success';

    const finalizar = respuesta => {
      respondido = true;
      modal.hide();
      resolve(respuesta);
    };

    btnCancelar.onclick = () => finalizar(false);
    btnAceptar.onclick = () => finalizar(true);

    modalEl.addEventListener('hidden.bs.modal', () => {
      if (!respondido) resolve(false);
    }, { once: true });

    modal.show();
  });
}

function limpiarBotonesExtraModalAviso() {
  document.querySelectorAll('#modalAvisoApp .modal-aviso-extra').forEach(btn => btn.remove());
}

function normalizarEstadoPartidoCliente(estado) {
  return String(estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_');
}

function elegirEstadoMarcador(mensaje, titulo = 'Estado del encuentro') {
  const modalEl = document.getElementById('modalAvisoApp');
  if (!modalEl) return Promise.resolve(null);
  limpiarBotonesExtraModalAviso();

  return new Promise(resolve => {
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    const btnCancelar = document.getElementById('modalAvisoAppCancelar');
    const btnAceptar = document.getElementById('modalAvisoAppAceptar');
    const btnEnCurso = document.createElement('button');
    let respondido = false;

    document.getElementById('modalAvisoAppTitulo').textContent = titulo;
    const mensajeEl = document.getElementById('modalAvisoAppMensaje');
    mensajeEl.textContent = mensaje;
    mensajeEl.classList.add('text-dark');
    mensajeEl.classList.remove('text-danger', 'fw-bold');

    btnCancelar.classList.remove('d-none');
    btnCancelar.textContent = 'Cancelar';
    btnCancelar.className = 'btn btn-outline-secondary';
    btnEnCurso.type = 'button';
    btnEnCurso.className = 'btn btn-warning modal-aviso-extra';
    btnEnCurso.textContent = 'En curso';
    btnAceptar.textContent = 'Finalizado';
    btnAceptar.className = 'btn btn-success';
    btnAceptar.parentNode.insertBefore(btnEnCurso, btnAceptar);

    const finalizar = respuesta => {
      respondido = true;
      limpiarBotonesExtraModalAviso();
      modal.hide();
      resolve(respuesta);
    };

    btnCancelar.onclick = () => finalizar(null);
    btnEnCurso.onclick = () => finalizar('en_curso');
    btnAceptar.onclick = () => finalizar('finalizado');

    modalEl.addEventListener('hidden.bs.modal', () => {
      limpiarBotonesExtraModalAviso();
      if (!respondido) resolve(null);
    }, { once: true });

    modal.show();
  });
}

