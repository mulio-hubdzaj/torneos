              <th>Fecha</th>
              <th>Pantalla</th>
              <th>Equipo / afectado</th>
              <th>Acción</th>
              <th>Usuario</th>
              <th>Detalle</th>
            </tr>
            <tr class="table-light">
              <th></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="pantalla" placeholder="Filtrar"></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="afectado" placeholder="Filtrar"></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="accion" placeholder="Filtrar"></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="usuario" placeholder="Filtrar"></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="detalle" placeholder="Filtrar"></th>
            </tr>
          </thead>
          <tbody id="auditoriaTbody">
            <% if (!(auditoria || []).length) { %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">No hay movimientos de auditoría para este contexto.</td>
              </tr>
            <% } %>
            <% (auditoria || []).forEach(registro => { %>
              <% const fechaAudit = registro.fecha_hora ? new Date(registro.fecha_hora) : null; %>
              <tr data-pantalla="<%= registro.pantalla || '' %>"
                  data-afectado="<%= registro.afectado || '' %>"
                  data-accion="<%= registro.accion || '' %>"
                  data-usuario="<%= [registro.usuario_display, registro.usuario_documento_display].filter(Boolean).join(' ') %>"
                  data-detalle="<%= registro.detalle_legible || '' %>">
                <td>
                  <small>
                    <%= fechaAudit && !Number.isNaN(fechaAudit.getTime()) ? fechaAudit.toLocaleString('es-PY', { dateStyle: 'short', timeStyle: 'short' }) : '-' %>
                  </small>
                </td>
                <td><%= registro.pantalla || '-' %></td>
                <td><%= registro.afectado || '-' %></td>
                <td>
                  <span class="badge <%= registro.accion === 'DELETE' ? 'text-bg-danger' : (registro.accion === 'UPDATE' ? 'text-bg-primary' : (registro.accion === 'INGRESO' ? 'text-bg-dark' : 'text-bg-success')) %>">
                    <%= registro.accion %>
                  </span>
                </td>
                <td>
                  <strong><%= registro.usuario_display || 'Sistema' %></strong>
                  <% if (registro.usuario_documento_display) { %>
                    <br><small class="text-muted"><%= registro.usuario_documento_display %></small>
                  <% } %>
                </td>
                <td><%= registro.detalle_legible || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

  <div class="tab-pane fade tab-pane-spaced" id="equipos">
  <div class="card bg-light bg-opacity-75 p-3 shadow">
    <div class="d-flex justify-content-between align-items-center mb-3 jugadores-header">
      <h3 class="mb-0">Equipos</h3>
      <% if (rol_id == 3 || rol_id == 99) { %>
        <form action="/torneos/<%= torneo.id_torneo %>/permitir-agregar-jugadores"
              method="POST"
              class="form-switch-agregar-jugadores">
          <input type="hidden"
                 name="permitir_agregar_jugadores"
                 value="<%= torneo.permitir_agregar_jugadores === false ? '1' : '0' %>">
          <div class="form-check form-switch mb-0">
            <input class="form-check-input"
                   type="checkbox"
                   role="switch"
                   id="switchAgregarJugadoresDelegados"
                   onchange="confirmarPermisoAgregarJugadores(this)"
                   <%= torneo.permitir_agregar_jugadores === false ? '' : 'checked' %>>
            <label class="form-check-label" for="switchAgregarJugadoresDelegados">
              Delegados agregan jugadores
            </label>
          </div>
        </form>
      <% } %>
    </div>

    <% if (torneo.Equipos && torneo.Equipos.length > 0) { %>
      <ul class="list-group">
        <% torneo.Equipos.forEach(equipo => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span class="<%= !equipo.estado ? 'text-muted' : '' %>">
              <%= equipo.nombre %>
            </span>

            <div class="d-flex align-items-center">
              <!-- Switch activar/desactivar -->
              <% if (rol_id == 3 || rol_id == 99) { %>
                <form action="/equipos/toggle/<%= equipo.id_equipo %>" method="POST" class="me-3 form-toggle-equipo">
                  <input type="hidden" name="confirmar_desactivacion" value="0">
                  <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" 
                           data-equipo-nombre="<%= equipo.nombre %>"
                           data-partidos-pendientes="<%= equipo.partidos_pendientes || 0 %>"
                           onchange="confirmarToggleEquipo(this)" 
                           <%= equipo.estado ? 'checked' : '' %>>
                  </div>
                </form>
              <% } %>

              <!-- Icono ojo para ver alineaciones -->
              <a href="/equipos/ver/<%= equipo.id_equipo %>?returnUrl=<%= encodeURIComponent('/torneos/gestionar/' + torneo.id_torneo + '#equipos') %>" 
                 class="btn btn-sm btn-info me-2">
                <i class="bi bi-eye-fill"></i> <!-- Bootstrap icon ojo -->
              </a>

              <!-- Icono engranaje para administrar -->
              <% const puedeAdministrarEquipo = (rol_id == 3 || rol_id == 99 || (rol_id == 2 && equipo.es_equipo_delegado)); %>
              <% if (equipo.estado && puedeAdministrarEquipo) { %>
                <a href="/equipos/administrar/<%= equipo.id_equipo %>" 
                   class="btn btn-sm btn-secondary">
                  <i class="bi bi-gear-fill"></i> <!-- Bootstrap icon engranaje -->
                </a>
              <% } else if (rol_id == 2 && !equipo.es_equipo_delegado) { %>
                <button class="btn btn-sm btn-outline-secondary" disabled title="Solo puede administrar su equipo vinculado">
                  <i class="bi bi-lock"></i>
                </button>
              <% } else { %>
                <button class="btn btn-sm btn-secondary" disabled>
                  <i class="bi bi-gear-fill"></i>
                </button>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="text-muted">No hay equipos creados aún.</p>
    <% } %>
  </div>
  </div>



  <!-- pestaña jugadores -->
  <script>
    async function confirmarPermisoAgregarJugadores(input) {
      const activar = input.checked;
      const mensaje = activar
        ? 'Si activa esta opcion, permitira que los delegados puedan ingresar nuevos jugadores a sus equipos.'
        : 'Si desactiva esta opcion, los delegados ya no podran agregar jugadores a sus equipos.';

      const confirmado = await confirmarApp(mensaje, 'Confirmar permiso', {
        aceptar: 'Aceptar',
        cancelar: 'Cancelar'
      });

      if (!confirmado) {
        input.checked = !activar;
        return;
      }

      input.closest('form').submit();
    }
  </script>

