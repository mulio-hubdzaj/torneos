      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title">Asignar Delegados</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <%- include('../partials/listaUsuarios', { usuarios: usuarios, id_torneo: id_torneo }) %>
        </div>

        <div class="modal-footer">
          <button type="submit" class="btn btn-success">Guardar</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
        </div>
      </div>
    </div>
  </div>
</form>


<script>
document.querySelectorAll('.form-agregar-equipo').forEach(form => {
  form.addEventListener('submit', async event => {
    if (form.dataset.confirmadoMudanza === '1') return;

    event.preventDefault();
    const formData = new FormData(form);
    const params = new URLSearchParams(formData);

    try {
      const response = await fetch('/equipos/validarMudanza', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: params.toString()
      });
      const data = await response.json();

      if (!data.ok) {
        mostrarAvisoApp(data.message || 'No se pudo validar el equipo.', 'Equipos');
        return;
      }

      if (data.requiereConfirmacion) {
        const confirmado = await confirmarApp(
          data.message || 'Este equipo ya pertenece a otro grupo. ¿Desea moverlo?',
          'Mover equipo',
          {
            aceptar: 'Sí, mover equipo',
            cancelar: 'Cancelar'
          }
        );
        if (!confirmado) return;

        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'confirmar_mudanza';
        input.value = '1';
        form.appendChild(input);
      }

      form.dataset.confirmadoMudanza = '1';
      form.submit();
    } catch (error) {
      console.error('Error al validar mudanza:', error);
      mostrarAvisoApp('Error al validar el equipo.', 'Equipos');
    }
  });
});

function aplicarBusquedaJugadores() {
  const inputBusqueda = document.getElementById('buscarJugadores');
  const busqueda = (inputBusqueda?.value || '').trim().toUpperCase();
  sessionStorage.setItem('jugadoresFiltroBusqueda', inputBusqueda?.value || '');

  document.querySelectorAll('#jugadores tbody tr').forEach(row => {
    const nombreFila = (row.dataset.nombre || '').toUpperCase();
    const documentoFila = (row.dataset.documento || '').toUpperCase();
    const equipoFila = (row.dataset.equipo || '').toUpperCase();
    const coincide = !busqueda
      || nombreFila.includes(busqueda)
      || documentoFila.includes(busqueda)
      || equipoFila.includes(busqueda);

    row.classList.toggle('d-none', !coincide);
  });
}

document.getElementById('btnBuscarJugadores')?.addEventListener('click', aplicarBusquedaJugadores);
document.getElementById('buscarJugadores')?.addEventListener('keydown', event => {
  if (event.key === 'Enter') aplicarBusquedaJugadores();
});
const filtroJugadoresGuardado = sessionStorage.getItem('jugadoresFiltroBusqueda');
if (filtroJugadoresGuardado !== null) {
  const inputBuscarJugadores = document.getElementById('buscarJugadores');
  if (inputBuscarJugadores) {
    inputBuscarJugadores.value = filtroJugadoresGuardado;
    aplicarBusquedaJugadores();
  }
}

function aplicarFiltrosUsuariosAdmin() {
  const busqueda = (document.getElementById('buscarUsuariosAdmin')?.value || '').trim().toUpperCase();
  const torneoId = document.getElementById('filtroUsuariosTorneo')?.value || '';
  const rolId = document.getElementById('filtroUsuariosRol')?.value || '';
  const estado = document.getElementById('filtroUsuariosEstado')?.value || '';
  let visibles = 0;

  document.querySelectorAll('#tablaUsuariosAdmin tbody tr').forEach(row => {
    const nombreFila = (row.dataset.nombre || '').toUpperCase();
    const documentoFila = (row.dataset.documento || '').toUpperCase();
    const rolFila = row.dataset.rol || '';
    const estadoFila = row.dataset.estado || '';
    const equiposFila = (row.dataset.equipos || '').toUpperCase();
    const torneosTextoFila = (row.dataset.torneosTexto || '').toUpperCase();
    const torneosFila = (row.dataset.torneos || '').split(',').filter(Boolean);
    const coincideBusqueda = !busqueda
      || nombreFila.includes(busqueda)
      || documentoFila.includes(busqueda)
      || equiposFila.includes(busqueda)
      || torneosTextoFila.includes(busqueda);
    const coincideTorneo = !torneoId || torneosFila.includes(torneoId);
    const coincideRol = !rolId || rolFila === rolId;
    const coincideEstado = !estado || estadoFila === estado;
    const visible = coincideBusqueda && coincideTorneo && coincideRol && coincideEstado;

    row.classList.toggle('d-none', !visible);
    if (visible) {
      visibles += 1;
      const indice = row.querySelector('.usuarios-admin-indice');
      if (indice) indice.textContent = visibles;
    }
  });

  const contador = document.getElementById('usuariosAdminVisibles');
  if (contador) contador.textContent = visibles;
}

document.getElementById('btnBuscarUsuariosAdmin')?.addEventListener('click', aplicarFiltrosUsuariosAdmin);
document.getElementById('buscarUsuariosAdmin')?.addEventListener('keydown', event => {
  if (event.key === 'Enter') aplicarFiltrosUsuariosAdmin();
});
document.getElementById('filtroUsuariosTorneo')?.addEventListener('change', aplicarFiltrosUsuariosAdmin);
document.getElementById('filtroUsuariosRol')?.addEventListener('change', aplicarFiltrosUsuariosAdmin);
document.getElementById('filtroUsuariosEstado')?.addEventListener('change', aplicarFiltrosUsuariosAdmin);
aplicarFiltrosUsuariosAdmin();

function aplicarFiltrosAuditoria() {
  const filtros = {};
  document.querySelectorAll('.audit-filter').forEach(input => {
    filtros[input.dataset.col] = (input.value || '').trim().toUpperCase();
  });

  document.querySelectorAll('#tablaAuditoria tbody tr').forEach(row => {
    if (!row.dataset.pantalla) return;
    const visible = Object.entries(filtros).every(([col, valor]) => {
      if (!valor) return true;
      return String(row.dataset[col] || '').toUpperCase().includes(valor);
    });
    row.classList.toggle('d-none', !visible);
  });
}

document.querySelectorAll('.audit-filter').forEach(input => {
  input.addEventListener('input', aplicarFiltrosAuditoria);
});

document.querySelectorAll('.dashboard-tab-link').forEach(btn => {
  btn.addEventListener('click', () => {
    const targetTab = btn.dataset.targetTab;
    const targetSubtab = btn.dataset.targetSubtab;
    const trigger = document.querySelector(`.navbar [href="${targetTab}"]`);

    if (trigger) {
      bootstrap.Tab.getOrCreateInstance(trigger).show();
      window.location.hash = targetTab;
    }

    if (targetSubtab) {
      setTimeout(() => {
        const subtrigger = document.querySelector(`[data-bs-target="${targetSubtab}"]`);
        if (subtrigger) bootstrap.Tab.getOrCreateInstance(subtrigger).show();
      }, 60);
    }
  });
});

function claseAccionAuditoria(accion) {
  if (accion === 'DELETE') return 'text-bg-danger';
  if (accion === 'UPDATE') return 'text-bg-primary';
  if (accion === 'INGRESO') return 'text-bg-dark';
  return 'text-bg-success';
}

function formatoFechaAuditoria(valor) {
  const fecha = valor ? new Date(valor) : null;
  return fecha && !Number.isNaN(fecha.getTime())
    ? fecha.toLocaleString('es-PY', { dateStyle: 'short', timeStyle: 'short' })
    : '-';
}

async function refrescarAuditoria() {
  const tbody = document.getElementById('auditoriaTbody');
  if (!tbody) return;

  try {
    const response = await fetch('/torneos/<%= torneo.id_torneo %>/auditoria/resumen');
    const data = await response.json();
    if (!data.success) return;

    const registros = data.auditoria || [];
    if (!registros.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">No hay movimientos de auditoría para este contexto.</td></tr>';
      return;
    }

    tbody.innerHTML = registros.map(registro => `
      <tr data-pantalla="${escaparHtml(registro.pantalla || '')}"
          data-afectado="${escaparHtml(registro.afectado || '')}"
          data-accion="${escaparHtml(registro.accion || '')}"
          data-usuario="${escaparHtml([registro.usuario_display, registro.usuario_documento_display].filter(Boolean).join(' '))}"
          data-detalle="${escaparHtml(registro.detalle_legible || '')}">
        <td><small>${formatoFechaAuditoria(registro.fecha_hora)}</small></td>
        <td>${escaparHtml(registro.pantalla || '-')}</td>
        <td>${escaparHtml(registro.afectado || '-')}</td>
        <td><span class="badge ${claseAccionAuditoria(registro.accion)}">${escaparHtml(registro.accion || '-')}</span></td>
        <td>
          <strong>${escaparHtml(registro.usuario_display || 'Sistema')}</strong>
          ${registro.usuario_documento_display ? `<br><small class="text-muted">${escaparHtml(registro.usuario_documento_display)}</small>` : ''}
        </td>
        <td>${escaparHtml(registro.detalle_legible || '-')}</td>
      </tr>
    `).join('');
    aplicarFiltrosAuditoria();
  } catch (error) {
    console.error('Error al refrescar auditoria:', error);
  }
}

function aplicarFiltroPartidosFechaCalendario() {
  const fecha = document.getElementById('filtroPartidosFechaCalendario')?.value || '';
  const url = new URL(window.location.href);

  url.searchParams.delete('grupo_id');
  url.searchParams.delete('fecha');
  if (fecha) {
    url.searchParams.set('fecha_calendario', fecha);
  } else {
    url.searchParams.delete('fecha_calendario');
  }

  window.location = `${url.pathname}${url.search}#partidos`;
}

document.getElementById('btnFiltrarPartidosFecha')?.addEventListener('click', aplicarFiltroPartidosFechaCalendario);
document.getElementById('filtroPartidosFechaCalendario')?.addEventListener('keydown', event => {
  if (event.key === 'Enter') aplicarFiltroPartidosFechaCalendario();
});
document.getElementById('btnLimpiarPartidosFecha')?.addEventListener('click', () => {
  const input = document.getElementById('filtroPartidosFechaCalendario');
  if (input) input.value = '';
  aplicarFiltroPartidosFechaCalendario();
});

function activarVistaPublicaPartidos() {
  const panel = document.getElementById('partidos');
  panel?.classList.add('partidos-vista-publica');
  document.getElementById('btnVistaPublicaPartidos')?.classList.add('d-none');
  document.getElementById('btnVistaAdminPartidos')?.classList.remove('d-none');
  sessionStorage.setItem('partidosModoAdmin', '0');
}

function activarVistaAdminPartidos() {
  const panel = document.getElementById('partidos');
  panel?.classList.remove('partidos-vista-publica');
  document.getElementById('btnVistaAdminPartidos')?.classList.add('d-none');
  document.getElementById('btnVistaPublicaPartidos')?.classList.remove('d-none');
  sessionStorage.setItem('partidosModoAdmin', '1');
}

document.getElementById('btnVistaPublicaPartidos')?.addEventListener('click', activarVistaPublicaPartidos);
document.getElementById('btnVistaAdminPartidos')?.addEventListener('click', activarVistaAdminPartidos);
if (sessionStorage.getItem('partidosModoAdmin') === '1') {
  activarVistaAdminPartidos();
} else {
  activarVistaPublicaPartidos();
}

function activarVistaPublicaJugadores() {
  const panel = document.getElementById('jugadores');
  panel?.classList.add('jugadores-vista-publica');
  document.getElementById('btnVistaPublicaJugadores')?.classList.add('d-none');
  document.getElementById('btnVistaAdminJugadores')?.classList.remove('d-none');
  sessionStorage.setItem('jugadoresModoAdmin', '0');
}

function activarVistaAdminJugadores() {
  const panel = document.getElementById('jugadores');
  panel?.classList.remove('jugadores-vista-publica');
  document.getElementById('btnVistaAdminJugadores')?.classList.add('d-none');
  document.getElementById('btnVistaPublicaJugadores')?.classList.remove('d-none');
  sessionStorage.setItem('jugadoresModoAdmin', '1');
}

document.getElementById('btnVistaPublicaJugadores')?.addEventListener('click', activarVistaPublicaJugadores);
document.getElementById('btnVistaAdminJugadores')?.addEventListener('click', activarVistaAdminJugadores);
if (sessionStorage.getItem('jugadoresModoAdmin') === '1') {
  activarVistaAdminJugadores();
} else {
  activarVistaPublicaJugadores();
}

document.querySelectorAll('.navbar [data-bs-toggle="tab"]').forEach(tab => {
  tab.addEventListener('shown.bs.tab', event => {
    const href = event.target?.getAttribute('href');

    if (href !== '#partidos') {
      sessionStorage.removeItem('partidosModoAdmin');
      activarVistaPublicaPartidos();
    } else if (sessionStorage.getItem('partidosModoAdmin') !== '1') {
      activarVistaPublicaPartidos();
    }

    if (href !== '#jugadores') {
      sessionStorage.removeItem('jugadoresModoAdmin');
      sessionStorage.removeItem('jugadoresFiltroBusqueda');
      activarVistaPublicaJugadores();
    } else if (sessionStorage.getItem('jugadoresModoAdmin') !== '1') {
      activarVistaPublicaJugadores();
    }

    if (href !== '#usuarios') {
      sessionStorage.removeItem('usuariosModoAdmin');
      activarVistaPublicaUsuarios();
    } else if (sessionStorage.getItem('usuariosModoAdmin') !== '1') {
      activarVistaPublicaUsuarios();
    }

    if (href === '#auditoria') {
      refrescarAuditoria();
    }
  });
});

