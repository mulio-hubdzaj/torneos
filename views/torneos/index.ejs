function inicializarPullToRefresh() {
  const indicador = document.getElementById('pullRefreshIndicator');
  if (!indicador || !window.matchMedia('(pointer: coarse)').matches) return;

  const texto = indicador.querySelector('span');
  const umbralActivacion = 92;
  const umbralVisible = 24;
  let inicioY = 0;
  let distancia = 0;
  let arrastrando = false;
  let actualizando = false;
  let timeoutActualizacion = null;

  function scrollArriba() {
    const scrollTop = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
    return scrollTop <= 0;
  }

  function objetivoInteractivo(target) {
    return Boolean(target?.closest('input, textarea, select, button, a, .modal, .dropdown-menu'));
  }

  function limpiarIndicador() {
    if (timeoutActualizacion) {
      clearTimeout(timeoutActualizacion);
      timeoutActualizacion = null;
    }
    actualizando = false;
    indicador.classList.remove('is-visible', 'is-ready');
    indicador.style.transform = '';
    if (texto) texto.textContent = 'Desliza para actualizar';
  }

  document.addEventListener('touchstart', event => {
    if (actualizando || event.touches.length !== 1 || objetivoInteractivo(event.target) || !scrollArriba()) return;
    inicioY = event.touches[0].clientY;
    distancia = 0;
    arrastrando = true;
  }, { passive: true });

  document.addEventListener('touchmove', event => {
    if (!arrastrando || actualizando || event.touches.length !== 1) return;
    distancia = event.touches[0].clientY - inicioY;

    if (distancia <= umbralVisible || !scrollArriba()) {
      if (distancia < 0) arrastrando = false;
      limpiarIndicador();
      return;
    }

    event.preventDefault();
    const desplazamiento = Math.min(46, (distancia - umbralVisible) * 0.45);
    const listo = distancia >= umbralActivacion;
    indicador.classList.add('is-visible');
    indicador.classList.toggle('is-ready', listo);
    indicador.style.transform = `translate(-50%, ${desplazamiento}px)`;
    if (texto) texto.textContent = listo ? 'Suelta para actualizar' : 'Desliza para actualizar';
  }, { passive: false });

  document.addEventListener('touchend', () => {
    if (!arrastrando || actualizando) return;
    arrastrando = false;

    if (distancia >= umbralActivacion) {
      actualizando = true;
      indicador.classList.add('is-visible', 'is-ready', 'is-refreshing');
      indicador.style.transform = 'translate(-50%, 46px)';
      if (texto) texto.textContent = 'Actualizando...';
      const tabActual = document.querySelector('.navbar [data-bs-toggle="tab"].active')?.getAttribute('href') || window.location.hash || '#torneos';
      const urlActual = new URL(window.location.href);
      urlActual.searchParams.set('tab', tabActual.replace('#', ''));
      urlActual.searchParams.set('_apk_refresh', String(Date.now()));
      urlActual.hash = tabActual;
      timeoutActualizacion = setTimeout(() => {
        limpiarIndicador();
        mostrarAvisoApp('No se pudo completar la actualizacion. Intenta nuevamente.', 'Actualizar');
      }, 12000);
      window.location.replace(urlActual.toString());
      return;
    }

    limpiarIndicador();
  }, { passive: true });

  document.addEventListener('touchcancel', () => {
    arrastrando = false;
    if (!actualizando) limpiarIndicador();
  }, { passive: true });
}

inicializarPullToRefresh();

(function limpiarMarcaRefreshApk() {
