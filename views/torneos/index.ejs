}

function actualizarAccionesPartido(partidoId, estado) {
  const estadoNormalizado = normalizarEstadoPartidoCliente(estado);
  const fila = document.querySelector(`.estado-select[data-id="${partidoId}"]`)?.closest('tr');
  if (!fila) return;
  const botonEditar = fila.querySelector('.editar-horario-btn');
  const botonEliminar = fila.querySelector('form[action*="/eliminar"] button[type="submit"]');
  const selectEstado = fila.querySelector('.estado-select');

  if (botonEditar) botonEditar.disabled = estadoNormalizado === 'finalizado';
  if (botonEliminar) botonEliminar.disabled = estadoNormalizado === 'finalizado';
  if (selectEstado) {
    selectEstado.classList.toggle('estado-en-curso', estadoNormalizado === 'en_curso');
  }
  actualizarEstadoPublicoPartido(partidoId, estadoNormalizado);
}

function normalizarEstadoPartidoCliente(estado) {
  return String(estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_');
}

function textoEstadoPartidoCliente(estado) {
  const estadoNormalizado = normalizarEstadoPartidoCliente(estado);
  if (estadoNormalizado === 'en_curso') return 'En curso';
  return estadoNormalizado.charAt(0).toUpperCase() + estadoNormalizado.slice(1);
}

function claseBadgeEstadoPartidoCliente(estado) {
  const estadoNormalizado = normalizarEstadoPartidoCliente(estado);
  if (estadoNormalizado === 'en_curso') return 'estado-badge-en-curso';
  if (estadoNormalizado === 'finalizado') return 'text-bg-success';
  if (estadoNormalizado === 'suspendido') return 'text-bg-secondary';
  return 'text-bg-light';
}

function actualizarEstadoPublicoPartido(partidoId, estado) {
  const estadoNormalizado = normalizarEstadoPartidoCliente(estado);
  const publicCard = document.querySelector(`[data-public-partido-card="${partidoId}"]`);
  if (!publicCard) return;

  publicCard.className = publicCard.className
    .split(/\s+/)
    .filter(clase => clase && !clase.startsWith('fixture-public-estado-'))
    .join(' ');
  publicCard.classList.add(`fixture-public-estado-${estadoNormalizado}`);

  const estadoEl = publicCard.querySelector('.fixture-public-status');
  if (estadoEl) {
    estadoEl.className = `fixture-public-status badge ${claseBadgeEstadoPartidoCliente(estadoNormalizado)}`;
    estadoEl.textContent = textoEstadoPartidoCliente(estadoNormalizado);
  }

  const marcador = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a]`);
  const mostrarMarcador = estadoNormalizado === 'finalizado' || estadoNormalizado === 'en_curso';
  const score = publicCard.querySelector('.fixture-public-score');
  const vs = publicCard.querySelector('.fixture-public-vs');
  if (score && marcador) score.textContent = `${marcador.dataset.golesA || 0} - ${marcador.dataset.golesB || 0}`;
  score?.classList.toggle('d-none', !mostrarMarcador);
  vs?.classList.toggle('d-none', mostrarMarcador);
}

