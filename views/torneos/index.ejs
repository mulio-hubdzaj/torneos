.pull-refresh-indicator {
  position: fixed;
  top: 10px;
  left: 50%;
  z-index: 1100;
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  min-height: 38px;
  padding: 0.45rem 0.85rem;
  color: #fff;
  background: rgba(13, 110, 253, 0.96);
  border: 1px solid rgba(255, 255, 255, 0.32);
  border-radius: 999px;
  box-shadow: 0 10px 24px rgba(4, 12, 26, 0.24);
  font-size: 0.88rem;
  font-weight: 700;
  pointer-events: none;
  opacity: 0;
  transform: translate(-50%, -130%);
  transition: opacity 0.16s ease, transform 0.16s ease, background-color 0.16s ease;
}

.pull-refresh-indicator.is-visible {
  opacity: 1;
  transform: translate(-50%, 0);
}

.pull-refresh-indicator.is-ready {
  background: rgba(25, 135, 84, 0.98);
}

.pull-refresh-indicator.is-refreshing .bi {
  animation: pullRefreshSpin 0.8s linear infinite;
}

@keyframes pullRefreshSpin {
  to {
    transform: rotate(360deg);
  }
}

