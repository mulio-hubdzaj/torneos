              data-nombre="<%= [j.nombre, j.apellido].filter(Boolean).join(' ') %>">
            <td data-label="Nombre">
              <%= j.nombre %>
              <% if (j.capitan) { %>
                <span class="badge text-bg-warning ms-1">c</span>
              <% } %>
            </td>
            <td data-label="Apellido"><%= j.apellido %></td>
            <td data-label="Documento"><%= j.documento %></td>
