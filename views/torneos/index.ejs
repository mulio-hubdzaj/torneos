      campo.addEventListener('input', actualizarEstadoBoton);
      campo.addEventListener('change', actualizarEstadoBoton);
    });
    actualizarEstadoBoton();
  });

  document.querySelectorAll('.guardar-horarios-btn').forEach(button => {
    button.addEventListener('click', () => {
      const numeroFecha = button.dataset.numeroFecha;
      guardarHorariosComunes(numeroFecha);
    });
  });

  document.querySelectorAll('.abrir-cruce-manual-btn').forEach(button => {
    button.addEventListener('click', () => {
      abrirModalCruceManual(button.dataset.numeroFecha, button.dataset.grupoId || '');
    });
  });

  const manualGrupoEquipoA = document.getElementById('manualGrupoEquipoA');
  const manualGrupoEquipoB = document.getElementById('manualGrupoEquipoB');
  if (manualGrupoEquipoA) {
    manualGrupoEquipoA.addEventListener('change', actualizarOpcionesCruceManual);
  }
  if (manualGrupoEquipoB) {
    manualGrupoEquipoB.addEventListener('change', actualizarOpcionesCruceManual);
  }

  const manualEquipoA = document.getElementById('manualEquipoA');
  const manualEquipoB = document.getElementById('manualEquipoB');
  if (manualEquipoA && manualEquipoB) {
    manualEquipoA.addEventListener('change', actualizarOpcionesCruceManual);
    manualEquipoB.addEventListener('change', actualizarOpcionesCruceManual);
  }

  const formCruceManual = document.getElementById('formCruceManual');
  if (formCruceManual) {
    formCruceManual.addEventListener('submit', async (event) => {
      if (formCruceManual.dataset.confirmadoIdaVuelta === '1') return;

      const equipoA = manualEquipoA ? manualEquipoA.value : '';
      const equipoB = manualEquipoB ? manualEquipoB.value : '';
      if (!equipoA || !equipoB) {
        event.preventDefault();
        mostrarAvisoApp('Selecciona grupo y equipo para ambos lados del cruce.', 'Cruce manual');
        return;
      }
      if (String(equipoA) === String(equipoB)) {
        event.preventDefault();
        mostrarAvisoApp('El cruce manual no puede usar el mismo equipo en ambos lados.', 'Cruce manual');
        return;
      }

      event.preventDefault();
      const cruceModalEl = document.getElementById('modalCruceManual');
      if (cruceModalEl?.classList.contains('show')) {
        const cruceModal = bootstrap.Modal.getOrCreateInstance(cruceModalEl);
        await new Promise(resolve => {
          cruceModalEl.addEventListener('hidden.bs.modal', resolve, { once: true });
          cruceModal.hide();
        });
      }

      const inputIdaVuelta = document.getElementById('manualIdaVuelta');
      if (inputIdaVuelta) {
        const crearIdaVuelta = await confirmarApp(
          'Desea crear encuentro en formato ida y vuelta?',
          'Tipo de encuentro',
          {
            aceptar: 'SI, crear ida y vuelta',
            cancelar: 'NO, crear encuentro simple'
          }
        );
        inputIdaVuelta.value = crearIdaVuelta ? '1' : '0';
      }

      formCruceManual.dataset.confirmadoIdaVuelta = '1';
      formCruceManual.submit();
    });
  }

  document.querySelectorAll('.form-eliminar-encuentro').forEach(form => {
    form.addEventListener('submit', async event => {
      if (form.dataset.confirmadoEliminar === '1') return;

      event.preventDefault();
      const confirmado = await confirmarApp(
        'Esta accion eliminara el encuentro seleccionado.',
        'Eliminar encuentro',
        {
          aceptar: 'SI, eliminar encuentro',
          cancelar: 'NO, conservar encuentro',
          destacar: true
        }
      );

      if (!confirmado) return;

      form.dataset.confirmadoEliminar = '1';
      form.submit();
    });
  });

  document.querySelectorAll('.form-intercambiar-equipos').forEach(form => {
    form.addEventListener('submit', async event => {
      if (form.dataset.confirmadoIntercambiar === '1') return;

      event.preventDefault();
      const confirmado = await confirmarApp(
        'Desea intercambiar Equipo A y Equipo B en este encuentro?',
        'Intercambiar equipos',
        {
          aceptar: 'SI, intercambiar',
          cancelar: 'NO, mantener orden'
        }
      );

      if (!confirmado) return;

      const redirectInput = form.querySelector('input[name="redirect_url"]');
      if (redirectInput) {
        const url = new URL(window.location.href);
        url.searchParams.set('tab', 'partidos');
        url.hash = '#partidos';
        redirectInput.value = `${url.pathname}${url.search}${url.hash}`;
      }

      form.dataset.confirmadoIntercambiar = '1';
      form.submit();
    });
  });

  document.querySelectorAll('.btn-item-nuevo').forEach(btn => {
    btn.addEventListener('click', () => abrirModalItem());
  });

  document.querySelectorAll('.btn-item-editar').forEach(btn => {
    btn.addEventListener('click', () => {
      abrirModalItem({
        id_item: btn.dataset.id,
        nombre: btn.dataset.nombre,
        descripcion: btn.dataset.descripcion,
        monto: btn.dataset.monto
      });
    });
  });

  document.querySelectorAll('.btn-editar-cancha').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = document.getElementById('formEditarCancha');
      const nombreInput = document.getElementById('editarCanchaNombre');
      const direccionInput = document.getElementById('editarCanchaDireccion');

      if (!form || !nombreInput || !direccionInput) return;

      form.action = `/torneos/<%= torneo.id_torneo %>/canchas/${btn.dataset.id}`;
      nombreInput.value = btn.dataset.nombre || '';
      direccionInput.value = btn.dataset.direccion || '';
      form.classList.remove('d-none');
      nombreInput.focus();
    });
  });

  document.getElementById('btnCancelarEditarCancha')?.addEventListener('click', () => {
    const form = document.getElementById('formEditarCancha');
    if (!form) return;
    form.reset();
    form.action = '';
    form.classList.add('d-none');
  });

  document.querySelectorAll('.btn-editar-usuario-admin').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = document.getElementById('formEditarUsuarioAdmin');
      const nombreInput = document.getElementById('editarUsuarioNombre');
      const documentoInput = document.getElementById('editarUsuarioDocumento');
      const correoInput = document.getElementById('editarUsuarioCorreo');

      if (!form || !nombreInput || !documentoInput || !correoInput) return;

      form.action = `/torneos/<%= torneo.id_torneo %>/usuarios/${btn.dataset.id}/editar`;
      nombreInput.value = btn.dataset.nombre || '';
      documentoInput.value = btn.dataset.documento || '';
      correoInput.value = btn.dataset.correo || '';

      bootstrap.Modal.getOrCreateInstance(document.getElementById('modalEditarUsuarioAdmin')).show();
    });
  });
});

// Función para guardar horarios comunes a toda una fecha
async function guardarHorariosComunes(numeroFecha) {
  const form = document.getElementById(`formFechaComun-${numeroFecha}`);
  const formData = new FormData(form);

  const fechaComun = formData.get('fecha_comun');
  const horaInicial = formData.get('hora_inicial');
  const intervaloMinutos = parseInt(formData.get('intervalo_minutos'));

  if (!fechaComun) {
    mostrarAvisoApp('Por favor selecciona una fecha común.', 'Horarios');
    return;
  }
  if (!horaInicial) {
    mostrarAvisoApp('Por favor ingresa una hora inicial.', 'Horarios');
    return;
  }
  if (!intervaloMinutos || intervaloMinutos < 5) {
    mostrarAvisoApp('Por favor ingresa un intervalo válido (mínimo 5 minutos).', 'Horarios');
    return;
  }

  try {
    const response = await fetch(`/partidos/actualizar-horarios-fecha`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        numero_fecha: numeroFecha,
        torneo_id: formData.get('torneo_id'),
        grupo_id: formData.get('grupo_id') || '',
        fecha_comun: fechaComun,
        hora_inicial: horaInicial,
        intervalo_minutos: intervaloMinutos
      })
    });

    const data = await response.json();

  if (data.success) {
    mostrarAvisoApp(data.message || 'Horarios actualizados correctamente.', 'Horarios');
    marcarDashboardInicioDesactualizado();
    const fechaDisplay = fechaComun.split('-').reverse().join('/');
    const fechaPane = document.getElementById(`fecha-${numeroFecha}`);
    if (fechaPane) {
      let horaActual = horaInicial;
      fechaPane.querySelectorAll('tbody tr[data-partido-row]').forEach(row => {
        const fechaCell = row.querySelector('.fixture-fecha-cell');
        const horaCell = row.querySelector('.fixture-hora-cell');
        if (fechaCell) fechaCell.textContent = fechaDisplay;
        if (horaCell) horaCell.textContent = horaActual;

        const detalle = fechaPane.querySelector(`.partido-detalle[data-partido-id="${row.dataset.partidoRow}"]`);
        const fechaEl = detalle?.querySelector('.partido-detalle-fecha');
        const horaEl = detalle?.querySelector('.partido-detalle-hora');
        if (fechaEl) fechaEl.textContent = fechaDisplay;
        if (horaEl) horaEl.textContent = horaActual;

        const publicCard = row.querySelector('.fixture-public-card');
        const publicFecha = publicCard?.querySelector('.fixture-public-fecha');
        const publicHora = publicCard?.querySelector('.fixture-public-hora');
        if (publicFecha) publicFecha.textContent = fechaDisplay;
        if (publicHora) publicHora.textContent = horaActual;

        const btnEditar = row.querySelector('.editar-horario-btn');
        if (btnEditar) {
          btnEditar.dataset.fecha = fechaComun;
          btnEditar.dataset.hora = horaActual;
        }

        horaActual = sumarMinutosHora(horaActual, intervaloMinutos);
      });

      const fechaActualTab = document.getElementById('fechaActualTab');
      if (fechaActualTab?.getAttribute('data-bs-target') === `#fecha-${numeroFecha}`) {
        fechaActualTab.textContent = `Fecha ${numeroFecha} - ${fechaDisplay}`;
      }
    }
  } else {
    mostrarAvisoApp(data.message || 'No se pudieron actualizar los horarios.', 'Horarios');
  }
  } catch (error) {
    console.error('Error:', error);
    mostrarAvisoApp('Error al actualizar los horarios.', 'Horarios');
  }
}

function poblarCruceManualGrupo(grupoId) {
  const inputGrupoFixture = document.getElementById('manualGrupoFixtureId');
  const selectGrupoEquipoA = document.getElementById('manualGrupoEquipoA');
  const selectGrupoEquipoB = document.getElementById('manualGrupoEquipoB');
  const selectEquipoA = document.getElementById('manualEquipoA');
  const selectEquipoB = document.getElementById('manualEquipoB');

  if (!selectGrupoEquipoA || !selectGrupoEquipoB || !selectEquipoA || !selectEquipoB) return;

  if (inputGrupoFixture) inputGrupoFixture.value = grupoId || selectGrupoEquipoA.value || selectGrupoEquipoB.value || '';
  selectGrupoEquipoA.value = grupoId || selectGrupoEquipoA.options[0]?.value || '';
  selectGrupoEquipoB.value = grupoId || selectGrupoEquipoB.options[0]?.value || '';
  selectEquipoA.value = '';
  selectEquipoB.value = '';
  actualizarOpcionesCruceManual();
}

function abrirModalCruceManual(numeroFecha, grupoId = '') {
  const inputFecha = document.getElementById('manualNumeroFecha');
  const inputGrupoFixture = document.getElementById('manualGrupoFixtureId');
  const selectGrupoEquipoA = document.getElementById('manualGrupoEquipoA');
  const redirectInput = document.getElementById('manualRedirectUrl');
  if (inputFecha) inputFecha.value = numeroFecha;
  if (redirectInput) {
    const params = new URLSearchParams(window.location.search);
    params.set('fecha', numeroFecha);
    params.set('tab', 'partidos');
    redirectInput.value = `${window.location.pathname}?${params.toString()}#partidos`;
  }
  if (selectGrupoEquipoA) {
    if (grupoId) {
      poblarCruceManualGrupo(grupoId);
    } else if (selectGrupoEquipoA.options.length > 0) {
      const primerGrupo = selectGrupoEquipoA.options[0].value || selectGrupoEquipoA.options[1]?.value || '';
      poblarCruceManualGrupo(primerGrupo);
    }
  }
  if (inputGrupoFixture && !inputGrupoFixture.value) {
    inputGrupoFixture.value = grupoId || selectGrupoEquipoA?.value || '';
  }
  const modal = new bootstrap.Modal(document.getElementById('modalCruceManual'));
  modal.show();
}

// Cambiar estado de un partido
async function cambiarEstado(selectElement) {
  const partidoId = selectElement.dataset.id;
  const nuevoEstado = selectElement.value;

  try {
    const response = await fetch(`/partidos/${partidoId}/estado`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        partido_id: partidoId,
        nuevoEstado: nuevoEstado
      })
    });

    const data = await response.json();
    if (!data.success) {
      mostrarAvisoApp(data.message || 'No se pudo actualizar el estado del partido.', 'Partidos');
    } else {
      const marcador = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a-id]`);
      if (marcador) marcador.dataset.estado = nuevoEstado;
      recalcularEstadisticasCliente();
      marcarDashboardInicioDesactualizado();
    }
  } catch (error) {
    console.error('Error:', error);
  }
}

// Guardar marcador
function actualizarMarcadorPartidoEnVista(partidoId, golesA, golesB, estado = null) {
  const estadoNormalizado = estado ? normalizarEstadoPartidoCliente(estado) : null;
  const resultCell = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a]`);
  if (resultCell) {
    resultCell.setAttribute('data-goles-a', golesA);
    resultCell.setAttribute('data-goles-b', golesB);
    if (estadoNormalizado) resultCell.setAttribute('data-estado', estadoNormalizado);
    const span = resultCell.querySelector('span');
    if (span) span.textContent = `${golesA} - ${golesB}`;
  }

  const publicScore = document.querySelector(`[data-public-partido-card="${partidoId}"] .fixture-public-score`);
  if (publicScore) publicScore.textContent = `${golesA} - ${golesB}`;

  if (estadoNormalizado) {
    const selectEstado = document.querySelector(`.estado-select[data-id="${partidoId}"]`);
    if (selectEstado) {
      selectEstado.value = estadoNormalizado;
      selectEstado.dataset.estadoActual = estadoNormalizado;
    }
    actualizarAccionesPartido(partidoId, estadoNormalizado);
  }
}

async function guardarMarcador() {
  const partidoId = document.getElementById('marcadorPartidoId').value;
  const golesA = document.getElementById('marcadorGolesA').value;
  const golesB = document.getElementById('marcadorGolesB').value;
  const selectEstadoActual = document.querySelector(`.estado-select[data-id="${partidoId}"]`);
  const marcadorCell = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a]`);
  const estadoActual = normalizarEstadoPartidoCliente(selectEstadoActual?.value || marcadorCell?.dataset.estado || 'programado');
  let estadoMarcador = estadoActual;

  if (golesA === '' || golesB === '') {
    mostrarAvisoApp('Por favor ingresa ambos marcadores.', 'Marcador');
    return;
  }

  if (!marcadorValido(golesA) || !marcadorValido(golesB)) {
    mostrarAvisoApp('El marcador debe ser un número entero entre 0 y 99, sin negativos ni ceros a la izquierda.', 'Marcador');
    return;
  }

  if (!['en_curso', 'finalizado'].includes(estadoActual)) {
    estadoMarcador = await elegirEstadoMarcador(
      'El encuentro todavia no esta en curso ni finalizado. Como queres dejarlo al guardar el marcador?',
      'Estado del marcador'
    );
    if (!estadoMarcador) return;
  }

  try {
    const response = await fetch(`/partidos/${partidoId}/marcador`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        partido_id: partidoId,
        goles_a: golesA,
        goles_b: golesB,
        estado: estadoMarcador
      })
    });

    const data = await response.json();
    if (data.success) {
      actualizarMarcadorPartidoEnVista(partidoId, golesA, golesB, estadoMarcador);
      recalcularEstadisticasCliente();
      marcarDashboardInicioDesactualizado();
      cerrarModalBootstrapSeguro('modalEditarMarcador');
    } else {
      mostrarAvisoApp(data.message || 'No se pudo actualizar el marcador.', 'Marcador');
    }
  } catch (error) {
    console.error('Error:', error);
    mostrarAvisoApp('Error al actualizar marcador.', 'Marcador');
  }
}

async function guardarEstadoPartido(pidoId, nuevoEstado) {
  try {
    const res = await fetch(`/partidos/${pidoId}/estado`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ partido_id: pidoId, nuevoEstado: nuevoEstado })
    });
    const data = await res.json();
    if (data.success) {
      const selectEl = document.querySelector(`.estado-select[data-id="${pidoId}"]`);
      if (selectEl) {
        selectEl.value = nuevoEstado;
        selectEl.dataset.estadoActual = nuevoEstado;
      }
      const marcador = document.querySelector(`td[data-id="${pidoId}"][data-equipo-a-id]`);
      if (marcador) marcador.dataset.estado = nuevoEstado;
      actualizarAccionesPartido(pidoId, nuevoEstado);
      recalcularEstadisticasCliente();
      marcarDashboardInicioDesactualizado();
      return true;
    } else {
      mostrarAvisoApp(data.message || 'No se pudo actualizar el estado del partido.', 'Partidos');
      return false;
    }
  } catch (e) {
    console.error(e);
    return false;
  }
}

function initMatchHandlers() {
  document.querySelectorAll('.estado-select').forEach(select => {
    select.dataset.estadoActual = select.dataset.estadoActual || select.value;
    select.onchange = async () => {
      const estadoAnterior = select.dataset.estadoActual || 'programado';
      const estadoNuevo = select.value;
      if (estadoNuevo === estadoAnterior) return;

      const textoEstado = select.selectedOptions?.[0]?.textContent?.trim() || estadoNuevo;
      const confirmado = await confirmarApp(
        `Desea guardar el estado "${textoEstado}" para este encuentro?`,
        'Confirmar estado',
        {
          aceptar: 'Si, guardar',
          cancelar: 'Cancelar'
        }
      );

      if (!confirmado) {
        select.value = estadoAnterior;
        return;
      }

      select.disabled = true;
      const guardado = await guardarEstadoPartido(select.dataset.id, estadoNuevo);
      select.disabled = false;

      if (guardado) {
        select.dataset.estadoActual = estadoNuevo;
        if (estadoAnterior === 'finalizado' && estadoNuevo === 'en_curso') {
          recargarManteniendoPestana('#partidos');
        }
      } else {
        select.value = estadoAnterior;
      }
    };
  });

  document.querySelectorAll('td[data-equipo-a][data-id]').forEach(td => {
    td.style.cursor = 'pointer';
    td.onclick = () => {
      document.getElementById('marcadorTitulo').textContent = td.dataset.equipoA + ' vs ' + td.dataset.equipoB;
      document.getElementById('marcadorPartidoId').value = td.dataset.id;
      document.getElementById('marcadorGolesA').value = td.dataset.golesA || 0;
      document.getElementById('marcadorGolesB').value = td.dataset.golesB || 0;
      new bootstrap.Modal(document.getElementById('modalEditarMarcador')).show();
    };
  });
}

document.addEventListener('DOMContentLoaded', () => { initMatchHandlers(); });

document.addEventListener('DOMContentLoaded', () => {
  const modalMarcador = document.getElementById('modalEditarMarcador');
  if (modalMarcador) {
    modalMarcador.addEventListener('hidden.bs.modal', limpiarBloqueoModalBootstrap);
