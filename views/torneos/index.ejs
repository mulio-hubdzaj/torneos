      modal.show();
    });
  });

  document.getElementById('formEditarHorario')?.addEventListener('submit', async event => {
    event.preventDefault();
    const form = event.currentTarget;
    const formData = new FormData(form);
    const partidoId = document.getElementById('horarioPartidoId')?.value || '';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: {
          'Accept': 'application/json'
        },
