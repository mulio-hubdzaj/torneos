            <input type="text" class="form-control campo-dinero" id="cargaMontoAportado" inputmode="numeric" oninput="formatearCampoDinero(this); recalcularCargaEquipoPartido();">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold text-dark">Saldo</label>
            <input type="text" class="form-control" id="cargaSaldoFinal" readonly>
          </div>
        </div>

        <ul class="nav nav-tabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#cargaJugadoresTab" type="button" role="tab">Jugadores</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#cargaItemsTab" type="button" role="tab">Items y finanzas</button>
          </li>
        </ul>

        <div class="tab-content pt-3">
          <div class="tab-pane fade show active" id="cargaJugadoresTab" role="tabpanel">
            <div class="d-flex justify-content-end mb-2">
              <div class="input-group input-group-sm" style="max-width: 310px;">
