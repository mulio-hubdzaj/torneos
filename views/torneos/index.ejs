<!-- Modal item -->
<div class="modal fade" id="modalReglaTarjetas" tabindex="-1" aria-labelledby="modalReglaTarjetasTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form action="/torneos/<%= torneo.id_torneo %>/regla-tarjetas" method="POST">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalReglaTarjetasTitulo">Regla de tarjetas</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <% const regla = reglaTarjetas || {}; %>
          <% if (!regla.tabla_configurada) { %>
            <div class="alert alert-warning py-2">
              Falta aplicar la tabla de configuracion para guardar esta regla.
            </div>
          <% } %>

          <div class="regla-tarjeta-opcion">
            <div>
              <label class="form-label fw-bold mb-0" for="reglaAcumulaAmarillas">Suspension automatica por acumulacion</label>
              <div class="form-text">Si un jugador llega al limite de amarillas, el sistema propondra deshabilitarlo/suspenderlo.</div>
            </div>
            <div class="form-check form-switch m-0">
              <input type="hidden" name="acumula_amarillas" value="0">
              <input class="form-check-input" type="checkbox" id="reglaAcumulaAmarillas" name="acumula_amarillas" value="1" <%= regla.acumula_amarillas ? 'checked' : '' %>>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label for="reglaAmarillasSuspension" class="form-label text-dark">Amarillas para suspender</label>
              <input type="number" class="form-control" id="reglaAmarillasSuspension" name="amarillas_para_suspension" min="1" step="1" value="<%= regla.amarillas_para_suspension || 5 %>" required>
            </div>
            <div class="col-md-6">
              <label for="reglaFechasSuspension" class="form-label text-dark">Fechas de suspension</label>
              <input type="number" class="form-control" id="reglaFechasSuspension" name="fechas_suspension_acumulacion" min="1" step="1" value="<%= regla.fechas_suspension_acumulacion || 1 %>" required>
            </div>
          </div>

          <div class="regla-tarjeta-opcion mt-3">
            <div>
              <label class="form-label fw-bold mb-0" for="reglaReiniciar">Reiniciar conteo</label>
              <div class="form-text">Vuelve a contar desde cero despues de registrar la sancion por acumulacion.</div>
            </div>
            <div class="form-check form-switch m-0">
              <input type="hidden" name="reiniciar_al_sancionar" value="0">
              <input class="form-check-input" type="checkbox" id="reglaReiniciar" name="reiniciar_al_sancionar" value="1" <%= regla.reiniciar_al_sancionar !== false ? 'checked' : '' %>>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-success">Guardar regla</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="modalCanchas" tabindex="-1" aria-labelledby="modalCanchasTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="modalCanchasTitulo">Sedes/canchas</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <form action="/torneos/<%= torneo.id_torneo %>/canchas" method="POST" class="row g-2 align-items-end mb-3">
          <div class="col-md-5">
            <label class="form-label text-dark fw-bold" for="canchaNombre">Nombre</label>
            <input type="text" class="form-control" id="canchaNombre" name="nombre" maxlength="120" required>
          </div>
          <div class="col-md-5">
            <label class="form-label text-dark fw-bold" for="canchaDireccion">Direccion</label>
            <input type="text" class="form-control" id="canchaDireccion" name="direccion" maxlength="255">
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-success w-100">
              <i class="bi bi-plus-lg"></i> Agregar
            </button>
          </div>
        </form>

        <form action="" method="POST" id="formEditarCancha" class="row g-2 align-items-end mb-3 d-none border rounded p-2 bg-light">
          <div class="col-md-5">
            <label class="form-label text-dark fw-bold" for="editarCanchaNombre">Editar nombre</label>
            <input type="text" class="form-control" id="editarCanchaNombre" name="nombre" maxlength="120" required>
          </div>
          <div class="col-md-5">
            <label class="form-label text-dark fw-bold" for="editarCanchaDireccion">Editar direccion</label>
            <input type="text" class="form-control" id="editarCanchaDireccion" name="direccion" maxlength="255">
          </div>
          <div class="col-md-2 d-grid gap-1">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-save"></i> Guardar
            </button>
            <button type="button" class="btn btn-outline-secondary" id="btnCancelarEditarCancha">
              Cancelar
            </button>
          </div>
        </form>

        <div class="table-responsive">
          <table class="table table-sm align-middle">
            <thead class="table-light">
              <tr>
                <th>Nombre</th>
                <th>Direccion</th>
                <th>Estado</th>
                <th class="text-end">Accion</th>
              </tr>
            </thead>
            <tbody>
              <% if (!(canchas || []).length) { %>
                <tr>
                  <td colspan="4" class="text-center text-muted py-3">No hay sedes/canchas cargadas.</td>
                </tr>
              <% } %>
              <% (canchas || []).forEach(cancha => { %>
                <tr>
                  <td><strong><%= cancha.nombre %></strong></td>
                  <td><%= cancha.direccion || '-' %></td>
                  <td>
                    <span class="badge <%= cancha.estado ? 'text-bg-success' : 'text-bg-secondary' %>">
                      <%= cancha.estado ? 'Activa' : 'Inactiva' %>
                    </span>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm" role="group">
                      <button type="button"
                              class="btn btn-outline-primary btn-editar-cancha"
                              data-id="<%= cancha.id_cancha %>"
                              data-nombre="<%= cancha.nombre %>"
                              data-direccion="<%= cancha.direccion || '' %>"
                              title="Editar cancha">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form action="/torneos/<%= torneo.id_torneo %>/canchas/<%= cancha.id_cancha %>/toggle" method="POST">
                        <button type="submit" class="btn <%= cancha.estado ? 'btn-outline-warning' : 'btn-outline-success' %>">
                          <%= cancha.estado ? 'Desactivar' : 'Activar' %>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalItem" tabindex="-1" aria-labelledby="itemModalTitulo" aria-hidden="true">
