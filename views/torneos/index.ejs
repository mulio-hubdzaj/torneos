


<!DOCTYPE html>
<html>
<head>
  <title>Gestión de Torneos</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const hash = window.location.hash;
      const rolId = Number(<%= Number(rol_id || 0) %>);
      const hashesBloqueados = rolId === 1
        ? ['#grupos', '#equipos', '#items', '#usuarios', '#auditoria', '#finanzas']
        : (rolId === 2 ? ['#grupos', '#items', '#usuarios', '#auditoria'] : []);

      if (hashesBloqueados.includes(hash)) {
        window.location.hash = '#torneos';
        return;
      }

      if (hash) {
        const triggerEl = document.querySelector(`a[href="${hash}"]`);
        if (triggerEl) {
          const tab = new bootstrap.Tab(triggerEl);
          tab.show();
        }
      }

      const fechaActiva = new URLSearchParams(window.location.search).get('fecha');
      if (fechaActiva) {
        const fechaTrigger = document.getElementById(`fecha-${fechaActiva}-tab`);
        if (fechaTrigger) {
          const fechaTab = new bootstrap.Tab(fechaTrigger);
          fechaTab.show();
        }
      }
    });
  </script>
</head>

<body class="bg-stadium torneos-page">
  <div id="pullRefreshIndicator" class="pull-refresh-indicator" aria-live="polite">
    <i class="bi bi-arrow-clockwise"></i>
    <span>Desliza para actualizar</span>
  </div>

  <!-- Barra superior fija -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
    <div class="container-fluid">
      <div class="navbar-brand fw-bold me-4 py-0">
        <div>Panel de Torneos</div>
        <div class="small fw-normal text-warning lh-sm">
          <i class="bi bi-building"></i>
          <%= entidadActual ? (entidadActual.codigo || ('Entidad #' + entityId)) : ('Entidad #' + entityId) %>
        </div>
      </div>
      <ul class="nav nav-tabs me-auto" role="tablist">


        <li class="nav-item">
          <a class="nav-link active" 
             id="torneos-tab" data-bs-toggle="tab" href="#torneos" role="tab">TORNEOS</a>
        </li>


        <% if (rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" 
               id="grupos-tab" data-bs-toggle="tab" href="#grupos" role="tab">Grupos</a>
          </li>
        <% } %>

        <li class="nav-item">
          <a class="nav-link" id="jugadores-tab" data-bs-toggle="tab" href="#jugadores" role="tab">Jugadores</a>
        </li>
        <% if (rol_id == 2 || rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" id="equipos-tab" data-bs-toggle="tab" href="#equipos" role="tab">Equipos</a>
          </li>
        <% } %>
        <li class="nav-item">
          <a class="nav-link" id="partidos-tab" data-bs-toggle="tab" href="#partidos" role="tab">Fixture</a>
        </li>
        <% if (rol_id != 1) { %>
          <li class="nav-item">
            <a class="nav-link" id="finanzas-tab" data-bs-toggle="tab" href="#finanzas" role="tab">Finanzas</a>
          </li>
        <% } %>
        <li class="nav-item">
          <a class="nav-link" id="estadisticas-tab" data-bs-toggle="tab" href="#estadisticas" role="tab">Estadísticas</a>
        </li>
        <% if (rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" id="items-tab" data-bs-toggle="tab" href="#items" role="tab">Items</a>
          </li>
        <% } %>
        <% if (rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" id="usuarios-tab" data-bs-toggle="tab" href="#usuarios" role="tab">Usuarios</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="auditoria-tab" data-bs-toggle="tab" href="#auditoria" role="tab">Auditoría</a>
          </li>
        <% } %>
      </ul>

      <!-- Botones de navegación a la derecha -->
      <div class="d-flex ms-auto app-nav-actions">
        <% if (rol_id != 1) { %>
          <a href="/entidad/gestionar/<%= entityId %>" class="btn btn-success btn-sm me-2">Ir a Torneos</a>
        <% } %>
        <% if (rol_id == 99) { %>
          <a href="/admin" class="btn btn-success btn-sm me-2">Ir a Entidades</a>
        <% } %>
        <a href="/logout" class="btn btn-success btn-sm">Cerrar sesión</a>
      </div>
    </div>
  </nav>

  <!-- Bloque de alertas arriba -->
 <% if (messages.danger && messages.danger.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.danger[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.success && messages.success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.success[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.info && messages.info.length > 0) { %>
  <div class="alert alert-info alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.info[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.warning && messages.warning.length > 0) { %>
  <div class="alert alert-warning alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.warning[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>


  <!-- Contenido de pestañas -->
  <div class="container mt-5 tab-content">

  <!-- TORNEOS -->

    <div class="tab-pane fade show active" 
     id="torneos" role="tabpanel">

      <h3 class="text-white">Selección de Torneos</h3>
      <ul class="list-group mb-3">
        <li class="list-group-item fw-bold text-muted">Todos los torneos</li>
        <% torneos.forEach(function(t) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center <%= (selectedTorneo == t.id_torneo ? 'active' : '') %>">
            <a href="/torneos/gestionar/<%= t.id_torneo %>" class="text-decoration-none <%= (selectedTorneo == t.id_torneo ? 'text-white' : 'text-dark') %>">
              <strong><%= t.nombre_torneo %></strong> - <%= t.temporada %>
            </a>
            <% if (rol_id == 3 || rol_id == 99) { %>
              <button type="button"
                      class="btn btn-sm <%= (selectedTorneo == t.id_torneo ? 'btn-light' : 'btn-outline-primary') %>"
                      data-id="<%= t.id_torneo %>"
                      data-nombre="<%= t.nombre_torneo %>"
                      data-portada="<%= t.portada || '' %>"
                      onclick="abrirModalPersonalizarTorneo(this)">
                <i class="bi bi-image"></i> Personalizar
              </button>
            <% } %>
          </li>
        <% }); %>
      </ul>
      <% if (selectedTorneo) { %>
        <p class="text-white">Torneo seleccionado: <%= torneo.nombre_torneo %> (<%= torneo.temporada %>)</p>
        <% if (torneo.descripcion) { %>
          <p class="text-muted"><%= torneo.descripcion %></p>
        <% } %>
        <div class="d-flex flex-wrap gap-2 mt-3 mb-2 dashboard-quick-actions">
          <button type="button" class="btn btn-success btn-sm dashboard-tab-link" data-target-tab="#estadisticas" data-target-subtab="#estadisticasTablaPosiciones">
            <i class="bi bi-table"></i> Tabla
          </button>
          <button type="button" class="btn btn-outline-light btn-sm dashboard-tab-link" data-target-tab="#estadisticas" data-target-subtab="#estadisticasRankingGoles">
            <i class="bi bi-trophy"></i> Goleadores
          </button>
          <button type="button" class="btn btn-outline-light btn-sm dashboard-tab-link" data-target-tab="#partidos">
            <i class="bi bi-calendar-event"></i> Fixture
          </button>
          <button type="button" class="btn btn-outline-light btn-sm dashboard-tab-link" data-target-tab="#jugadores">
            <i class="bi bi-people"></i> Jugadores
          </button>
        </div>

        <div class="row g-3 mt-1">
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong>Tabla de posiciones</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#estadisticas" data-target-subtab="#estadisticasTablaPosiciones">Ver</button>
              </div>
              <div class="table-responsive bg-white">
                <table class="table table-sm align-middle mb-0">
                  <tbody>
                    <% ((dashboardInicio || {}).tablaTop || []).forEach((item, index) => { %>
                      <tr>
                        <td style="width:40px;"><strong><%= index + 1 %></strong></td>
                        <td>
                          <img src="<%= item.icono || '/images/default_team.png' %>" alt="" style="width:24px;height:24px;object-fit:contain;">
                          <strong><%= item.nombre %></strong>
                        </td>
                        <td class="text-end"><strong><%= item.puntos %> pts</strong></td>
                      </tr>
                    <% }) %>
                    <% if (!((dashboardInicio || {}).tablaTop || []).length) { %>
                      <tr><td class="text-center text-muted py-3">Sin posiciones todavia.</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong>Goleadores</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#estadisticas" data-target-subtab="#estadisticasRankingGoles">Ver</button>
              </div>
              <div class="table-responsive bg-white">
                <table class="table table-sm align-middle mb-0">
                  <tbody>
                    <% ((dashboardInicio || {}).goleadoresTop || []).forEach(jugador => { %>
                      <tr>
                        <td><strong><%= [jugador.nombre, jugador.apellido].filter(Boolean).join(' ') %></strong></td>
                        <td><small><%= jugador.equipo || 'Libre' %></small></td>
                        <td class="text-end"><strong><%= jugador.goles %></strong></td>
                      </tr>
                    <% }) %>
                    <% if (!((dashboardInicio || {}).goleadoresTop || []).length) { %>
                      <tr><td class="text-center text-muted py-3">Sin goles cargados todavia.</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <% if (((dashboardInicio || {}).partidosEnCurso || []).length) { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0 dashboard-en-curso-card">
              <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <strong>En curso</strong>
                <button type="button" class="btn btn-sm btn-outline-dark dashboard-tab-link" data-target-tab="#partidos">Fixture</button>
              </div>
              <div class="list-group list-group-flush">
                <% ((dashboardInicio || {}).partidosEnCurso || []).forEach(partido => { %>
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between gap-2 align-items-start">
                      <div>
                        <strong class="d-block"><%= partido.nombre_equipo_a || 'Equipo A' %> <span class="text-warning-emphasis"><%= partido.goles_a ?? 0 %> - <%= partido.goles_b ?? 0 %></span> <%= partido.nombre_equipo_b || 'Equipo B' %></strong>
                        <small class="text-muted">Fecha <%= partido.numero_fecha || '-' %><% if (partido.fecha_formateada && partido.fecha_formateada !== '-') { %> | <%= partido.fecha_formateada %><% } %><% if (partido.hora && partido.hora !== '-') { %> | <%= partido.hora %><% } %></small>
                      </div>
                      <span class="badge estado-badge-en-curso">En curso</span>
                    </div>
                    <small>
                      Fecha <%= partido.numero_fecha || '-' %> Â· <%= partido.fecha_formateada || '-' %> Â· <%= partido.hora || '-' %>
                    </small>
                  </div>
                <% }) %>
                <% if (!((dashboardInicio || {}).partidosEnCurso || []).length) { %>
                  <div class="list-group-item text-center text-muted py-3">Sin encuentros en curso.</div>
                <% } %>
              </div>
            </div>
          </div>
          <% } %>

          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong>Últimos resultados</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#partidos">Fixture</button>
              </div>
              <div class="list-group list-group-flush">
                <% ((dashboardInicio || {}).ultimosResultados || []).forEach(partido => { %>
                  <div class="list-group-item d-flex justify-content-between align-items-center">
                    <span><%= partido.nombre_equipo_a %> <strong><%= partido.goles_a %> - <%= partido.goles_b %></strong> <%= partido.nombre_equipo_b %></span>
                    <small class="text-muted">Fecha <%= partido.numero_fecha || '-' %></small>
                  </div>
                <% }) %>
                <% if (!((dashboardInicio || {}).ultimosResultados || []).length) { %>
                  <div class="list-group-item text-center text-muted py-3">Sin resultados finalizados.</div>
                <% } %>
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong>Próximos encuentros</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#partidos">Fixture</button>
              </div>
              <div class="list-group list-group-flush">
                <% ((dashboardInicio || {}).proximosPartidos || []).forEach(partido => { %>
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between">
                      <strong><%= partido.nombre_equipo_a %> vs <%= partido.nombre_equipo_b %></strong>
                      <small class="text-muted">Fecha <%= partido.numero_fecha || '-' %></small>
                    </div>
                    <small>
                      <%= partido.fecha_formateada || '-' %> · <%= partido.hora || '-' %><%= partido.nombre_cancha ? ' · ' + partido.nombre_cancha : '' %>
                    </small>
                  </div>
                <% }) %>
                <% if (!((dashboardInicio || {}).proximosPartidos || []).length) { %>
                  <div class="list-group-item text-center text-muted py-3">Sin encuentros pendientes.</div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% } else { %>
        <p class="text-muted">Seleccione un torneo para ver detalles.</p>
      <% } %>
    </div>


    
    <!-- Grupos -->
    <!-- Grupos -->
<div class="tab-pane fade" 
     id="grupos" role="tabpanel">
  <h3 class="text-white">Grupos del Torneo</h3>

  <!-- Crear grupo -->
  <form action="/grupos/crear" method="POST" class="mb-3">
    <div class="input-group">
      <input type="text" name="nombre_grupo" class="form-control text-uppercase"
             placeholder="Nuevo grupo" required
             oninput="this.value = this.value.toUpperCase()">
      <input type="hidden" name="id_torneo" value="<%= torneo.id_torneo %>">
      <button type="submit" class="btn btn-success">Agregar Grupo</button>
    </div>
  </form>

  <% if (grupos && grupos.length > 0) { %>
    <div class="row">
      <% grupos.forEach(grupo => { %>
        <div class="col-md-6 mb-4">
          <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
              <strong><%= grupo.nombre_grupo %></strong>
              <% if (grupo.Equipos && grupo.Equipos.length > 0) { %>
                <form action="/grupos/eliminar/<%= grupo.id_grupo %>" method="POST"
                      class="form-confirmar-app"
                      data-confirm-title="Eliminar grupo"
                      data-confirm-message="Este grupo contiene equipos. ¿Seguro que quiere eliminarlo?"
                      data-confirm-accept="Sí, eliminar"
                      data-confirm-cancel="Cancelar">
                  <button type="submit" class="btn btn-sm btn-danger">✖</button>
                </form>
              <% } else { %>
                <form action="/grupos/eliminar/<%= grupo.id_grupo %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-danger">✖</button>
                </form>
              <% } %>
            </div>

            <div class="card-body">
              <!-- Mostrar nombre sin edición -->
              <p class="fw-bold">Nombre personalizado: <%= grupo.nombre_grupo %></p>

              <% if (grupo.Equipos && grupo.Equipos.length > 0) { %>
                <h6>Equipos en este grupo:</h6>
                <ul class="list-group">
                  <% grupo.Equipos.forEach(equipo => { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center 
                               <%= !equipo.estado ? 'text-muted bg-light' : '' %>">
                      <span><%= equipo.nombre %></span>
                      <div class="btn-group">
                        <form action="/equipos/eliminar/<%= equipo.id_equipo %>" method="POST" style="display:inline;">
                          <input type="hidden" name="redirect_hash" value="#grupos">
                          <button type="submit" class="btn btn-sm btn-danger">✖</button>
                        </form>
                      </div>
                      <% if (!equipo.estado) { %>
                        <small class="badge text-bg-secondary">Equipo inactivo - deshabilitada</small>
                      <% } %>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="text-muted">No hay equipos asignados a este grupo.</p>
              <% } %>

              <% if (grupo.movimientos_salida && grupo.movimientos_salida.length > 0) { %>
                <div class="mt-2">
                  <% grupo.movimientos_salida.forEach(mov => { %>
                    <div class="alert alert-warning py-1 px-2 mb-1">
                      <strong><%= mov.Equipo ? mov.Equipo.nombre : 'Equipo' %></strong>
                      <strong>Pasó a otro grupo/fase</strong>
                      <% if (mov.GrupoDestino) { %>
                        <small class="text-muted">(<%= mov.GrupoDestino.nombre_grupo %>)</small>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <!-- Agregar equipo -->
              <form action="/equipos/crear" method="POST" class="mt-2 form-agregar-equipo">
                <div class="input-group">
                  <input type="text" name="nombre_equipo" class="form-control text-uppercase" 
                         placeholder="Nuevo equipo" required 
                         oninput="this.value = this.value.toUpperCase()">
                  <input type="hidden" name="id_grupo" value="<%= grupo.id_grupo %>">
                  <input type="hidden" name="id_torneo" value="<%= torneo.id_torneo %>">
                  <button type="submit" class="btn btn-success">Agregar</button>
                </div>
              </form>

              <% if (rol_id == 3 || rol_id == 99) { %>
                <% const grupoVisibleFixture = grupo.visible_fixture !== false; %>
                <form action="/grupos/fixture-visibilidad/<%= grupo.id_grupo %>"
                      method="POST"
                      class="mt-2 form-confirmar-app"
                      data-confirm-title="<%= grupoVisibleFixture ? 'Ocultar grupo del Fixture' : 'Mostrar grupo en Fixture' %>"
                      data-confirm-message="<%= grupoVisibleFixture ? 'El historico de este grupo seguira en dashboard y estadisticas, pero dejara de verse en Fixture. ¿Desea continuar?' : 'Este grupo volvera a verse en Fixture. ¿Desea continuar?' %>"
                      data-confirm-accept="<%= grupoVisibleFixture ? 'Dejar de ver' : 'Volver a ver' %>"
                      data-confirm-cancel="Cancelar">
                  <input type="hidden" name="visible_fixture" value="<%= grupoVisibleFixture ? '0' : '1' %>">
                  <button type="submit"
                          class="btn btn-sm <%= grupoVisibleFixture ? 'btn-outline-secondary' : 'btn-outline-success' %> w-100 text-start">
                    <i class="bi <%= grupoVisibleFixture ? 'bi-eye-slash' : 'bi-eye' %>"></i>
                    <%= grupoVisibleFixture ? 'Dejar de ver en Fixture' : 'Volver a ver en Fixture' %>
                  </button>
                  <small class="text-muted d-block mt-1">
                    <%= grupoVisibleFixture
                      ? 'Se vera el historico en dashboard, pero no en Fixture.'
                      : 'Actualmente no aparece en Fixture; el historico sigue disponible.' %>
                  </small>
                </form>
              <% } %>

              <!-- Botón para sortear encuentros -->
              <% if (grupo.encuentros_sorteados) { %>
                <button class="btn btn-secondary mt-3" disabled>
                  <i class="bi bi-lock-fill"></i> Sortear Encuentros
                </button>
                <div class="mt-2 small text-warning">Encuentros ya sorteados</div>
              <% } else if (grupo.Equipos && grupo.Equipos.length > 1) { %>
                <button class="btn btn-primary mt-3 abrir-sorteo-btn" 
                        data-bs-toggle="modal" 
                        data-bs-target="#modalSorteoFase1"
                        data-id-grupo="<%= grupo.id_grupo %>"
                        data-num-equipos="<%= grupo.Equipos.length %>"
                        data-id-torneo="<%= torneo.id_torneo %>">
                  <i class="fas fa-shuffle"></i> Sortear Encuentros
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-muted">No hay grupos creados aún para este torneo.</p>
  <% } %>

  <!-- ============================================ -->
  <!-- MODAL FASE 1: CONFIRMACIÓN INICIAL -->
  <!-- ============================================ -->
  <div class="modal fade" id="modalSorteoFase1" tabindex="-1" role="dialog" aria-labelledby="modalLabel1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalLabel1">
            <i class="fas fa-shuffle"></i> Sortear Encuentros
          </h5>
          <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <p class="lead">¿Desea sortear los equipos de este grupo?</p>
          <p class="text-muted" id="grupoNombreInfo"></p>
          <div class="alert alert-info" role="alert">
            <i class="fas fa-lightbulb"></i>
            <strong>Total de equipos:</strong> <span id="totalEquiposInfo">-</span>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-times"></i> Cancelar
          </button>
          <button type="button" class="btn btn-primary" onclick="abrirModalFase2()">
            <i class="fas fa-arrow-right"></i> Continuar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MODAL FASE 2: CONFIGURACIÓN DEL SORTEO -->
  <!-- ============================================ -->
  <div class="modal fade" id="modalSorteoFase2" tabindex="-1" role="dialog" aria-labelledby="modalLabel2" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalLabel2">
            <i class="fas fa-cog"></i> Configurar Sorteo
          </h5>
          <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="formSorteo">
            <!-- Tipo de encuentro -->
            <div class="form-group">
              <label for="tipoEncuentro" class="font-weight-bold">
                <i class="fas fa-question-circle"></i> Tipo de encuentro:
              </label>
              <div class="custom-control custom-radio mb-2">
                <input 
                  type="radio" 
                  id="radioSimple" 
                  name="tipo" 
                  value="simple" 
                  class="custom-control-input" 
                  checked 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioSimple">
                  <strong>Simple</strong> - Cada equipo juega una sola vez contra cada otro
                </label>
              </div>
              <div class="custom-control custom-radio mb-3">
                <input 
                  type="radio" 
                  id="radioIdaVuelta" 
                  name="tipo" 
                  value="ida_vuelta" 
                  class="custom-control-input" 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioIdaVuelta">
                  <strong>Ida y Vuelta</strong> - Cada equipo juega dos veces contra cada otro
                </label>
              </div>
              <div class="custom-control custom-radio mb-3">
                <input 
                  type="radio" 
                  id="radioFijo" 
                  name="tipo" 
                  value="fijo" 
                  class="custom-control-input" 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioFijo">
                  <strong>Fijo</strong> - Especificar número de fechas manualmente
                </label>
              </div>
            </div>

            <!-- Campo para número de fechas (solo visible cuando es fijo) -->
            <div class="form-group" id="grupNumFechas" style="display: none;">
              <label for="numFechas" class="font-weight-bold">
                <i class="fas fa-calendar-alt"></i> Número de fechas:
              </label>
              <input 
                type="number" 
                id="numFechas" 
                name="numFechas" 
                class="form-control" 
                min="1" 
                max="50" 
                placeholder="Ej: 3, 5, 10"
                oninput="actualizarValidacion()"
              >
              <small class="text-muted d-block mt-1" id="textNumFechasInfo"></small>
            </div>

            <!-- Validación de fechas -->
            <div id="alertaValidacion" class="alert mt-3" style="display: none;" role="alert"></div>

            <!-- Resumen estimado -->
            <div class="card bg-light mt-3">
              <div class="card-body">
                <h6 class="card-title">
                  <i class="fas fa-chart-bar"></i> Resumen:
                </h6>
                <ul class="list-unstyled small">
                  <li>
                    <strong>Equipos en el grupo:</strong> 
                    <span id="resumenEquipos">-</span>
                  </li>
                  <li>
                    <strong>Partidos por equipo (estimado):</strong> 
                    <span id="resumenPartidosEquipo">-</span>
                  </li>
                  <li>
                    <strong>Total de partidos (estimado):</strong> 
                    <span id="resumenTotalPartidos">-</span>
                  </li>
                  <li>
                    <strong>Número de fechas:</strong> 
                    <span id="resumenFechas">-</span>
                  </li>
                </ul>
              </div>
            </div>
          </form>
          </div>
          <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-arrow-left"></i> Atrás
          </button>
          <button type="button" class="btn btn-success" id="btnConfirmarSorteo" onclick="confirmarSorteo()">
            <i class="fas fa-check"></i> Confirmar Sorteo
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Variables globales para el modal
let grupoActual = null;
let numEquiposActual = 0;
let torneoActual = null;
const equiposPorGrupo = <%- JSON.stringify((equipos || []).reduce((acc, equipo) => {
  const key = String(equipo.id_grupo || '');
  if (!acc[key]) acc[key] = [];
  acc[key].push({
    id_equipo: equipo.id_equipo,
    nombre: equipo.nombre,
    id_grupo: equipo.id_grupo,
    nombre_grupo: equipo.nombre_grupo || 'Sin grupo'
  });
  return acc;
}, {})) %>;
let finanzasResumen = <%- JSON.stringify(finanzasResumen || []).replace(/</g, '\\u003c') %>;

function formatearFechaInput(fecha) {
  if (!fecha) return '';
  return String(fecha).slice(0, 10);
}

function formatoMontoFinanzas(valor) {
  const numero = Number(valor || 0);
  return numero.toLocaleString('es-PY', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  });
}

function formatoFechaFinanzas(fecha) {
  if (!fecha) return '-';
  const valor = String(fecha).slice(0, 10);
  return valor ? valor.split('-').reverse().join('/') : '-';
}

function etiquetaFechaFinanzas(movimiento) {
  const numero = movimiento?.numero_fecha || '-';
  const fechaCalendario = formatoFechaFinanzas(movimiento?.fecha_calendario || movimiento?.fecha_registro);
  const grupo = movimiento?.nombre_grupo_display || movimiento?.nombre_grupo || '';
  const grupoVisible = grupo && grupo !== 'Sin grupo';
  const titulo = grupoVisible ? `${grupo} - Fecha ${numero}` : `Fecha ${numero}`;
  return `
    <strong class="d-block">${escaparHtml(titulo)}</strong>
    <small class="text-muted">${fechaCalendario}</small>
  `;
}

function conceptoVisibleFinanzas(movimiento) {
  return movimiento?.concepto_display || movimiento?.concepto || 'Movimiento';
}

function renderFinanzasResumen() {
  const tbody = document.getElementById('finanzasResumenTbody');
  if (!tbody) return;

  if (!finanzasResumen.length) {
    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No hay equipos cargados para este torneo.</td></tr>';
    return;
  }

  tbody.innerHTML = finanzasResumen.map(equipo => `
    <tr data-finanzas-equipo-id="${escaparHtml(equipo.id_equipo)}">
      <td data-label="Equipo">
        <div class="d-flex align-items-center gap-2">
          <img src="${escaparHtml(equipo.icono || '/images/default_team.png')}" alt="" style="width:28px;height:28px;object-fit:cover;border-radius:50%;">
          <strong class="text-dark">${escaparHtml(equipo.nombre || '')}</strong>
        </div>
      </td>
      <td class="text-dark" data-label="Grupo">${escaparHtml(equipo.nombre_grupo || 'Sin grupo')}</td>
      <td class="text-center finanzas-estado-cell" data-label="Estado">
        ${equipo.adeuda ? '<span class="fw-bold text-danger" title="Equipo con deuda">‼️‼️</span>' : '<span class="badge text-bg-success">Al dia</span>'}
      </td>
      <td class="text-end fw-bold finanzas-admin-only finanzas-saldo-cell ${equipo.adeuda ? 'text-danger' : 'text-dark'}" data-label="Saldo">${formatoMontoFinanzas(equipo.saldo_actual)}</td>
      <td class="text-end" data-label="Acciones">
        <button type="button" class="btn btn-sm btn-outline-dark" onclick="abrirDetalleFinanzas('${escaparHtml(equipo.id_equipo)}')">Detalles</button>
      </td>
    </tr>
  `).join('');
}

async function sincronizarFinanzasDesdeServidor() {
  try {
    const response = await fetch(`/torneos/<%= torneo.id_torneo %>/finanzas/resumen`, {
      headers: { 'Accept': 'application/json' }
    });
    const data = await response.json();
    if (!data.success) return;
    finanzasResumen = data.finanzasResumen || [];
    renderFinanzasResumen();
  } catch (error) {
    console.error('No se pudo actualizar finanzas:', error);
  }
}

function abrirDetalleFinanzas(idEquipo) {
  const equipo = finanzasResumen.find(item => String(item.id_equipo) === String(idEquipo));
  if (!equipo) return;

  document.getElementById('finanzasDetalleTitulo').textContent = `Detalle financiero - ${equipo.nombre}`;
  document.getElementById('finanzasDetalleSubtitulo').textContent = `${equipo.nombre_grupo || 'Sin grupo'} · Saldo actual: ${formatoMontoFinanzas(equipo.saldo_actual)}`;

  const tbody = document.getElementById('finanzasDetalleTbody');
  tbody.innerHTML = '';

  if (!equipo.movimientos || equipo.movimientos.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Sin movimientos financieros registrados.</td></tr>';
  } else {
    equipo.movimientos.forEach(movimiento => {
      const fila = document.createElement('tr');
      fila.innerHTML = `
        <td>${etiquetaFechaFinanzas(movimiento)}</td>
        <td>${escaparHtml(conceptoVisibleFinanzas(movimiento))}</td>
        <td class="text-end">${formatoMontoFinanzas(movimiento.deuda_inicial)}</td>
        <td class="text-end">${formatoMontoFinanzas(movimiento.total_items)}</td>
        <td class="text-end">${formatoMontoFinanzas(movimiento.entrega)}</td>
        <td class="text-end fw-bold">${formatoMontoFinanzas(movimiento.saldo)}</td>
      `;
      tbody.appendChild(fila);

      const items = movimiento.items || [];
      if (items.length > 0) {
        const filaItems = document.createElement('tr');
        filaItems.innerHTML = `
          <td></td>
          <td colspan="5">
            <div class="small text-dark">
              ${items.map(item => `
                <div class="d-flex justify-content-between border-bottom py-1">
                  <span>${escaparHtml(item.nombre || 'Item')} x${item.cantidad || 0}${item.observaciones ? ` · ${escaparHtml(item.observaciones)}` : ''}</span>
                  <strong>${formatoMontoFinanzas(item.total)}</strong>
                </div>
              `).join('')}
            </div>
          </td>
        `;
        tbody.appendChild(filaItems);
      }
    });
  }

  document.getElementById('finanzasDetalleTotalItems').textContent = formatoMontoFinanzas(equipo.total_items);
  document.getElementById('finanzasDetalleTotalEntregado').textContent = formatoMontoFinanzas(equipo.total_entregado);
  document.getElementById('finanzasDetalleSaldo').textContent = formatoMontoFinanzas(equipo.saldo_actual);
  document.getElementById('finanzasDetalleAlerta').classList.toggle('d-none', !equipo.adeuda);

  bootstrap.Modal.getOrCreateInstance(document.getElementById('modalDetalleFinanzas')).show();
}

function sumarMinutosHora(hora, minutos) {
  if (!hora) return '';
  const [hh, mm] = hora.split(':').map(Number);
  const base = new Date(2000, 0, 1, hh || 0, mm || 0, 0, 0);
  base.setMinutes(base.getMinutes() + Number(minutos || 0));
  return `${String(base.getHours()).padStart(2, '0')}:${String(base.getMinutes()).padStart(2, '0')}`;
}

function recargarManteniendoPestana(hash = '#partidos') {
  window.location.href = `${window.location.pathname}${window.location.search}${hash}`;
}

function obtenerEquiposGrupo(grupoId) {
  return equiposPorGrupo[String(grupoId)] || [];
}

function actualizarAccionesPartido(partidoId, estado) {
  const estadoNormalizado = normalizarEstadoPartidoCliente(estado);
  const fila = document.querySelector(`.estado-select[data-id="${partidoId}"]`)?.closest('tr');
  if (!fila) return;
  const botonEditar = fila.querySelector('.editar-horario-btn');
  const botonEliminar = fila.querySelector('form[action*="/eliminar"] button[type="submit"]');
  const selectEstado = fila.querySelector('.estado-select');

  if (botonEditar) botonEditar.disabled = estadoNormalizado === 'finalizado';
  if (botonEliminar) botonEliminar.disabled = estadoNormalizado === 'finalizado';
  if (selectEstado) {
    selectEstado.classList.toggle('estado-en-curso', estadoNormalizado === 'en_curso');
  }
}

function normalizarEstadoPartidoCliente(estado) {
  return String(estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_');
}

function cerrarModalBootstrapSeguro(modalId) {
  const modalEl = document.getElementById(modalId);
  if (!modalEl) return;
  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  modal.hide();
  setTimeout(() => {
    document.body.classList.remove('modal-open');
    document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
    document.body.style.removeProperty('padding-right');
    document.body.style.removeProperty('overflow');
  }, 150);
}

function limpiarBloqueoModalBootstrap() {
  document.body.classList.remove('modal-open');
  document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
  document.body.style.removeProperty('padding-right');
  document.body.style.removeProperty('overflow');
}

function normalizarCampoMarcador(input) {
  input.value = input.value.replace(/\D/g, '');
}

function marcadorValido(valor) {
  return /^(0|[1-9]\d*)$/.test(valor) && Number.parseInt(valor, 10) <= 99;
}

function abrirModalItem(item = null) {
  const form = document.getElementById('formItem');
  const titulo = document.getElementById('itemModalTitulo');
  const idInput = document.getElementById('itemId');
  const nombreInput = document.getElementById('itemNombre');
  const descripcionInput = document.getElementById('itemDescripcion');
  const montoInput = document.getElementById('itemMonto');
  const torneoInput = document.getElementById('itemTorneoId');
  const entityInput = document.getElementById('itemEntityId');

  if (!form || !titulo || !idInput || !nombreInput || !descripcionInput || !montoInput || !torneoInput || !entityInput) return;

  if (item) {
    titulo.textContent = 'Editar item';
    form.action = `/items/${item.id_item}`;
    idInput.value = item.id_item;
    nombreInput.value = item.nombre || '';
    descripcionInput.value = item.descripcion || '';
    montoInput.value = item.monto || '';
  } else {
    titulo.textContent = 'Nuevo item';
    form.action = '/items';
    idInput.value = '';
    nombreInput.value = '';
    descripcionInput.value = '';
    montoInput.value = '';
  }

  torneoInput.value = '<%= torneo.id_torneo %>';
  entityInput.value = '<%= torneo.entity_id %>';

  const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('modalItem'));
  modal.show();
}

function abrirModalPersonalizarTorneo(button) {
  const torneoId = button.dataset.id;
  const nombre = button.dataset.nombre || 'torneo';
  const portada = button.dataset.portada || '';
  const modalEl = document.getElementById('modalPersonalizarTorneo');
  const titulo = document.getElementById('modalPersonalizarTorneoTitulo');
  const formPortada = document.getElementById('formPortadaTorneo');
  const formEliminar = document.getElementById('formEliminarPortadaTorneo');
  const bloqueActual = document.getElementById('bloquePortadaActual');
  const imgActual = document.getElementById('portadaActualPreview');

  if (!torneoId || !modalEl || !titulo || !formPortada || !formEliminar || !bloqueActual || !imgActual) return;

  titulo.textContent = `Personalizar ${nombre}`;
  formPortada.action = `/torneos/${torneoId}/portada`;
  formEliminar.action = `/torneos/${torneoId}/portada/eliminar`;

  if (portada) {
    imgActual.src = portada;
    bloqueActual.classList.remove('d-none');
    formEliminar.classList.remove('d-none');
  } else {
    imgActual.removeAttribute('src');
    bloqueActual.classList.add('d-none');
    formEliminar.classList.add('d-none');
  }

  const input = document.getElementById('portadaTorneo');
  if (input) input.value = '';

  bootstrap.Modal.getOrCreateInstance(modalEl).show();
}

function actualizarOpcionesCruceManual() {
  const selectGrupo = document.getElementById('manualGrupoId');
  const selectEquipoA = document.getElementById('manualEquipoA');
  const selectEquipoB = document.getElementById('manualEquipoB');

  if (!selectGrupo || !selectEquipoA || !selectEquipoB) return;

  const grupoId = selectGrupo.value;
  const equipos = obtenerEquiposGrupo(grupoId);
  const equipoASeleccionado = selectEquipoA.value;
  const equipoBSeleccionado = selectEquipoB.value;

  const renderOptions = (seleccionExcluida) => {
    return ['<option value="">Seleccione un equipo</option>']
      .concat(
        equipos
          .filter(equipo => String(equipo.id_equipo) !== String(seleccionExcluida))
          .map(equipo => `<option value="${equipo.id_equipo}">${equipo.nombre}</option>`)
      )
      .join('');
  };

  selectEquipoA.innerHTML = renderOptions(equipoBSeleccionado);
  selectEquipoB.innerHTML = renderOptions(equipoASeleccionado);

  if (equipoASeleccionado && equipos.some(e => String(e.id_equipo) === String(equipoASeleccionado))) {
    selectEquipoA.value = equipoASeleccionado;
  }
  if (equipoBSeleccionado && equipos.some(e => String(e.id_equipo) === String(equipoBSeleccionado))) {
    selectEquipoB.value = equipoBSeleccionado;
  }
}

// Validar fechas según cantidad de equipos
function validarFechas(numEquipos, fechasIngresadas) {
  const maxSimple = numEquipos - 1;
  const maxIdaVuelta = (numEquipos - 1) * 2;

  let valido = false;
  let mensaje = "";
  let tipo = "";

  if (fechasIngresadas > 0 && fechasIngresadas <= maxSimple) {
    valido = true;
    tipo = "success";
    mensaje = `✅ Excelente! Con ${fechasIngresadas} fechas, todos los equipos juegan ${fechasIngresadas} encuentros de forma balanceada.`;
  } else if (fechasIngresadas === maxIdaVuelta) {
    valido = true;
    tipo = "success";
    mensaje = `✅ Excelente! Con ${fechasIngresadas} fechas, todos los equipos juegan ida y vuelta (${maxIdaVuelta} encuentros) de forma balanceada.`;
  } else if (fechasIngresadas > 0) {
    valido = true;
    tipo = "warning";
    mensaje = `⚠️ Atención: con ${numEquipos} equipos y ${fechasIngresadas} fechas, el torneo quedará disparejo. 
    Se sugiere ${maxSimple} (simple) o ${maxIdaVuelta} (ida/vuelta). El sistema generará encuentros aleatorios.`;
  } else {
    valido = false;
    tipo = "danger";
    mensaje = `❌ Error: el número de fechas debe ser mayor a 0.`;
  }

  return { valido, mensaje, tipo };
}

// Abrir modal fase 1 y capturar datos
function abrirModalSorteo(idGrupo, numEquipos, idTorneo) {
  grupoActual = idGrupo;
  numEquiposActual = numEquipos;
  torneoActual = idTorneo;
  
  // Actualizar info en fase 1
  document.getElementById('grupoNombreInfo').innerHTML = `Grupo con <strong>${numEquipos} equipos</strong>`;
  document.getElementById('totalEquiposInfo').textContent = numEquipos;
}

// Abrir modal fase 2
function abrirModalFase2() {
  const modal1 = bootstrap.Modal.getInstance(document.getElementById('modalSorteoFase1'));
  if (modal1) modal1.hide();
  
  setTimeout(() => {
    const modal2 = new bootstrap.Modal(document.getElementById('modalSorteoFase2'));
    modal2.show();
    actualizarValidacion(); // Calcular valores iniciales
  }, 300);
}

// Actualizar validación en tiempo real
function actualizarValidacion() {
  const tipo = document.querySelector('input[name="tipo"]:checked').value;
  const numFechas = document.getElementById('numFechas');
  const grupNumFechas = document.getElementById('grupNumFechas');
  const alertaValidacion = document.getElementById('alertaValidacion');
  const textNumFechasInfo = document.getElementById('textNumFechasInfo');

  // Mostrar/ocultar campo de fechas
  if (tipo === 'fijo') {
    grupNumFechas.style.display = 'block';
    textNumFechasInfo.textContent = `Ingrese un número entre 1 y ${numEquiposActual * 2}`;
  } else {
    grupNumFechas.style.display = 'none';
  }

  // Calcular fechas automáticamente
  let fechas = 0;
  const maxSimple = numEquiposActual % 2 === 1 ? numEquiposActual : numEquiposActual - 1;
  if (tipo === 'simple') {
    fechas = maxSimple;
  } else if (tipo === 'ida_vuelta') {
    fechas = maxSimple * 2;
  } else if (tipo === 'fijo') {
    fechas = parseInt(numFechas.value) || 0;
  }

  // Actualizar resumen
  actualizarResumen(tipo, fechas);

  // Validar si es fijo
  if (tipo === 'fijo' && numFechas.value) {
    const validacion = validarFechas(numEquiposActual, fechas);
    alertaValidacion.innerHTML = validacion.mensaje;
    alertaValidacion.className = `alert alert-${validacion.tipo} mt-3`;
    alertaValidacion.style.display = 'block';
  } else {
    alertaValidacion.style.display = 'none';
  }
}

// Actualizar resumen de estadísticas
function actualizarResumen(tipo, fechas) {
  const maxPartidosPorEquipo = (numEquiposActual - 1) * 2;
  const partidosPorEquipo = Math.min(numEquiposActual - 1, fechas);
  const totalPartidos = Math.floor((numEquiposActual * partidosPorEquipo) / 2);

  document.getElementById('resumenEquipos').textContent = numEquiposActual;
  document.getElementById('resumenFechas').textContent = fechas || '-';
  document.getElementById('resumenPartidosEquipo').textContent = partidosPorEquipo || '-';
  document.getElementById('resumenTotalPartidos').textContent = totalPartidos || '-';
}

// Confirmar y ejecutar sorteo
async function confirmarSorteo() {
  const tipo = document.querySelector('input[name="tipo"]:checked').value;
  let numFechas = 0;

  const maxSimple = numEquiposActual % 2 === 1 ? numEquiposActual : numEquiposActual - 1;
  if (tipo === 'simple') {
    numFechas = maxSimple;
  } else if (tipo === 'ida_vuelta') {
    numFechas = maxSimple * 2;
  } else if (tipo === 'fijo') {
    numFechas = parseInt(document.getElementById('numFechas').value);
  }

  if (!numFechas || numFechas <= 0) {
    mostrarAvisoApp('Por favor, ingrese un número válido de fechas.', 'Sorteo');
    return;
  }

  const btnConfirmar = document.getElementById('btnConfirmarSorteo');
  btnConfirmar.disabled = true;
  btnConfirmar.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

  try {
    const response = await fetch(`/partidos/torneos/${torneoActual}/grupos/${grupoActual}/sortear`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        tipo: tipo,
        numFechas: numFechas
      })
    });

    const data = await response.json();

    if (data.success) {
      // Mostrar mensaje de éxito
