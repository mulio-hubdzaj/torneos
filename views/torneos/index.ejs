                  data-detalle="<%= registro.detalle_legible || '' %>">
                <td>
                  <small>
                    <%= fechaAudit && !Number.isNaN(fechaAudit.getTime()) ? fechaAudit.toLocaleString('es-PY', { dateStyle: 'short', timeStyle: 'short' }) : '-' %>
