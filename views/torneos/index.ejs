<div class="modal fade" id="modalPersonalizarTorneo" tabindex="-1" aria-labelledby="modalPersonalizarTorneoTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="modalPersonalizarTorneoTitulo">Personalizar torneo</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div id="bloquePortadaActual" class="d-none">
          <img id="portadaActualPreview" src="" alt="Portada actual" class="portada-preview mb-3">
        </div>

        <form id="formPortadaTorneo" action="" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label for="portadaTorneo" class="form-label">Portada</label>
            <input type="file" class="form-control" id="portadaTorneo" name="portada" accept="image/*" required>
          </div>
          <div class="d-flex justify-content-end">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-upload"></i> Guardar portada
            </button>
          </div>
        </form>

        <hr>
        <form id="formEliminarPortadaTorneo" action="" method="POST"
              class="form-confirmar-app"
              data-confirm-title="Eliminar portada"
              data-confirm-message="¿Eliminar la portada de este torneo?"
              data-confirm-accept="Sí, eliminar"
              data-confirm-cancel="Cancelar">
          <button type="submit" class="btn btn-outline-danger w-100">
            <i class="bi bi-trash"></i> Eliminar portada
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalEditarHorario" tabindex="-1" aria-labelledby="modalHorarioTitulo" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form action="" method="POST" id="formEditarHorario">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalHorarioTitulo">Editar horario</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="torneo_id" id="horarioTorneoId">
          <input type="hidden" id="horarioPartidoId">
          <div class="mb-3">
            <label for="horarioFecha" class="form-label">Fecha</label>
            <input type="date" class="form-control" id="horarioFecha" name="fecha">
          </div>
          <div class="mb-3">
            <label for="horarioHora" class="form-label">Hora</label>
            <input type="time" class="form-control" id="horarioHora" name="hora">
          </div>
          <div class="mb-3">
            <label for="horarioCancha" class="form-label">Cancha</label>
            <select class="form-select" id="horarioCancha" name="id_cancha">
              <option value="">Sin cancha</option>
              <% (canchas || []).filter(cancha => cancha.estado).forEach(cancha => { %>
                <option value="<%= cancha.id_cancha %>"><%= cancha.nombre %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

