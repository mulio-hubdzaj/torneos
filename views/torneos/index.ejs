              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="accion" placeholder="Filtrar"></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="usuario" placeholder="Filtrar"></th>
              <th><input type="text" class="form-control form-control-sm audit-filter" data-col="detalle" placeholder="Filtrar"></th>
