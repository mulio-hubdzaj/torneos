function configurarSuspFechasDecision(tr, bloquear = false) {
  const input = tr.querySelector('.carga-jugador-suspendidos');
  if (!input) return;

  if (bloquear) {
    mostrarCamposSuspensionCarga(tr, true);
  }
  input.disabled = Boolean(bloquear);
  input.classList.toggle('bg-light', Boolean(bloquear));
  input.classList.toggle('text-muted', Boolean(bloquear));
}

function valorNumeroInput(valor) {
  const normalizado = String(valor || '0').replace(/\./g, '').replace(',', '.');
  const numero = Number(normalizado);
  return Number.isFinite(numero) && numero >= 0 ? numero : 0;
}

function formatearCampoDinero(input) {
  const soloNumeros = String(input.value || '').replace(/\D/g, '');
  input.value = soloNumeros ? formatoMonto(soloNumeros) : '';
}

function normalizarNombreItem(valor) {
  return String(valor || '').trim().replace(/\s+/g, ' ').toUpperCase();
}

function opcionesItemsCarga(nombreSeleccionado = '') {
  return [
    '<option value="">Seleccionar item</option>',
    ...cargaItemsDisponibles.map(item => {
      const nombre = String(item.nombre || '');
      const selected = nombre === nombreSeleccionado ? 'selected' : '';
      return `<option value="${escaparHtml(nombre)}" data-monto="${escaparHtml(item.monto)}" ${selected}>${escaparHtml(nombre)} - ${formatoMonto(item.monto)}</option>`;
    })
  ].join('');
}

function agregarFilaItemCarga(item = {}) {
  const tbody = document.getElementById('cargaItemsTbody');
  const tr = document.createElement('tr');
  if (item.autoTarjeta) {
    tr.dataset.tarjetaAuto = '1';
  }
  tr.innerHTML = `
    <td class="carga-items-col-item">
      <select class="form-select form-select-sm carga-item-nombre">
        ${opcionesItemsCarga(item.nombre || '')}
      </select>
    </td>
    <td class="carga-items-col-monto"><input type="text" inputmode="numeric" class="form-control form-control-sm carga-monto carga-item-monto campo-dinero" value="${formatoMonto(item.monto || 0)}"></td>
    <td class="carga-items-col-cantidad"><input type="number" min="1" step="1" class="form-control form-control-sm carga-numero carga-item-cantidad" value="${item.cantidad || 1}"></td>
    <td class="carga-items-col-observacion"><input type="text" class="form-control form-control-sm carga-item-observaciones" value="${escaparHtml(item.observaciones || '')}"></td>
    <td class="text-end carga-item-total carga-items-col-total">0.00</td>
    <td class="text-center carga-items-col-accion">
      <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('tr').remove(); recalcularCargaEquipoPartido();">
        <i class="bi bi-trash"></i>
      </button>
    </td>
  `;

  tbody.appendChild(tr);
  const select = tr.querySelector('.carga-item-nombre');
  select.addEventListener('change', () => {
    const option = select.selectedOptions[0];
    tr.querySelector('.carga-item-monto').value = formatoMonto(option?.dataset?.monto || 0);
    delete tr.dataset.tarjetaAuto;
    recalcularCargaEquipoPartido();
  });
  tr.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', () => {
      if (input.classList.contains('campo-dinero')) formatearCampoDinero(input);
      recalcularCargaEquipoPartido();
    });
  });
  recalcularCargaEquipoPartido();
  return tr;
}

function actualizarAcumulacionAmarillasFila(tr, avisar = false) {
  const regla = cargaReglaTarjetasActual || {};
  const info = tr.querySelector('.carga-acumulado-amarillas');
  if (!info) return false;

  const previas = Number.parseInt(tr.dataset.amarillasPrevias || '0', 10) || 0;
  const amarillasPartido = Number.parseInt(tr.querySelector('.carga-jugador-amarillas')?.value || '0', 10) || 0;
  const limite = Number.parseInt(regla.amarillas_para_suspension || tr.dataset.amarillasLimite || '0', 10) || 0;
  const total = previas + amarillasPartido;
  const umbralAlerta = Math.max(limite - 1, 1);
  const alerta = Boolean(regla.acumula_amarillas) && limite > 0 && total >= umbralAlerta && total < limite;
  const alcanzoLimite = Boolean(regla.acumula_amarillas) && limite > 0 && total >= limite;
  const destacar = alerta || alcanzoLimite;

  info.classList.toggle('text-danger', destacar);
  info.classList.toggle('fw-bold', destacar);
  if (limite > 0) {
    const decision = tr.dataset.accionAcumulacion;
    const estado = alcanzoLimite
      ? (decision === 'suspension' ? ' - suspension confirmada' : (decision === 'advertencia' ? ' - advertencia registrada' : ' - requiere decision'))
      : (alerta ? ' - en riesgo' : '');
    info.textContent = `Amarillas acumuladas: ${total}/${limite}${estado}`;
  } else {
    info.textContent = `Amarillas acumuladas: ${total}`;
  }

  if (alcanzoLimite) {
    const observaciones = tr.querySelector('.carga-jugador-observaciones');
    if (observaciones && !/acumulacion/i.test(observaciones.value || '')) {
      observaciones.placeholder = 'Suspension por acumulacion de amarillas';
    }
    if (avisar && tr.dataset.avisoAcumulacion !== '1') {
      tr.dataset.avisoAcumulacion = '1';
      mostrarAvisoApp('El jugador alcanzo el limite de amarillas. Al guardar se pedira confirmar si se suspende o solo se registra advertencia.', 'Suspension por acumulacion');
    }
  } else {
    delete tr.dataset.avisoAcumulacion;
    delete tr.dataset.accionAcumulacion;
    configurarSuspFechasDecision(tr, false);
  }

  return alcanzoLimite;
}

function actualizarAcumulacionesAmarillas(avisar = false) {
  let hayAcumulacion = false;
  document.querySelectorAll('#cargaTarjetasTbody tr[data-jugador-id]').forEach(tr => {
    hayAcumulacion = actualizarAcumulacionAmarillasFila(tr, avisar) || hayAcumulacion;
  });
  return hayAcumulacion;
}

function obtenerNombreJugadorCarga(tr) {
  return tr.querySelector('strong')?.textContent?.trim() || 'Jugador';
}

async function resolverDecisionesAcumulacion() {
  const filas = Array.from(document.querySelectorAll('#cargaTarjetasTbody tr[data-jugador-id]'))
    .filter(tr => actualizarAcumulacionAmarillasFila(tr) && !tr.dataset.accionAcumulacion);
  const regla = cargaReglaTarjetasActual || {};
  const fechasDefault = Number.parseInt(regla.fechas_suspension_acumulacion || '1', 10) || 1;

  for (const tr of filas) {
    const nombre = obtenerNombreJugadorCarga(tr);
    const confirmarSuspension = await confirmarApp(
      `${nombre} alcanzo el limite de amarillas. Quiere confirmar la suspension del jugador?`,
      'Confirmar suspension',
      { aceptar: 'SI', cancelar: 'NO' }
    );
    const suspendidos = tr.querySelector('.carga-jugador-suspendidos');

    if (confirmarSuspension) {
      tr.dataset.accionAcumulacion = 'suspension';
      if (suspendidos && (Number.parseInt(suspendidos.value || '0', 10) || 0) <= 0) {
        suspendidos.value = fechasDefault;
      }
      configurarSuspFechasDecision(tr, true);
    } else {
      tr.dataset.accionAcumulacion = 'advertencia';
      if (suspendidos) suspendidos.value = 0;
      configurarSuspFechasDecision(tr, false);
    }

    actualizarAcumulacionAmarillasFila(tr);
  }
}

function aplicarBusquedaCargaJugadores() {
  const busqueda = normalizarNombreItem(document.getElementById('buscarCargaJugadores')?.value || '');
  document.querySelectorAll('#cargaJugadoresTbody tr[data-jugador-id], #cargaTarjetasTbody tr[data-jugador-id]').forEach(tr => {
    const texto = normalizarNombreItem(tr.dataset.busqueda || '');
    tr.classList.toggle('d-none', Boolean(busqueda) && !texto.includes(busqueda));
  });
}

function normalizarMinutosEvento(valor) {
  if (Array.isArray(valor)) return valor.map(v => String(v).trim()).filter(Boolean);
  return String(valor || '').split(/[,\s;]+/).map(v => v.trim()).filter(Boolean);
}

function obtenerMinutosEventoFila(tr, tipo) {
  return Array.from(tr.querySelectorAll(`.carga-jugador-minuto-${tipo}`))
    .map(input => input.value.trim())
    .filter(Boolean);
}

function formatearCampoTiempoEvento(input) {
  const soloDigitos = String(input.value || '').replace(/\D/g, '').slice(0, 5);
  if (!soloDigitos) {
    input.value = '';
    return;
  }
  if (soloDigitos.length <= 2) {
    input.value = soloDigitos;
    return;
  }
  const minutos = soloDigitos.slice(0, -2);
  const segundos = soloDigitos.slice(-2);
  input.value = `${Number(minutos)}:${segundos}`;
}

function sincronizarEventoDesdeDetalle(tr, tipo) {
  const selectorInput = {
    gol: '.carga-jugador-goles',
    amarilla: '.carga-jugador-amarillas',
    roja: '.carga-jugador-rojas'
  }[tipo];
  const input = tr.querySelector(selectorInput);
  const eventos = tr.querySelectorAll(`.carga-jugador-minuto-${tipo}`);
  if (input) {
    input.value = eventos.length;
  }
  actualizarEstadoContadorEvento(tr, tipo);
}

function actualizarEstadoVacioEventos(tr, tipo) {
  const claseContenedor = {
    gol: '.carga-goles-detalle',
    amarilla: '.carga-amarilla-detalle',
    roja: '.carga-roja-detalle'
  }[tipo];
  const contenedor = claseContenedor ? tr.querySelector(claseContenedor) : null;
  if (!contenedor) return;
  const tieneEventos = Boolean(contenedor.querySelector(`.carga-jugador-minuto-${tipo}`));
  contenedor.classList.toggle('carga-eventos-vacio', !tieneEventos);
  if (!tieneEventos) {
    contenedor.innerHTML = '';
  } else {
    contenedor.querySelectorAll('small.text-muted').forEach(el => el.remove());
  }
  actualizarEstadoContadorEvento(tr, tipo);
}

function actualizarEstadoContadorEvento(tr, tipo) {
  const selectorInput = {
    gol: '.carga-jugador-goles',
    amarilla: '.carga-jugador-amarillas',
    roja: '.carga-jugador-rojas'
  }[tipo];
  const input = tr.querySelector(selectorInput);
  const wrapper = input?.closest('.carga-contador-evento');
  if (!input || !wrapper) return;

  const cantidad = Number.parseInt(input.value || '0', 10) || 0;
  const tieneDetalle = Boolean(tr.querySelector(`.carga-jugador-minuto-${tipo}`));
  const mostrar = cantidad > 0 || tieneDetalle || document.activeElement === input;
  wrapper.classList.toggle('d-none', !mostrar);
  wrapper.closest('td')?.classList.toggle('carga-contador-oculto', !mostrar);
}

function mostrarCamposSuspensionCarga(origen, enfocar = false) {
  const tr = origen?.closest ? origen.closest('tr[data-jugador-id]') : origen;
  if (!tr) return;

  const campos = tr.querySelector('.carga-suspension-fields');
  const boton = tr.querySelector('.carga-btn-suspension');
  if (!campos) return;

  campos.classList.remove('d-none');
  boton?.classList.add('d-none');
  if (enfocar) {
    setTimeout(() => tr.querySelector('.carga-jugador-suspendidos')?.focus(), 0);
  }
}

function actualizarEstadoSuspensionCarga(tr) {
  const campos = tr.querySelector('.carga-suspension-fields');
  const boton = tr.querySelector('.carga-btn-suspension');
  const suspendidos = tr.querySelector('.carga-jugador-suspendidos');
  const observaciones = tr.querySelector('.carga-jugador-observaciones');
  if (!campos || !boton || !suspendidos || !observaciones) return;

  const tieneSuspension = (Number.parseInt(suspendidos.value || '0', 10) || 0) > 0 || Boolean((observaciones.value || '').trim());
  campos.classList.toggle('d-none', !tieneSuspension);
  boton.classList.toggle('d-none', tieneSuspension);
}

function agregarMinutoEventoCarga(origen, tipo, minuto = '') {
  const tr = origen?.closest ? origen.closest('tr[data-jugador-id]') : origen;
  if (!tr) return;
  const claseContenedor = {
    gol: '.carga-goles-detalle',
    amarilla: '.carga-amarilla-detalle',
    roja: '.carga-roja-detalle'
  }[tipo];
  const contenedor = claseContenedor ? tr.querySelector(claseContenedor) : null;
  if (!contenedor) return;
  if (contenedor.classList.contains('carga-eventos-vacio')) {
    contenedor.innerHTML = '';
    contenedor.classList.remove('carga-eventos-vacio');
  }

  const grupo = document.createElement('div');
  grupo.className = 'input-group input-group-sm';
  grupo.innerHTML = `
    <span class="input-group-text">mm:ss</span>
    <input type="text" inputmode="numeric" pattern="^([0-9]{1,3}:[0-5][0-9]|[0-9]{1,3})$" class="form-control carga-jugador-minuto-${tipo}" value="${escaparHtml(minuto)}" placeholder="18:30">
    <button type="button" class="btn btn-outline-danger" title="Quitar evento">
      <i class="bi bi-x-lg"></i>
    </button>
  `;
  grupo.querySelector(`.carga-jugador-minuto-${tipo}`).addEventListener('input', event => {
    formatearCampoTiempoEvento(event.target);
    sincronizarEventoDesdeDetalle(tr, tipo);
  });
  grupo.querySelector('button').addEventListener('click', () => {
    grupo.remove();
    sincronizarEventoDesdeDetalle(tr, tipo);
    actualizarEstadoVacioEventos(tr, tipo);
  });
  contenedor.appendChild(grupo);
  sincronizarEventoDesdeDetalle(tr, tipo);
  actualizarEstadoVacioEventos(tr, tipo);
  grupo.querySelector(`.carga-jugador-minuto-${tipo}`)?.focus();
}

function renderCargaJugadores(jugadores) {
  const tbodyGoles = document.getElementById('cargaJugadoresTbody');
  const tbodyTarjetas = document.getElementById('cargaTarjetasTbody');
  tbodyGoles.innerHTML = '';
  tbodyTarjetas.innerHTML = '';

  if (!jugadores.length) {
    tbodyGoles.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Este equipo no tiene jugadores activos vinculados.</td></tr>';
    tbodyTarjetas.innerHTML = '<tr><td colspan="4" class="text-center text-muted">Este equipo no tiene jugadores activos vinculados.</td></tr>';
    return;
  }

  jugadores.forEach(jugador => {
    const busqueda = [
      jugador.numero_camiseta ? `#${jugador.numero_camiseta}` : '',
      jugador.numero_camiseta || '',
      jugador.nombre || '',
      jugador.apellido || '',
      jugador.documento || ''
    ].join(' ');
    const vinculoActivo = !(jugador.estado_vinculo === false || jugador.estado_vinculo === 'f' || jugador.estado_vinculo === 0);
    const sancionVigente = !vinculoActivo;
    const motivoBloqueo = jugador.observacion_vinculo || jugador.suspension_vigente_observaciones || '';
    const jugadorCelda = `
      <td data-label="Jugador" class="carga-jugador-cell">
        <strong>${jugador.numero_camiseta ? `#${escaparHtml(jugador.numero_camiseta)} ` : ''}${escaparHtml(jugador.nombre || '')} ${escaparHtml(jugador.apellido || '')}</strong>
        <small class="text-muted d-block">${escaparHtml(jugador.documento || '')}</small>
        ${sancionVigente ? `<span class="badge text-bg-warning">Suspendido ${escaparHtml(jugador.suspension_partidos_restantes || 1)} fecha</span>` : ''}
        ${sancionVigente && motivoBloqueo ? `<small class="text-muted d-block">${escaparHtml(motivoBloqueo)}</small>` : ''}
      </td>
    `;

    const trGoles = document.createElement('tr');
    trGoles.dataset.jugadorId = jugador.id_jugador;
    trGoles.dataset.busqueda = busqueda;
    if (sancionVigente) {
      trGoles.classList.add('table-warning');
      trGoles.dataset.sancionVigente = '1';
    }
    trGoles.dataset.golesOriginal = String(sancionVigente ? 0 : (Number.parseInt(jugador.goles || '0', 10) || 0));
    trGoles.innerHTML = `
      ${jugadorCelda}
      <td data-label="Goles" class="carga-evento-cell">
        <div class="carga-contador-evento d-none">
          <span class="carga-contador-label">Goles</span>
          <input type="number" min="0" step="1" class="form-control form-control-sm carga-numero carga-jugador-goles" value="${sancionVigente ? 0 : (jugador.goles || 0)}" ${sancionVigente ? 'disabled' : ''}>
        </div>
      </td>
      <td data-label="Goles del jugador" class="carga-evento-cell">
        <div class="carga-goles-detalle d-grid gap-1"></div>
        <button type="button" class="btn btn-outline-success btn-sm mt-1 carga-btn-agregar-gol" ${sancionVigente ? 'disabled' : ''} onclick="agregarMinutoEventoCarga(this, 'gol')">
          <i class="bi bi-plus-circle"></i> Gol
        </button>
      </td>
    `;

    const trTarjetas = document.createElement('tr');
    trTarjetas.dataset.jugadorId = jugador.id_jugador;
    trTarjetas.dataset.amarillasPrevias = jugador.amarillas_acumuladas_previas || 0;
    trTarjetas.dataset.amarillasLimite = jugador.amarillas_para_suspension || 0;
    trTarjetas.dataset.busqueda = busqueda;
    if (sancionVigente) {
      trTarjetas.classList.add('table-warning');
      trTarjetas.dataset.sancionVigente = '1';
    }
    trTarjetas.innerHTML = `
      <td data-label="Jugador" class="carga-jugador-cell">
        <strong>${jugador.numero_camiseta ? `#${escaparHtml(jugador.numero_camiseta)} ` : ''}${escaparHtml(jugador.nombre || '')} ${escaparHtml(jugador.apellido || '')}</strong>
        <small class="text-muted d-block">${escaparHtml(jugador.documento || '')}</small>
        <small class="text-muted d-block carga-acumulado-amarillas"></small>
        ${sancionVigente ? `<span class="badge text-bg-warning">Suspendido ${escaparHtml(jugador.suspension_partidos_restantes || 1)} fecha</span>` : ''}
        ${sancionVigente && motivoBloqueo ? `<small class="text-muted d-block">${escaparHtml(motivoBloqueo)}</small>` : ''}
      </td>
      <td data-label="Amarillas" class="carga-evento-cell">
        <div class="carga-contador-evento d-none">
          <span class="carga-contador-label">Amarillas</span>
          <input type="number" min="0" step="1" class="form-control form-control-sm carga-numero carga-jugador-amarillas" value="${sancionVigente ? 0 : (jugador.tarjetas_amarillas || 0)}" ${sancionVigente ? 'disabled' : ''}>
        </div>
        <div class="carga-amarilla-detalle d-grid gap-1 mt-1"></div>
        <button type="button" class="btn btn-outline-warning btn-sm mt-1" ${sancionVigente ? 'disabled' : ''} onclick="agregarMinutoEventoCarga(this, 'amarilla')">
          <i class="bi bi-plus-circle"></i> Amarilla
        </button>
      </td>
      <td data-label="Rojas" class="carga-evento-cell">
        <div class="carga-contador-evento d-none">
          <span class="carga-contador-label">Rojas</span>
          <input type="number" min="0" step="1" class="form-control form-control-sm carga-numero carga-jugador-rojas" value="${sancionVigente ? 0 : (jugador.tarjetas_rojas || 0)}" ${sancionVigente ? 'disabled' : ''}>
        </div>
        <div class="carga-roja-detalle d-grid gap-1 mt-1"></div>
        <button type="button" class="btn btn-outline-danger btn-sm mt-1" ${sancionVigente ? 'disabled' : ''} onclick="agregarMinutoEventoCarga(this, 'roja')">
          <i class="bi bi-plus-circle"></i> Roja
        </button>
      </td>
      <td data-label="Suspension" class="carga-suspension-cell" colspan="2">
        <div class="carga-suspension-fields d-none">
          <div class="carga-suspension-grid">
            <input type="number" min="0" step="1" class="form-control form-control-sm carga-numero carga-jugador-suspendidos" value="${jugador.partidos_suspendidos || 0}" aria-label="Fechas de suspension">
            <input type="text" class="form-control form-control-sm carga-jugador-observaciones" value="${escaparHtml(jugador.suspension_observaciones || '')}" placeholder="Motivo suspension" aria-label="Motivo suspension">
          </div>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm carga-btn-suspension" onclick="mostrarCamposSuspensionCarga(this, true)">
          <i class="bi bi-plus-circle"></i> Susp.
        </button>
      </td>
    `;
    tbodyGoles.appendChild(trGoles);
    tbodyTarjetas.appendChild(trTarjetas);

    normalizarMinutosEvento(jugador.goles_minutos).forEach(minuto => agregarMinutoEventoCarga(trGoles, 'gol', minuto));
    normalizarMinutosEvento(jugador.amarillas_minutos).forEach(minuto => agregarMinutoEventoCarga(trTarjetas, 'amarilla', minuto));
    normalizarMinutosEvento(jugador.rojas_minutos).forEach(minuto => agregarMinutoEventoCarga(trTarjetas, 'roja', minuto));
    actualizarEstadoVacioEventos(trGoles, 'gol');
    ['amarilla', 'roja'].forEach(tipo => actualizarEstadoVacioEventos(trTarjetas, tipo));

    ['gol'].forEach(tipo => {
      const input = trGoles.querySelector({
        gol: '.carga-jugador-goles',
        amarilla: '.carga-jugador-amarillas',
        roja: '.carga-jugador-rojas'
      }[tipo]);
      input?.addEventListener('input', () => actualizarEstadoContadorEvento(trGoles, tipo));
      input?.addEventListener('blur', () => actualizarEstadoContadorEvento(trGoles, tipo));
      actualizarEstadoContadorEvento(trGoles, tipo);
    });
    ['amarilla', 'roja'].forEach(tipo => {
      const input = trTarjetas.querySelector({
        amarilla: '.carga-jugador-amarillas',
        roja: '.carga-jugador-rojas'
      }[tipo]);
      input?.addEventListener('input', () => actualizarEstadoContadorEvento(trTarjetas, tipo));
      input?.addEventListener('blur', () => actualizarEstadoContadorEvento(trTarjetas, tipo));
      actualizarEstadoContadorEvento(trTarjetas, tipo);
    });

    actualizarEstadoSuspensionCarga(trTarjetas);
    trTarjetas.querySelectorAll('.carga-jugador-suspendidos, .carga-jugador-observaciones').forEach(input => {
      input.addEventListener('input', () => mostrarCamposSuspensionCarga(trTarjetas));
    });
    trTarjetas.querySelectorAll('.carga-jugador-amarillas, .carga-jugador-rojas').forEach(input => {
      input.addEventListener('input', () => {
        delete trTarjetas.dataset.accionAcumulacion;
        configurarSuspFechasDecision(trTarjetas, false);
        actualizarAcumulacionAmarillasFila(trTarjetas, input.classList.contains('carga-jugador-amarillas'));
      });
    });
    actualizarAcumulacionAmarillasFila(trTarjetas);
  });
}

function opcionesJugadoresCambio(valorSeleccionado = '') {
  return [
    '<option value="">Seleccione jugador</option>',
    ...cargaJugadoresCambio.map(jugador => {
      const etiqueta = `${jugador.numero_camiseta ? `#${jugador.numero_camiseta} ` : ''}${jugador.nombre || ''} ${jugador.apellido || ''}`.trim();
      const selected = String(valorSeleccionado || '') === String(jugador.id_jugador) ? 'selected' : '';
      return `<option value="${escaparHtml(jugador.id_jugador)}" ${selected}>${escaparHtml(etiqueta)}</option>`;
    })
  ].join('');
}

function agregarFilaCambioCarga(cambio = {}) {
  const tbody = document.getElementById('cargaCambiosTbody');
  if (!tbody) return;
  const tr = document.createElement('tr');
  tr.innerHTML = `
    <td><select class="form-select form-select-sm carga-cambio-sale">${opcionesJugadoresCambio(cambio.jugador_sale_id)}</select></td>
    <td><select class="form-select form-select-sm carga-cambio-entra">${opcionesJugadoresCambio(cambio.jugador_entra_id)}</select></td>
    <td><input type="text" inputmode="numeric" pattern="^([0-9]{1,3}:[0-5][0-9]|[0-9]{1,3})$" class="form-control form-control-sm carga-cambio-minuto" value="${escaparHtml(cambio.minuto || '')}" placeholder="18:30"></td>
    <td class="text-center">
      <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('tr').remove();">
        <i class="bi bi-trash"></i>
      </button>
    </td>
  `;
  tbody.appendChild(tr);
  tr.querySelector('.carga-cambio-minuto')?.addEventListener('input', event => {
    formatearCampoTiempoEvento(event.target);
  });
}

function renderCargaCambios(cambios = []) {
  const tbody = document.getElementById('cargaCambiosTbody');
  if (!tbody) return;
  tbody.innerHTML = '';
  cambios.forEach(cambio => agregarFilaCambioCarga(cambio));
}

function recalcularCargaEquipoPartido() {
  const deudaAnterior = valorNumeroInput(document.getElementById('cargaDeudaAnterior').value);
  const aporte = valorNumeroInput(document.getElementById('cargaMontoAportado').value);
  let totalItems = 0;

  document.querySelectorAll('#cargaItemsTbody tr').forEach(tr => {
    const monto = valorNumeroInput(tr.querySelector('.carga-item-monto')?.value);
    const cantidad = valorNumeroInput(tr.querySelector('.carga-item-cantidad')?.value);
    const total = monto * cantidad;
    totalItems += total;
    const totalCell = tr.querySelector('.carga-item-total');
    if (totalCell) totalCell.textContent = formatoMonto(total);
  });

  const saldo = deudaAnterior + totalItems - aporte;
  document.getElementById('cargaTotalItems').value = formatoMonto(totalItems);
  document.getElementById('cargaSaldoFinal').value = formatoMonto(saldo);
}

async function abrirCargaEquipoPartido(partidoId, equipoId, boton = null) {
  try {
    cargaEquipoPartidoBotonActual = boton;
    const response = await fetch(`/partidos/${partidoId}/equipo/${equipoId}/carga`);
    const data = await response.json();
    if (!data.success) {
      mostrarAvisoApp(data.message || 'No se pudo preparar la carga', 'Carga del encuentro');
      return;
    }

    cargaEquipoPartidoActual = {
      partidoId,
      equipoId,
      equipoNombre: data.equipo.nombre,
      equipoRival: data.equipo.rival || '',
      numeroFecha: data.partido.numero_fecha || null,
      fechaCalendario: data.partido.fecha || null,
      estado: normalizarEstadoPartidoCliente(data.partido.estado || 'programado')
    };
    cargaItemsDisponibles = data.items || [];
    cargaJugadoresCambio = data.jugadores || [];
    cargaReglaTarjetasActual = data.reglaTarjetas || { acumula_amarillas: false };

    document.getElementById('cargaPartidoTitulo').textContent = `${data.equipo.nombre} - Fecha ${data.partido.numero_fecha || '-'}`;
    document.getElementById('cargaPartidoSubtitulo').textContent = `Partido #${data.partido.id_partido} · ${data.partido.fecha || '-'}`;
    document.getElementById('cargaDeudaAnterior').value = formatoMonto(data.deudaAnterior);
    document.getElementById('cargaMontoAportado').value = formatoMonto(data.montoAportado);
    document.getElementById('cargaItemsTbody').innerHTML = '';
    document.getElementById('cargaCambiosTbody').innerHTML = '';
    document.getElementById('cargaCambiosTabNav')?.classList.remove('d-none');
    mostrarEstadoCargaEquipo('');
    const buscadorCarga = document.getElementById('buscarCargaJugadores');
    if (buscadorCarga) buscadorCarga.value = '';

    renderCargaJugadores(data.jugadores || []);
    renderCargaCambios(data.cambios || []);
    bootstrap.Tab.getOrCreateInstance(document.querySelector('[data-bs-target="#cargaJugadoresTab"]')).show();

    if (data.itemsCargados && data.itemsCargados.length > 0) {
      data.itemsCargados.forEach(item => agregarFilaItemCarga(item));
    }

    actualizarAcumulacionesAmarillas();
    recalcularCargaEquipoPartido();
    bootstrap.Modal.getOrCreateInstance(document.getElementById('modalCargaEquipoPartido')).show();
  } catch (error) {
    console.error(error);
    mostrarAvisoApp('Error al abrir la carga del encuentro', 'Carga del encuentro');
  }
}

function leerEquiposEstadisticasCliente() {
  return Array.from(document.querySelectorAll('#estadisticasTbody tr[data-equipo-id]')).map(row => ({
    id_equipo: row.dataset.equipoId,
    nombre: row.dataset.nombre || '',
    icono: row.dataset.icono || '/images/default_team.png',
    nombre_grupo: row.dataset.grupoNombre || 'Sin grupo',
    pj: 0,
    pj_total: 0,
    pg: 0,
    pe: 0,
    pp: 0,
    gf: 0,
    gc: 0,
    puntos: 0
  }));
}

function recalcularEstadisticasCliente() {
  const tbody = document.getElementById('estadisticasTbody');
  if (!tbody) return;

  const equipos = leerEquiposEstadisticasCliente();
  if (!equipos.length) return;

  const mapa = new Map(equipos.map(equipo => [String(equipo.id_equipo), equipo]));

  document.querySelectorAll('td[data-equipo-a-id][data-equipo-b-id]').forEach(partido => {
    const equipoA = mapa.get(String(partido.dataset.equipoAId));
    const equipoB = mapa.get(String(partido.dataset.equipoBId));

    if (equipoA) equipoA.pj_total += 1;
    if (equipoB) equipoB.pj_total += 1;

    const estadoSelect = document.querySelector(`.estado-select[data-id="${partido.dataset.id}"]`);
    const estado = estadoSelect ? estadoSelect.value : partido.dataset.estado;
    if (estado !== 'finalizado') return;

    const golesA = Number.parseInt(partido.dataset.golesA || '0', 10) || 0;
    const golesB = Number.parseInt(partido.dataset.golesB || '0', 10) || 0;

    if (equipoA) {
      equipoA.pj += 1;
      equipoA.gf += golesA;
      equipoA.gc += golesB;
    }
    if (equipoB) {
      equipoB.pj += 1;
      equipoB.gf += golesB;
      equipoB.gc += golesA;
    }

    if (golesA > golesB) {
      if (equipoA) {
        equipoA.pg += 1;
        equipoA.puntos += 3;
      }
      if (equipoB) equipoB.pp += 1;
    } else if (golesB > golesA) {
      if (equipoB) {
        equipoB.pg += 1;
        equipoB.puntos += 3;
      }
      if (equipoA) equipoA.pp += 1;
    } else {
      if (equipoA) {
        equipoA.pe += 1;
        equipoA.puntos += 1;
      }
      if (equipoB) {
        equipoB.pe += 1;
        equipoB.puntos += 1;
      }
    }
  });

  equipos.sort((a, b) => {
    if (b.puntos !== a.puntos) return b.puntos - a.puntos;
    const difA = a.gf - a.gc;
    const difB = b.gf - b.gc;
    if (difB !== difA) return difB - difA;
    if (b.gf !== a.gf) return b.gf - a.gf;
    return a.nombre.localeCompare(b.nombre);
  });

  tbody.innerHTML = equipos.map((item, index) => `
    <tr data-equipo-id="${escaparHtml(item.id_equipo)}"
        data-nombre="${escaparHtml(item.nombre)}"
        data-icono="${escaparHtml(item.icono)}"
        data-grupo-nombre="${escaparHtml(item.nombre_grupo)}">
      <td>
        <div class="estadisticas-equipo">
          <span class="estadisticas-pos">${index + 1}</span>
          <img src="${escaparHtml(item.icono)}" alt="" class="estadisticas-icono">
          <strong class="estadisticas-nombre" title="${escaparHtml(item.nombre)}">${escaparHtml(item.nombre)}</strong>
        </div>
      </td>
      <td><small>${escaparHtml(item.nombre_grupo)}</small></td>
      <td>${item.pj}/${item.pj_total}</td>
      <td class="estadisticas-col-detalle">${item.pg}</td>
      <td class="estadisticas-col-detalle">${item.pe}</td>
      <td class="estadisticas-col-detalle">${item.pp}</td>
      <td class="estadisticas-col-detalle">${item.gf}</td>
      <td class="estadisticas-col-detalle">${item.gc}</td>
      <td>${item.gf - item.gc}</td>
      <td><strong>${item.puntos}</strong></td>
    </tr>
  `).join('');
}

async function abrirCargaEquipoLibre(torneoId, numeroFecha, equipoId, boton = null) {
  try {
    cargaEquipoPartidoBotonActual = boton;
    const response = await fetch(`/partidos/libre/torneos/${torneoId}/fecha/${numeroFecha}/equipo/${equipoId}/carga`);
    const data = await response.json();
    if (!data.success) {
      mostrarAvisoApp(data.message || 'No se pudo preparar la carga de fecha libre', 'Carga de fecha libre');
      return;
    }

    cargaEquipoPartidoActual = {
      modo: 'libre',
      torneoId,
      numeroFecha,
      equipoId,
      equipoNombre: data.equipo.nombre,
      fechaCalendario: data.partido.fecha || null
    };
    cargaItemsDisponibles = data.items || [];
    cargaJugadoresCambio = [];
    cargaReglaTarjetasActual = { acumula_amarillas: false };

    document.getElementById('cargaPartidoTitulo').textContent = `${data.equipo.nombre} - Fecha ${data.partido.numero_fecha || '-'} libre`;
    document.getElementById('cargaPartidoSubtitulo').textContent = 'Equipo libre sin encuentro programado';
    document.getElementById('cargaDeudaAnterior').value = formatoMonto(data.deudaAnterior);
    document.getElementById('cargaMontoAportado').value = formatoMonto(data.montoAportado);
    document.getElementById('cargaItemsTbody').innerHTML = '';
    document.getElementById('cargaCambiosTbody').innerHTML = '';
    document.getElementById('cargaCambiosTabNav')?.classList.add('d-none');
    mostrarEstadoCargaEquipo('');

    renderCargaJugadores([]);
    renderCargaCambios([]);
    bootstrap.Tab.getOrCreateInstance(document.querySelector('[data-bs-target="#cargaItemsTab"]')).show();

    if (data.itemsCargados && data.itemsCargados.length > 0) {
      data.itemsCargados.forEach(item => agregarFilaItemCarga(item));
    }

    recalcularCargaEquipoPartido();
    bootstrap.Modal.getOrCreateInstance(document.getElementById('modalCargaEquipoPartido')).show();
  } catch (error) {
    console.error(error);
    mostrarAvisoApp('Error al abrir la carga de fecha libre', 'Carga de fecha libre');
  }
}

function marcarBotonCargaRegistrada() {
  if (!cargaEquipoPartidoBotonActual) return;
  cargaEquipoPartidoBotonActual.classList.remove('btn-warning');
  cargaEquipoPartidoBotonActual.classList.add('btn-success');
  cargaEquipoPartidoBotonActual.title = 'Carga registrada';
}

function mostrarEstadoCargaEquipo(mensaje = '', tipo = 'muted') {
  const estado = document.getElementById('cargaEquipoEstadoGuardado');
  if (!estado) return;

  estado.textContent = mensaje;
  estado.className = `me-auto small fw-bold text-${tipo}`;
}

function sincronizarOriginalesCargaJugadores() {
  document.querySelectorAll('#cargaJugadoresTbody tr[data-jugador-id]').forEach(tr => {
    const golesActual = Number.parseInt(tr.querySelector('.carga-jugador-goles')?.value || '0', 10) || 0;
    tr.dataset.golesOriginal = String(golesActual);
  });
}

function obtenerNombreJugadorCargaPorId(jugadorId) {
  const jugador = (cargaJugadoresCambio || []).find(item => String(item.id_jugador) === String(jugadorId));
  return {
    nombre: jugador?.nombre || '',
    apellido: jugador?.apellido || '',
    completo: [jugador?.nombre, jugador?.apellido].filter(Boolean).join(' '),
    numero_camiseta: jugador?.numero_camiseta || ''
  };
}

function actualizarDashboardEstadisticasDesdeCarga(jugadoresPayload = [], cambiosPayload = [], marcador = null) {
  if (!cargaEquipoPartidoActual?.partidoId || !Array.isArray(dashboardPartidosEstadisticas)) return;

  const partidoId = String(cargaEquipoPartidoActual.partidoId);
  const equipoId = String(cargaEquipoPartidoActual.equipoId);
  const partido = dashboardPartidosEstadisticas.find(item => String(item.id_partido) === partidoId);
  if (!partido) return;

  partido.estadisticas = (partido.estadisticas || []).filter(item => String(item.id_equipo || '') !== equipoId);
  jugadoresPayload.forEach(jugador => {
    const goles = Number(jugador.goles || 0);
    const amarillas = Number(jugador.tarjetas_amarillas || 0);
    const rojas = Number(jugador.tarjetas_rojas || 0);
    if (goles <= 0 && amarillas <= 0 && rojas <= 0) return;

    const nombre = obtenerNombreJugadorCargaPorId(jugador.id_jugador);
    partido.estadisticas.push({
      id_jugador: jugador.id_jugador,
      id_equipo: cargaEquipoPartidoActual.equipoId,
      nombre: nombre.nombre,
      apellido: nombre.apellido,
      goles,
      tarjetas_amarillas: amarillas,
      tarjetas_rojas: rojas
    });
  });

  partido.cambios = (partido.cambios || []).filter(item => String(item.equipo_id || '') !== equipoId);
  cambiosPayload.forEach(cambio => {
    const sale = obtenerNombreJugadorCargaPorId(cambio.jugador_sale_id);
    const entra = obtenerNombreJugadorCargaPorId(cambio.jugador_entra_id);
    partido.cambios.push({
      equipo_id: cargaEquipoPartidoActual.equipoId,
      jugador_sale_id: cambio.jugador_sale_id,
      jugador_entra_id: cambio.jugador_entra_id,
      jugador_sale_nombre: sale.completo,
      jugador_entra_nombre: entra.completo,
      jugador_sale_numero_camiseta: sale.numero_camiseta,
      jugador_entra_numero_camiseta: entra.numero_camiseta,
      minuto: cambio.minuto || ''
    });
  });

  if (marcador) {
    partido.goles_a = marcador.goles_a ?? partido.goles_a;
    partido.goles_b = marcador.goles_b ?? partido.goles_b;
  }
}

function aplicarSancionesEnListaJugadores(jugadoresSancionados = []) {
  jugadoresSancionados.forEach(jugador => {
    const row = document.querySelector(`#jugadores tbody tr[data-jugador-id="${jugador.id_jugador}"]`);
    if (!row) return;

    row.classList.remove('table-secondary');
    row.classList.add('table-warning');

    const estadoInput = row.querySelector('.jugador-estado-vinculo-input');
    if (estadoInput) estadoInput.checked = false;

    const observacionesCell = row.querySelector('.jugador-observaciones-cell');
    if (observacionesCell) {
      observacionesCell.textContent = jugador.observaciones || '';
    }

    const equipoEstado = row.querySelector('.jugador-equipo-estado');
    if (equipoEstado) {
      equipoEstado.classList.remove('text-primary', 'text-muted');
      equipoEstado.classList.add('text-warning');
      if (!/\(Inactivo\)/.test(equipoEstado.textContent)) {
        equipoEstado.textContent = `${equipoEstado.textContent.trim()} (Inactivo)`;
      }
    }
  });
}

function actualizarFinanzasDesdeCarga(resumen = {}) {
  if (!cargaEquipoPartidoActual) return;

  const equipoId = String(cargaEquipoPartidoActual.equipoId);
  const equipo = finanzasResumen.find(item => String(item.id_equipo) === equipoId);
  if (!equipo) return;

  const deudaInicial = Number(resumen.deudaAnterior || 0);
  const totalItems = Number(resumen.totalItems || 0);
  const entrega = Number(resumen.montoAportado || 0);
  const saldo = Number(resumen.saldo || 0);
  const esLibre = cargaEquipoPartidoActual.modo === 'libre';
  const concepto = esLibre
    ? `Fecha libre #${cargaEquipoPartidoActual.numeroFecha} - ${cargaEquipoPartidoActual.equipoNombre}`
    : `Encuentro #${cargaEquipoPartidoActual.partidoId} - ${cargaEquipoPartidoActual.equipoNombre}`;
  const conceptoDisplay = !esLibre && cargaEquipoPartidoActual.equipoRival
    ? `${concepto} vs ${cargaEquipoPartidoActual.equipoRival}`
    : concepto;

  equipo.saldo_actual = saldo;
  equipo.adeuda = saldo > 0;
  equipo.total_items = (equipo.movimientos || []).reduce((total, mov) => total + Number(mov.total_items || 0), 0);
  equipo.total_entregado = (equipo.movimientos || []).reduce((total, mov) => total + Number(mov.entrega || 0), 0);

  const movimientos = equipo.movimientos || [];
  const existente = movimientos.find(mov => String(mov.concepto || '') === concepto);
  const movimiento = {
    id_finanza: existente?.id_finanza || `tmp-${Date.now()}`,
    concepto,
    tipo: esLibre ? 'fecha_libre' : 'partido',
    fecha_registro: new Date().toISOString().slice(0, 10),
    numero_fecha: cargaEquipoPartidoActual.numeroFecha || null,
    fecha_calendario: cargaEquipoPartidoActual.fechaCalendario || null,
    nombre_grupo: equipo.nombre_grupo || null,
    nombre_grupo_display: equipo.nombre_grupo || null,
    concepto_display: conceptoDisplay,
    deuda_inicial: deudaInicial,
    total_items: totalItems,
    entrega,
    saldo,
    items: obtenerCargaItemsPayload().map(item => ({
      nombre: item.nombre,
      cantidad: Number(item.cantidad || 0),
      monto: Number(item.monto || 0),
      total: Number(item.monto || 0) * Number(item.cantidad || 0),
      observaciones: item.observaciones || ''
    }))
  };

  if (existente) {
    Object.assign(existente, movimiento);
  } else {
    movimientos.push(movimiento);
    equipo.movimientos = movimientos;
  }

  equipo.total_items = movimientos.reduce((total, mov) => total + Number(mov.total_items || 0), 0);
  equipo.total_entregado = movimientos.reduce((total, mov) => total + Number(mov.entrega || 0), 0);

  const row = document.querySelector(`#finanzas tbody tr[data-finanzas-equipo-id="${equipoId}"]`);
  if (!row) return;

  const estadoCell = row.querySelector('.finanzas-estado-cell');
  if (estadoCell) {
    estadoCell.innerHTML = equipo.adeuda
      ? '<span class="fw-bold text-danger" title="Equipo con deuda">‼️‼️</span>'
      : '<span class="badge text-bg-success">Al dia</span>';
  }

  const saldoCell = row.querySelector('.finanzas-saldo-cell');
  if (saldoCell) {
    saldoCell.textContent = formatoMontoFinanzas(saldo);
    saldoCell.classList.toggle('text-danger', equipo.adeuda);
    saldoCell.classList.toggle('text-dark', !equipo.adeuda);
  }
}

function obtenerCargaJugadoresPayload() {
  return Array.from(document.querySelectorAll('#cargaJugadoresTbody tr[data-jugador-id]')).map(trGoles => {
    const jugadorId = trGoles.dataset.jugadorId;
    const trTarjetas = Array.from(document.querySelectorAll('#cargaTarjetasTbody tr[data-jugador-id]'))
      .find(tr => String(tr.dataset.jugadorId) === String(jugadorId));
    return {
      id_jugador: jugadorId,
      goles: trGoles.querySelector('.carga-jugador-goles')?.value || 0,
      goles_minutos: obtenerMinutosEventoFila(trGoles, 'gol'),
      tarjetas_amarillas: trTarjetas?.querySelector('.carga-jugador-amarillas')?.value || 0,
      amarillas_minutos: trTarjetas ? obtenerMinutosEventoFila(trTarjetas, 'amarilla') : [],
      tarjetas_rojas: trTarjetas?.querySelector('.carga-jugador-rojas')?.value || 0,
      rojas_minutos: trTarjetas ? obtenerMinutosEventoFila(trTarjetas, 'roja') : [],
      partidos_suspendidos: trTarjetas?.querySelector('.carga-jugador-suspendidos')?.value || 0,
      suspension_observaciones: trTarjetas?.querySelector('.carga-jugador-observaciones')?.value || '',
      accion_acumulacion: trTarjetas?.dataset.accionAcumulacion || ''
    };
  });
}

function obtenerCargaCambiosPayload() {
  return Array.from(document.querySelectorAll('#cargaCambiosTbody tr')).map(tr => ({
    jugador_sale_id: tr.querySelector('.carga-cambio-sale')?.value || '',
    jugador_entra_id: tr.querySelector('.carga-cambio-entra')?.value || '',
    minuto: tr.querySelector('.carga-cambio-minuto')?.value || ''
  })).filter(cambio => cambio.jugador_sale_id || cambio.jugador_entra_id || cambio.minuto);
}

function obtenerCargaItemsPayload() {
  return Array.from(document.querySelectorAll('#cargaItemsTbody tr')).map(tr => ({
    nombre: tr.querySelector('.carga-item-nombre')?.value || '',
    monto: valorNumeroInput(tr.querySelector('.carga-item-monto')?.value || 0),
    cantidad: tr.querySelector('.carga-item-cantidad')?.value || 0,
    observaciones: tr.querySelector('.carga-item-observaciones')?.value || ''
  })).filter(item => item.nombre);
}

function cargaTieneGolesJugadoresModificados() {
  return Array.from(document.querySelectorAll('#cargaJugadoresTbody tr[data-jugador-id]')).some(tr => {
    const golesOriginal = Number.parseInt(tr.dataset.golesOriginal || '0', 10) || 0;
    const golesActual = Number.parseInt(tr.querySelector('.carga-jugador-goles')?.value || '0', 10) || 0;
    return golesActual > 0 && golesActual !== golesOriginal;
  });
}

async function guardarCargaEquipoPartido() {
  if (!cargaEquipoPartidoActual) return;
  const botonGuardar = document.getElementById('btnGuardarCargaEquipoPartido');
  const htmlBotonOriginal = botonGuardar?.innerHTML || '';
  if (botonGuardar?.disabled) return;

  if (botonGuardar) {
    botonGuardar.disabled = true;
    botonGuardar.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> Guardando';
  }
  mostrarEstadoCargaEquipo('Guardando...', 'muted');

  actualizarAcumulacionesAmarillas();
  recalcularCargaEquipoPartido();
  await resolverDecisionesAcumulacion();

  try {
    const jugadoresPayload = obtenerCargaJugadoresPayload();
    const itemsPayload = obtenerCargaItemsPayload();
    const cambiosPayload = obtenerCargaCambiosPayload();
    const { partidoId, equipoId, modo, torneoId, numeroFecha } = cargaEquipoPartidoActual;
    const url = modo === 'libre'
      ? `/partidos/libre/torneos/${torneoId}/fecha/${numeroFecha}/equipo/${equipoId}/carga`
      : `/partidos/${partidoId}/equipo/${equipoId}/carga`;
    let estadoPartido = null;
    if (modo !== 'libre' && cargaTieneGolesJugadoresModificados()) {
      const marcadorCell = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a]`);
      const estadoActual = normalizarEstadoPartidoCliente(
        cargaEquipoPartidoActual.estado || marcadorCell?.dataset.estado || 'programado'
      );
      if (!['en_curso', 'finalizado'].includes(estadoActual)) {
        estadoPartido = await elegirEstadoMarcador(
          'El encuentro esta pendiente/programado. Como queres dejarlo al registrar la carga?',
          'Estado del encuentro'
        );
        if (!estadoPartido) return;
      }
    }
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        jugadores: jugadoresPayload,
        items: itemsPayload,
        cambios: cambiosPayload,
        monto_aportado: valorNumeroInput(document.getElementById('cargaMontoAportado').value),
        estado_partido: estadoPartido || undefined
      })
    });

    const data = await response.json();
    if (!data.success) {
      mostrarAvisoApp(data.message || 'No se pudo guardar la carga', 'Carga del encuentro');
      mostrarEstadoCargaEquipo('No se pudo guardar.', 'danger');
      return;
    }

    marcarBotonCargaRegistrada();
    sincronizarOriginalesCargaJugadores();
    aplicarSancionesEnListaJugadores(data.jugadoresSancionados || []);
    if (data.marcador && partidoId) {
      actualizarMarcadorPartidoEnVista(
        partidoId,
        data.marcador.goles_a,
        data.marcador.goles_b,
        data.marcador.estado
      );
      cargaEquipoPartidoActual.estado = normalizarEstadoPartidoCliente(data.marcador.estado);
    }
    actualizarDashboardEstadisticasDesdeCarga(jugadoresPayload, cambiosPayload, data.marcador || null);
    actualizarFinanzasDesdeCarga(data.resumen || {});
    await sincronizarFinanzasDesdeServidor();
    refrescarDashboardEnCurso();
    marcarDashboardInicioDesactualizado();
    mostrarEstadoCargaEquipo('Guardado. Puede seguir cargando o cerrar.', 'success');
  } catch (error) {
    console.error(error);
    mostrarAvisoApp('Error al guardar la carga del encuentro', 'Carga del encuentro');
    mostrarEstadoCargaEquipo('Error al guardar.', 'danger');
  } finally {
    if (botonGuardar) {
      botonGuardar.disabled = false;
      botonGuardar.innerHTML = htmlBotonOriginal || '<i class="bi bi-save"></i> Registrar carga';
    }
  }
}

async function confirmarToggleEquipo(input) {
  const form = input.form;
  const confirmarInput = form.querySelector('input[name="confirmar_desactivacion"]');
  const partidosPendientes = Number(input.dataset.partidosPendientes || 0);

  if (!input.checked && partidosPendientes > 0) {
    const ok = await confirmarApp(
      'Este equipo tiene partidos en curso, pendientes o en proceso. Si lo desactiva, los encuentros quedarán disparejos para el equipo contrario en cada fecha.',
      'Desactivar equipo',
      {
        aceptar: 'Sí, desactivar',
        cancelar: 'Cancelar',
        destacar: true
      }
    );

    if (!ok) {
      input.checked = true;
      return;
    }

    confirmarInput.value = '1';
  }

  form.submit();
}

