            <label for="itemMonto" class="form-label text-dark fw-bold">Monto <span class="text-danger">*</span></label>
            <input type="number" class="form-control" id="itemMonto" name="monto" min="0" step="0.01" inputmode="decimal" required>
            <div class="form-text">Solo valores positivos.</div>
