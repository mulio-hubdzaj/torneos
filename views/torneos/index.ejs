              <% if (j.fecha_nacimiento_fmt) { %>
                <% const partesFechaNacimiento = String(j.fecha_nacimiento_fmt).slice(0, 10).split('-'); %>
                <%= partesFechaNacimiento.length === 3 ? `${partesFechaNacimiento[2]}/${partesFechaNacimiento[1]}/${partesFechaNacimiento[0]}` : j.fecha_nacimiento_fmt %>
