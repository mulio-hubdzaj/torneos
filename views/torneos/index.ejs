        <% } %>
        <li class="nav-item">
          <a class="nav-link<%= navActiva('partidos') %>" id="partidos-tab" data-bs-toggle="tab" href="#partidos" role="tab">Fixture</a>
        </li>
        <li class="nav-item">
          <a class="nav-link<%= navActiva('estadisticas') %>" id="estadisticas-tab" data-bs-toggle="tab" href="#estadisticas" role="tab">Estadísticas</a>
        </li>
        <% if (!esVistaPublica && rol_id != 1) { %>
          <li class="nav-item">
            <a class="nav-link<%= navActiva('finanzas') %>" id="finanzas-tab" data-bs-toggle="tab" href="#finanzas" role="tab">Finanzas</a>
          </li>
        <% } %>
        <% if (!esVistaPublica && (rol_id == 3 || rol_id == 99)) { %>
          <li class="nav-item">
            <a class="nav-link<%= navActiva('usuarios') %>" id="usuarios-tab" data-bs-toggle="tab" href="#usuarios" role="tab">Usuarios</a>
          </li>
        <% } %>
        <% if (!esVistaPublica && rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link<%= navActiva('auditoria') %>" id="auditoria-tab" data-bs-toggle="tab" href="#auditoria" role="tab">Auditoría</a>
          </li>
          <li class="nav-item">
            <a class="nav-link<%= navActiva('usoapp') %>" id="usoapp-tab" data-bs-toggle="tab" href="#usoapp" role="tab">Uso app</a>
