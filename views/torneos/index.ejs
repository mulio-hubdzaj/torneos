      <form id="formItem" action="/items" method="POST">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="itemModalTitulo">Nuevo item</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="itemId" name="id_item">
          <input type="hidden" id="itemTorneoId" name="id_torneo" value="<%= torneo.id_torneo %>">
