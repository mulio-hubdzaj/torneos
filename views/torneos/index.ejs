  <!-- pestaña Partidos -->
  <div class="tab-pane fade<%= paneActiva('partidos') %>" id="partidos">
  <div class="card-partidos p-3 shadow">
    <div class="d-flex justify-content-between align-items-center mb-3 fixture-header">
      <h3 class="mb-0">Fixture</h3>
      <% if (rol_id == 3 || rol_id == 99) { %>
        <div class="btn-group btn-group-sm" role="group">
          <% const primeraFechaVaciaPartidos = (partidosPorFecha || []).find(fecha => !((fecha.partidos || []).length)); %>
          <% const proximaFechaPartidos = primeraFechaVaciaPartidos
            ? Number(primeraFechaVaciaPartidos.numero_fecha || 1)
            : (((partidosPorFecha || []).reduce((max, fecha) => Math.max(max, Number(fecha.numero_fecha || 0)), 0) || 0) + 1); %>
          <button type="button"
                  class="btn btn-success fw-bold partidos-admin-only"
                  onclick="abrirModalCruceManual(<%= proximaFechaPartidos %>, '<%= grupoSeleccionadoId || '' %>')"
                  title="Agregar fecha adicional">
            <i class="bi bi-calendar-plus"></i> Agregar fecha
          </button>
          <button type="button" class="btn btn-outline-light" id="btnVistaPublicaPartidos" title="Vista usuario">
            <i class="bi bi-eye"></i> Vista usuario
          </button>
          <button type="button" class="btn btn-outline-warning d-none" id="btnVistaAdminPartidos" title="Habilitar administracion">
            <i class="bi bi-tools"></i> Habilitar admin
          </button>
        </div>
      <% } %>
    </div>
    <div class="row g-2 align-items-end mb-3">
      <div class="col-md-4">
        <label class="form-label text-dark fw-bold mb-1">Filtrar por grupo</label>
        <select class="form-select form-select-sm" onchange="window.location = '<%= (esVistaPublica ? '/publico/torneo/' : '/torneos/gestionar/') + torneo.id_torneo %>' + (this.value ? '?grupo_id=' + this.value + '&tab=partidos' : '?tab=partidos') + '#partidos'">
          <option value="">Vista general</option>
          <% ((typeof gruposFixture !== 'undefined' && gruposFixture) || grupos || []).forEach(grupo => { %>
            <option value="<%= grupo.id_grupo %>" <%= String(grupoSeleccionadoId || '') === String(grupo.id_grupo) ? 'selected' : '' %>>
              <%= grupo.nombre_grupo %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <% if (torneo.portada) { %>
      <div class="torneo-portada mb-3">
        <img src="<%= torneo.portada %>" alt="Portada de <%= torneo.nombre_torneo %>" loading="lazy" decoding="async" onerror="this.closest('.torneo-portada')?.remove();">
      </div>
      <% } %>

      <% if (partidosPorFecha && partidosPorFecha.length > 0) { %>
        <%
          const fechaSolicitadaFixture = typeof fechaSeleccionada !== 'undefined' && fechaSeleccionada ? String(fechaSeleccionada) : '';
          const fechaActivaFixture =
            (fechaSolicitadaFixture && (partidosPorFecha.find(f => String(f.numero_fecha) === fechaSolicitadaFixture) || {}).numero_fecha) ||
            (partidosPorFecha.find(f =>
              (f.partidos || []).some(p => String(p.estado || '').trim().toLowerCase() !== 'finalizado')
            ) || partidosPorFecha[0] || {}).numero_fecha;
          const fechaActivaObjetoFixture = partidosPorFecha.find(f => String(f.numero_fecha) === String(fechaActivaFixture)) || partidosPorFecha[0] || {};
          const fechaActivaIndexFixture = Math.max(0, partidosPorFecha.findIndex(f => String(f.numero_fecha) === String(fechaActivaFixture)));
          const fechaActivaTextoFixture = fechaActivaObjetoFixture.fecha_general
            ? `Fecha ${fechaActivaObjetoFixture.numero_fecha} - ${String(fechaActivaObjetoFixture.fecha_general).slice(0, 10).split('-').reverse().join('/')}`
            : `Fecha ${fechaActivaObjetoFixture.numero_fecha || '-'}`;
        %>
        <div class="fixture-fecha-navegador mb-3" id="fechasTab" role="tablist" data-fecha-activa-index="<%= fechaActivaIndexFixture %>">
          <button type="button"
                  class="btn btn-outline-primary fixture-fecha-nav-btn"
                  id="btnFechaAnterior"
                  title="Fecha anterior"
                  aria-label="Fecha anterior"
                  <%= fechaActivaIndexFixture <= 0 ? 'disabled' : '' %>>
            <i class="bi bi-chevron-left"></i>
          </button>
          <button class="btn fixture-fecha-tab active fixture-fecha-actual"
                  id="fechaActualTab"
                  data-bs-toggle="pill"
                  data-bs-target="#fecha-<%= fechaActivaFixture %>"
                  type="button"
                  role="tab"
                  aria-controls="fecha-<%= fechaActivaFixture %>"
                  aria-selected="true">
            <%= fechaActivaTextoFixture %>
          </button>
          <button type="button"
                  class="btn btn-outline-primary fixture-fecha-nav-btn"
                  id="btnFechaSiguiente"
                  title="Fecha siguiente"
                  aria-label="Fecha siguiente"
                  <%= fechaActivaIndexFixture >= partidosPorFecha.length - 1 ? 'disabled' : '' %>>
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
        <ul class="nav nav-pills mb-3 d-none" id="fechasTabOculto" role="tablist">
          <% partidosPorFecha.forEach((fecha, index) => { %>
            <% const fechaEsActiva = String(fecha.numero_fecha) === String(fechaActivaFixture); %>
            <li class="nav-item" role="presentation">
              <button class="nav-link fixture-fecha-tab <%= fechaEsActiva ? 'active' : '' %>"
                      id="fecha-<%= fecha.numero_fecha %>-tab"
                      data-bs-toggle="pill"
                      data-bs-target="#fecha-<%= fecha.numero_fecha %>"
                      type="button"
                      role="tab"
                      aria-controls="fecha-<%= fecha.numero_fecha %>"
                      aria-selected="<%= fechaEsActiva ? 'true' : 'false' %>">
                Fecha <%= fecha.numero_fecha %>
                <% if (fecha.fecha_general) { %>
                  <% const fechaGeneralVisible = String(fecha.fecha_general).slice(0, 10).split('-').reverse().join('/'); %>
                  - <%= fechaGeneralVisible %>
                <% } %>
              </button>
            </li>
          <% }) %>
        </ul>

        <div class="tab-content">
          <% partidosPorFecha.forEach((fecha, index) => { %>
            <% const fechaEsActiva = String(fecha.numero_fecha) === String(fechaActivaFixture); %>
            <div class="tab-pane fade <%= fechaEsActiva ? 'show active' : '' %>"
                 id="fecha-<%= fecha.numero_fecha %>"
                 role="tabpanel"
                 aria-labelledby="fecha-<%= fecha.numero_fecha %>-tab">
              <div class="fixture-fecha-panel">

              <!-- Formulario para asignar fecha y horarios comunes -->
              <form id="formFechaComun-<%= fecha.numero_fecha %>" class="mb-4 partidos-admin-only">
                <input type="hidden" name="numero_fecha" value="<%= fecha.numero_fecha %>">
                <input type="hidden" name="torneo_id" value="<%= torneo.id_torneo %>">
                <% if (grupoSeleccionadoId) { %>
                  <input type="hidden" name="grupo_id" value="<%= grupoSeleccionadoId %>">
                <% } %>
                <div class="row g-3 align-items-end">
                  <div class="col-md-3">
                    <label class="form-label fw-bold text-dark">📅 Fecha común</label>
                    <input type="date" class="form-control" id="fechaComun-<%= fecha.numero_fecha %>" name="fecha_comun" value="<%= fecha.fecha_general ? fecha.fecha_general : '' %>">
                  </div>
                  <div class="col-md-2">
                    <label class="form-label fw-bold text-dark">⏰ Hora inicial</label>
                    <input type="time" class="form-control" id="horaInicial-<%= fecha.numero_fecha %>" name="hora_inicial" placeholder="14:00">
                  </div>
                  <div class="col-md-2">
                    <label class="form-label fw-bold text-dark">⏱️ Intervalo (min)</label>
                    <input type="number" class="form-control" id="intervalo-<%= fecha.numero_fecha %>" name="intervalo_minutos" placeholder="20" min="5" max="120">
                  </div>
                  <div class="col-md-3">
                    <button type="button"
                            class="btn btn-primary w-100 mb-2 abrir-cruce-manual-btn"
                            data-numero-fecha="<%= fecha.numero_fecha %>"
                            data-grupo-id="<%= fecha.partidos && fecha.partidos.length > 0 ? fecha.partidos[0].id_grupo || '' : '' %>">
                      <i class="bi bi-diagram-3"></i> Cruce manual
                    </button>
                    <button type="button" class="btn btn-success w-100 guardar-horarios-btn" data-numero-fecha="<%= fecha.numero_fecha %>" disabled>
                      <i class="bi bi-check-circle"></i> Guardar cambios
                    </button>
                  </div>
                  <div class="col-md-2">
                    <small class="fixture-ayuda-horarios">
                      Asigna fecha y horarios espaciados a los encuentros visibles de esta fecha
                    </small>
                  </div>
                </div>
              </form>

              <form action="/partidos/torneos/<%= torneo.id_torneo %>/fecha/<%= fecha.numero_fecha %>/eliminar"
                    method="POST"
                    class="mb-3 partidos-admin-only form-confirmar-app"
                    data-confirm-title="Eliminar fecha"
                    data-confirm-message="Eliminar la fecha <%= fecha.numero_fecha %>. Solo se permitira si no tiene encuentros jugados ni cargas registradas."
                    data-confirm-accept="Si, eliminar fecha"
                    data-confirm-cancel="Cancelar">
                <% if (grupoSeleccionadoId) { %>
                  <input type="hidden" name="id_grupo" value="<%= grupoSeleccionadoId %>">
                <% } %>
                <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&tab=partidos' : '?tab=partidos' %>#partidos">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                  <i class="bi bi-calendar-x"></i> Eliminar fecha
                </button>
              </form>

              <% if (false) { %>
                  <button type="button"
                          class="btn btn-outline-danger btn-sm mb-3 partidos-admin-only"
                          disabled
                          title="Solo se puede eliminar una fecha vacia">
                    <i class="bi bi-calendar-x"></i> Eliminar fecha
                  </button>
              <% } else if (false) { %>
                  <form action="/partidos/torneos/<%= torneo.id_torneo %>/fecha/<%= fecha.numero_fecha %>/eliminar"
                        method="POST"
                        class="mb-3 partidos-admin-only form-confirmar-app"
                        data-confirm-title="Eliminar fecha vacia"
                        data-confirm-message="¿Eliminar todos los encuentros de la fecha <%= fecha.numero_fecha %>?"
                        data-confirm-accept="Sí, eliminar fecha"
                        data-confirm-cancel="Cancelar">
                    <% if (grupoSeleccionadoId) { %>
                      <input type="hidden" name="id_grupo" value="<%= grupoSeleccionadoId %>">
                    <% } %>
                    <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&tab=partidos' : '?tab=partidos' %>#partidos">
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                      <i class="bi bi-calendar-x"></i> Eliminar fecha
                    </button>
                  </form>
              <% } %>

              <% if (fecha.equipos_libres && fecha.equipos_libres.length > 0) { %>
                <div class="alert alert-warning py-2 mb-3">
                  <strong>Equipo(s) libre(s):</strong>
                  <% fecha.equipos_libres.forEach((libre, indexLibre) => { %>
                    <span class="badge bg-secondary me-1 d-inline-flex align-items-center gap-1">
                      <img src="<%= libre.icono || '/images/default_team.png' %>" alt="" style="width: 18px; height: 18px; object-fit: contain;">
                      <span><%= libre.nombre_grupo %>: <%= libre.nombre_equipo %></span>
                      <button type="button"
                              class="btn btn-sm py-0 px-1 partidos-admin-only <%= libre.carga_registrada ? 'btn-success' : 'btn-warning' %>"
                              title="<%= libre.carga_registrada ? 'Carga registrada' : 'Carga pendiente' %>"
                              onclick="abrirCargaEquipoLibre(<%= torneo.id_torneo %>, <%= fecha.numero_fecha %>, <%= libre.id_equipo %>, this)">
                        <i class="bi bi-pencil"></i>
                      </button>
                    </span>
                  <% }) %>
                </div>
              <% } %>

              <!-- Tabla de partidos más ancha -->
              <div class="table-responsive" style="overflow-x: auto;">
                <table class="table table-hover align-middle table-sm fixture-partidos-table" style="font-size: 0.85rem;">
                  <thead class="table-dark">
                    <tr>
                      <th class="partidos-admin-only fixture-docs-col">Docs</th>
                      <th class="fixture-equipo-col">Equipo A</th>
                      <th class="fixture-marcador-col">Marcador</th>
                      <th class="fixture-equipo-col">Equipo B</th>
                      <th class="fixture-grupo-col fixture-web-col">Grupo</th>
                      <th class="fixture-fecha-col fixture-web-col">Fecha</th>
                      <th class="fixture-hora-col fixture-web-col">Hora</th>
                      <th class="fixture-estado-col">Estado</th>
                      <th class="partidos-admin-only fixture-acciones-col">Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!fecha.partidos || fecha.partidos.length === 0) { %>
                      <tr>
                        <td colspan="9" class="text-center text-muted py-3">
                          Fecha sin encuentros programados. Use Cruce manual para agregar partidos en esta fecha.
                        </td>
                      </tr>
                    <% } %>
                    <% fecha.partidos.forEach(partido => { %>
                      <%
                        const estadoPartidoValor = String(partido.estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_');
                        const estadoPartidoTexto = estadoPartidoValor === 'en_curso' ? 'En curso' : (estadoPartidoValor.charAt(0).toUpperCase() + estadoPartidoValor.slice(1));
                        const estadoPartidoBadge = estadoPartidoValor === 'en_curso' ? 'estado-badge-en-curso' : (estadoPartidoValor === 'finalizado' ? 'text-bg-success' : (estadoPartidoValor === 'suspendido' ? 'text-bg-secondary' : 'text-bg-light'));
                        const grupoPartidoTexto = `${partido.nombre_grupo_display || partido.nombre_grupo || 'Sin grupo'}${(partido.observaciones === 'Ida' || partido.observaciones === 'Vuelta') && !String(partido.nombre_grupo_display || '').includes(partido.observaciones) ? ' - ' + partido.observaciones : ''}`;
                        const mostrarMarcadorPublico = estadoPartidoValor === 'finalizado' || estadoPartidoValor === 'en_curso';
                      %>
                      <tr class="<%= partido.tiene_equipo_inhabilitado ? 'table-secondary partido-inhabilitado' : '' %>" data-partido-row="<%= partido.id_partido %>">
                        <td class="fixture-public-card-cell partidos-public-only" colspan="9">
                          <article class="fixture-public-card fixture-public-estado-<%= estadoPartidoValor %>" data-public-partido-card="<%= partido.id_partido %>">
                            <div class="fixture-public-main">
                              <div class="fixture-public-team fixture-public-team-a">
                                <img src="<%= partido.icono_equipo_a || '/images/default_team.png' %>" alt="" class="fixture-public-icon">
                                <strong title="<%= partido.nombre_equipo_a || 'Equipo A' %>"><%= partido.nombre_equipo_a || 'Equipo A' %></strong>
                                <% if (partido.estado_equipo_a === false) { %>
                                  <span class="fixture-public-team-note">inhabilitada</span>
                                <% } %>
                              </div>
                              <div class="fixture-public-versus">
                                <span class="fixture-public-score <%= mostrarMarcadorPublico ? '' : 'd-none' %>"><%= partido.goles_a ?? 0 %> - <%= partido.goles_b ?? 0 %></span>
                                <span class="fixture-public-vs <%= mostrarMarcadorPublico ? 'd-none' : '' %>">VS</span>
                              </div>
                              <div class="fixture-public-team fixture-public-team-b">
                                <img src="<%= partido.icono_equipo_b || '/images/default_team.png' %>" alt="" class="fixture-public-icon">
                                <strong title="<%= partido.nombre_equipo_b || 'Equipo B' %>"><%= partido.nombre_equipo_b || 'Equipo B' %></strong>
                                <% if (partido.estado_equipo_b === false) { %>
                                  <span class="fixture-public-team-note">inhabilitada</span>
                                <% } %>
                              </div>
                            </div>
                            <div class="fixture-public-meta">
                              <span><i class="bi bi-diagram-3"></i> <strong class="fixture-public-grupo"><%= grupoPartidoTexto %></strong></span>
                              <span><i class="bi bi-calendar-event"></i> <strong class="fixture-public-fecha"><%= partido.fecha_formateada || '-' %></strong></span>
                              <span><i class="bi bi-clock"></i> <strong class="fixture-public-hora"><%= partido.hora || '-' %></strong></span>
                              <span class="fixture-public-cancha-wrap <%= partido.nombre_cancha ? '' : 'd-none' %>"><i class="bi bi-geo-alt"></i> <strong class="fixture-public-cancha"><%= partido.nombre_cancha || '' %></strong></span>
                              <span class="fixture-public-status badge <%= estadoPartidoBadge %>"><%= estadoPartidoTexto %></span>
                            </div>
                          </article>
                        </td>
                        <td class="partidos-admin-only fixture-docs-cell">
                          <button type="button"
                                  class="btn btn-outline-success btn-sm fixture-docs-btn"
                                  title="Documentos del encuentro"
                                  onclick="abrirModalDocsPartido(this)"
                                  data-partido-id="<%= partido.id_partido %>"
                                  data-numero-fecha="<%= partido.numero_fecha || '' %>"
                                  data-equipo-a-id="<%= partido.equipo_a %>"
                                  data-equipo-b-id="<%= partido.equipo_b %>"
                                  data-equipo-a-nombre="<%= partido.nombre_equipo_a || 'Equipo A' %>"
                                  data-equipo-b-nombre="<%= partido.nombre_equipo_b || 'Equipo B' %>"
                                  data-equipo-a-icono="<%= partido.icono_equipo_a || '/images/default_team.png' %>"
                                  data-equipo-b-icono="<%= partido.icono_equipo_b || '/images/default_team.png' %>">
                            <i class="bi bi-folder2-open"></i>
                          </button>
                        </td>
                        <td>
                          <div class="partidos-equipo">
                            <img src="<%= partido.icono_equipo_a || '/images/default_team.png' %>" alt="" class="partidos-equipo-icono">
                            <strong class="partidos-equipo-nombre" title="<%= partido.nombre_equipo_a || 'Equipo A' %>"><%= partido.nombre_equipo_a || 'Equipo A' %></strong>
                            <% if (partido.estado_equipo_a === false) { %>
                              <span class="badge text-bg-secondary">inhabilitada</span>
                            <% } %>
                            <button type="button"
                                    class="btn btn-sm partidos-equipo-carga partidos-admin-only <%= partido.carga_equipo_a_registrada ? 'btn-success' : 'btn-warning' %>"
                                    title="<%= partido.carga_equipo_a_registrada ? 'Carga registrada' : 'Carga pendiente' %>"
                                    onclick="abrirCargaEquipoPartido(<%= partido.id_partido %>, <%= partido.equipo_a %>, this)">
                              <i class="bi bi-pencil"></i>
                            </button>
                          </div>
                        </td>
                        <td class="text-center fw-bold editar-marcador-btn" style="cursor: pointer;" 
                            data-id="<%= partido.id_partido %>"
                            data-equipo-a-id="<%= partido.equipo_a %>"
                            data-equipo-b-id="<%= partido.equipo_b %>"
                            data-equipo-a="<%= partido.nombre_equipo_a || '' %>"
                            data-equipo-b="<%= partido.nombre_equipo_b || '' %>"
                            data-grupo-id="<%= partido.id_grupo || '' %>"
                            data-estado="<%= String(partido.estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_') %>"
                            data-goles-a="<%= partido.goles_a || 0 %>"
                            data-goles-b="<%= partido.goles_b || 0 %>">
                          <span style="font-weight: bold;"><%= partido.goles_a ?? 0 %> - <%= partido.goles_b ?? 0 %></span>
                        </td>
                        <td>
                          <div class="partidos-equipo">
                            <img src="<%= partido.icono_equipo_b || '/images/default_team.png' %>" alt="" class="partidos-equipo-icono">
                            <strong class="partidos-equipo-nombre" title="<%= partido.nombre_equipo_b || 'Equipo B' %>"><%= partido.nombre_equipo_b || 'Equipo B' %></strong>
                            <% if (partido.estado_equipo_b === false) { %>
                              <span class="badge text-bg-secondary">inhabilitada</span>
                            <% } %>
                            <button type="button"
                                    class="btn btn-sm partidos-equipo-carga partidos-admin-only <%= partido.carga_equipo_b_registrada ? 'btn-success' : 'btn-warning' %>"
                                    title="<%= partido.carga_equipo_b_registrada ? 'Carga registrada' : 'Carga pendiente' %>"
                                    onclick="abrirCargaEquipoPartido(<%= partido.id_partido %>, <%= partido.equipo_b %>, this)">
                              <i class="bi bi-pencil"></i>
                            </button>
                          </div>
                        </td>
                        <td class="fixture-web-col">
                          <%= partido.nombre_grupo_display || partido.nombre_grupo || 'Sin grupo' %>
                          <% if ((partido.observaciones === 'Ida' || partido.observaciones === 'Vuelta') && !String(partido.nombre_grupo_display || '').includes(partido.observaciones)) { %>
                            - <%= partido.observaciones %>
                          <% } %>
                        </td>
                        <td class="fixture-web-col fixture-fecha-cell"><%= partido.fecha_formateada || '-' %></td>
                        <td class="fixture-web-col fixture-hora-cell"><%= partido.hora || '-' %></td>
                        <td>
                          <select class="form-select form-select-sm estado-select partidos-admin-only <%= estadoPartidoValor === 'en_curso' ? 'estado-en-curso' : '' %>" data-id="<%= partido.id_partido %>" data-estado-actual="<%= estadoPartidoValor %>">
                            <option value="programado" <%= estadoPartidoValor === 'programado' ? 'selected' : '' %>>Programado</option>
                            <option value="en_curso" <%= estadoPartidoValor === 'en_curso' ? 'selected' : '' %>>En curso</option>
                            <option value="suspendido" <%= estadoPartidoValor === 'suspendido' ? 'selected' : '' %>>Suspendido</option>
                            <option value="finalizado" <%= estadoPartidoValor === 'finalizado' ? 'selected' : '' %>>Finalizado</option>
                          </select>
                          <span class="partidos-public-only badge <%= estadoPartidoBadge %>"><%= estadoPartidoTexto %></span>
                        </td>
                        <td class="partidos-admin-only" style="text-align: center;">
                          <div class="btn-group btn-group-sm" role="group">
                            <% if (partido.estado === 'finalizado') { %>
                              <button type="button" class="btn btn-outline-secondary" disabled
                                      title="No se puede intercambiar un partido finalizado"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-arrow-left-right"></i>
                              </button>
                            <% } else { %>
                              <form action="/partidos/<%= partido.id_partido %>/intercambiar" method="POST"
                                    class="form-intercambiar-equipos"
                                    style="display:inline-block;">
                                <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&fecha=' + fecha.numero_fecha + '&tab=partidos' : '?fecha=' + fecha.numero_fecha + '&tab=partidos' %>#partidos">
                                <button type="submit" class="btn btn-outline-secondary"
                                        title="Intercambiar Equipo A y Equipo B"
                                        style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                  <i class="bi bi-arrow-left-right"></i>
                                </button>
                              </form>
                            <% } %>

                            <!-- Botón editar horario -->
                            <% if (partido.estado === 'finalizado') { %>
                              <button type="button" class="btn btn-outline-primary" disabled
                                      title="No se puede editar un partido finalizado"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-pencil"></i>
                              </button>
                            <% } else { %>
                              <button type="button" class="btn btn-outline-primary editar-horario-btn"
                                      data-id="<%= partido.id_partido %>"
                                      data-equipo-a="<%= partido.nombre_equipo_a || '' %>"
                                      data-equipo-b="<%= partido.nombre_equipo_b || '' %>"
                                      data-fecha="<%= partido.fecha_input || partido.fecha || '' %>"
                                      data-hora="<%= partido.hora || '' %>"
                                      data-cancha-id="<%= partido.id_cancha || '' %>"
                                      data-torneo-id="<%= torneo.id_torneo %>"
                                      title="Editar horario"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-pencil"></i>
                              </button>
                            <% } %>
                            
                            <% const partidoTieneCargaRegistrada = partido.carga_equipo_a_registrada || partido.carga_equipo_b_registrada; %>
                            <% if (partido.estado === 'finalizado' || partidoTieneCargaRegistrada) { %>
                              <button type="button" class="btn btn-outline-danger" disabled
                                      title="<%= partido.estado === 'finalizado' ? 'No se puede eliminar un partido finalizado' : 'No se puede eliminar un encuentro con items o cargas registradas' %>"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-trash"></i>
                              </button>
                            <% } else { %>
                              <form action="/partidos/<%= partido.id_partido %>/eliminar" method="POST"
                                    class="form-eliminar-encuentro"
                                    style="display:inline-block;">
                                <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&fecha=' + fecha.numero_fecha + '&tab=partidos' : '?fecha=' + fecha.numero_fecha + '&tab=partidos' %>#partidos">
                                <button type="submit" class="btn btn-outline-danger"
                                        title="Eliminar encuentro"
                                        style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                  <i class="bi bi-trash"></i>
                                </button>
                              </form>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                      <tr class="partido-detalle-row <%= partido.nombre_cancha ? 'partido-detalle-row-cancha' : '' %> <%= partido.tiene_equipo_inhabilitado ? 'table-secondary partido-inhabilitado' : '' %>">
                        <td colspan="9">
                          <div class="partido-detalle" data-partido-id="<%= partido.id_partido %>">
                            <span class="partido-detalle-meta">
                              <strong>
                                <%= partido.nombre_grupo_display || partido.nombre_grupo || 'Sin grupo' %>
                                <% if ((partido.observaciones === 'Ida' || partido.observaciones === 'Vuelta') && !String(partido.nombre_grupo_display || '').includes(partido.observaciones)) { %>
                                  - <%= partido.observaciones %>
                                <% } %>
                              </strong>
                            </span>
                            <span class="partido-detalle-meta"><i class="bi bi-calendar-event"></i> Fecha: <strong class="partido-detalle-fecha"><%= partido.fecha_formateada || '-' %></strong></span>
                            <span class="partido-detalle-meta"><i class="bi bi-clock"></i> Hora: <strong class="partido-detalle-hora"><%= partido.hora || '-' %></strong></span>
                            <% if (partido.nombre_cancha) { %>
                              <span class="partido-detalle-cancha-wrap"><i class="bi bi-geo-alt"></i> Cancha: <strong class="partido-detalle-cancha"><%= partido.nombre_cancha %></strong></span>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="alert alert-info">No hay partidos generados aún para este torneo.</div>
      <% } %>
    </div>
  </div>

  <!-- pestaña Estadísticas -->
  <% if (rol_id != 1) { %>
  <div class="tab-pane fade<%= paneActiva('finanzas') %>" id="finanzas">
    <div class="p-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-white mb-0">Finanzas</h3>
        <% if (rol_id == 3 || rol_id == 99) { %>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-light" id="btnVistaPublicaFinanzas" title="Vista usuario">
              <i class="bi bi-eye"></i> Vista usuario
            </button>
            <button type="button" class="btn btn-outline-warning d-none" id="btnVistaAdminFinanzas" title="Habilitar administracion">
              <i class="bi bi-tools"></i> Habilitar admin
            </button>
          </div>
        <% } %>
      </div>
      <% if (rol_id == 3 || rol_id == 99) { %>
        <div class="row g-2 align-items-end mb-3">
          <div class="col-md-4">
            <label class="form-label text-dark mb-1" for="buscarFinanzasEquipo">Buscar equipo</label>
            <div class="input-group">
              <input type="text"
                     class="form-control text-uppercase"
                     id="buscarFinanzasEquipo"
                     placeholder="nombre de equipo">
              <button type="button"
                      class="btn btn-outline-light btn-buscar-gris"
                      id="btnBuscarFinanzasEquipo"
                      title="Buscar equipo">
                <i class="bi bi-search"></i>
              </button>
            </div>
          </div>
          <div class="col-md-8">
            <form action="/torneos/<%= torneo.id_torneo %>/permitir-delegados-ver-estado-finanzas"
                  method="POST"
                  class="form-switch-estado-finanzas d-flex justify-content-md-end">
              <input type="hidden"
                     name="permitir_delegados_ver_estado_finanzas"
                     value="<%= torneo.permitir_delegados_ver_estado_finanzas === true ? '0' : '1' %>">
              <div class="form-check form-switch mb-0">
                <input class="form-check-input"
                       type="checkbox"
                       role="switch"
                       id="switchEstadoFinanzasDelegados"
                       onchange="confirmarPermisoEstadoFinanzas(this)"
                       disabled
                       <%= torneo.permitir_delegados_ver_estado_finanzas === true ? 'checked' : '' %>>
                <label class="form-check-label text-dark" for="switchEstadoFinanzasDelegados">
                  Delegados pueden ver estado de otros equipos
                </label>
              </div>
            </form>
          </div>
        </div>
        <div class="text-dark small mb-2">
          Equipos visibles: <strong id="finanzasEquiposVisibles">0</strong> / <span id="finanzasEquiposTotal"><%= (finanzasResumen || []).length %></span>
        </div>
      <% } %>
      <div class="card bg-light bg-opacity-75 shadow finanzas-panel">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 finanzas-table">
              <thead class="table-light">
                <tr>
                  <th class="finanzas-equipo-col">Equipo</th>
                  <th class="finanzas-grupo-col">Grupo</th>
                  <th class="text-center finanzas-estado-col">Estado</th>
                  <th class="text-end finanzas-saldo-col finanzas-admin-only">Saldo actual</th>
                  <th class="text-end finanzas-acciones-col">Acciones</th>
                </tr>
              </thead>
              <tbody id="finanzasResumenTbody">
                <% if (finanzasResumen && finanzasResumen.length > 0) { %>
                  <% finanzasResumen.forEach(equipoFinanza => { %>
                    <tr data-finanzas-equipo-id="<%= equipoFinanza.id_equipo %>"
                        data-finanzas-equipo-nombre="<%= equipoFinanza.nombre || '' %>">
                      <td data-label="Equipo">
                        <div class="d-flex align-items-center gap-2">
                          <img src="<%= equipoFinanza.icono || '/images/default_team.png' %>"
                               alt=""
                               style="width:28px;height:28px;object-fit:cover;border-radius:50%;">
                          <strong class="text-dark"><%= equipoFinanza.nombre %></strong>
                        </div>
                      </td>
                      <td class="text-dark" data-label="Grupo"><%= equipoFinanza.nombre_grupo || 'Sin grupo' %></td>
                      <td class="text-center finanzas-estado-cell" data-label="Estado">
                        <% if (equipoFinanza.adeuda) { %>
                          <span class="fw-bold text-danger" title="Equipo con deuda">‼️‼️</span>
                        <% } else { %>
                          <span class="badge text-bg-success">Al dia</span>
                        <% } %>
                      </td>
                      <td class="text-end fw-bold finanzas-admin-only finanzas-saldo-cell <%= equipoFinanza.adeuda ? 'text-danger' : 'text-dark' %>" data-label="Saldo">
                        <%= equipoFinanza.puede_ver_detalle === false ? '-' : Number(equipoFinanza.saldo_actual || 0).toLocaleString('es-PY') %>
                      </td>
                      <td class="text-end" data-label="Acciones">
                        <% if (equipoFinanza.puede_ver_detalle === false) { %>
                          <span class="text-muted small">Sin detalle</span>
                        <% } else { %>
                          <button type="button"
                                  class="btn btn-sm btn-outline-dark"
                                  onclick="abrirDetalleFinanzas('<%= equipoFinanza.id_equipo %>')">
                            Detalles
                          </button>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center text-muted py-3">No hay equipos cargados para este torneo.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
  </div>
</div>
  <% } %>

  <div class="tab-pane fade<%= paneActiva('estadisticas') %>" id="estadisticas">
    <div class="p-3">
      <h3 class="text-white mb-3">Estadisticas</h3>

