</div>

  <!-- pestaña Partidos -->
  <div class="tab-pane fade" id="partidos">
  <div class="card-partidos p-3 shadow">
    <div class="d-flex justify-content-between align-items-center mb-3 fixture-header">
      <h3 class="mb-0">Fixture</h3>
      <% if (rol_id == 3 || rol_id == 99) { %>
        <div class="btn-group btn-group-sm" role="group">
          <% const proximaFechaPartidos = ((partidosPorFecha || []).reduce((max, fecha) => Math.max(max, Number(fecha.numero_fecha || 0)), 0) || 0) + 1; %>
          <button type="button"
                  class="btn btn-success fw-bold partidos-admin-only"
                  onclick="abrirModalCruceManual(<%= proximaFechaPartidos %>, '<%= grupoSeleccionadoId || '' %>')"
                  title="Agregar fecha adicional">
            <i class="bi bi-calendar-plus"></i> Agregar fecha
          </button>
          <button type="button" class="btn btn-outline-light" id="btnVistaPublicaPartidos" title="Vista usuario">
            <i class="bi bi-eye"></i> Vista usuario
          </button>
          <button type="button" class="btn btn-outline-warning d-none" id="btnVistaAdminPartidos" title="Habilitar administracion">
            <i class="bi bi-tools"></i> Habilitar admin
          </button>
        </div>
      <% } %>
    </div>
    <div class="row g-2 align-items-end mb-3">
      <div class="col-md-4">
        <label class="form-label text-dark fw-bold mb-1">Filtrar por grupo</label>
        <select class="form-select form-select-sm" onchange="window.location = '<%= '/torneos/gestionar/' + torneo.id_torneo %>' + (this.value ? '?grupo_id=' + this.value : '') + '#partidos'">
          <option value="">Vista general</option>
          <% ((typeof gruposFixture !== 'undefined' && gruposFixture) || grupos || []).forEach(grupo => { %>
            <option value="<%= grupo.id_grupo %>" <%= String(grupoSeleccionadoId || '') === String(grupo.id_grupo) ? 'selected' : '' %>>
              <%= grupo.nombre_grupo %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label text-dark fw-bold mb-1" for="filtroPartidosFechaCalendario">Filtrar por fecha calendario</label>
        <div class="input-group input-group-sm">
          <input type="date"
                 class="form-control"
                 id="filtroPartidosFechaCalendario"
                 value="<%= fechaCalendarioSeleccionada || '' %>">
          <button type="button" class="btn btn-primary fw-bold" id="btnFiltrarPartidosFecha">
            <i class="bi bi-calendar-check"></i> Ver día
          </button>
          <button type="button" class="btn btn-outline-secondary" id="btnLimpiarPartidosFecha" title="Limpiar fecha">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      </div>
      <% if (fechaCalendarioSeleccionada) { %>
        <div class="col-md-4">
          <span class="badge text-bg-warning">
            Mostrando todos los grupos del <%= fechaCalendarioSeleccionada.split('-').reverse().join('/') %>
          </span>
        </div>
      <% } %>
    </div>

    <% if (torneo.portada) { %>
      <div class="torneo-portada mb-3">
        <img src="<%= torneo.portada %>" alt="Portada de <%= torneo.nombre_torneo %>">
      </div>
      <% } %>

      <% if (partidosPorFecha && partidosPorFecha.length > 0) { %>
        <%
          const fechaActivaFixture =
            (partidosPorFecha.find(f =>
              (f.partidos || []).some(p => String(p.estado || '').trim().toLowerCase() !== 'finalizado')
            ) || partidosPorFecha[0] || {}).numero_fecha;
        %>
        <ul class="nav nav-pills mb-3" id="fechasTab" role="tablist">
          <% partidosPorFecha.forEach((fecha, index) => { %>
            <% const fechaEsActiva = String(fecha.numero_fecha) === String(fechaActivaFixture); %>
            <li class="nav-item" role="presentation">
              <button class="nav-link fixture-fecha-tab <%= fechaEsActiva ? 'active' : '' %>"
                      id="fecha-<%= fecha.numero_fecha %>-tab"
                      data-bs-toggle="pill"
                      data-bs-target="#fecha-<%= fecha.numero_fecha %>"
                      type="button"
                      role="tab"
                      aria-controls="fecha-<%= fecha.numero_fecha %>"
                      aria-selected="<%= fechaEsActiva ? 'true' : 'false' %>">
                Fecha <%= fecha.numero_fecha %>
                <% if (fecha.fecha_general) { %>
                  <% const fechaGeneralVisible = String(fecha.fecha_general).slice(0, 10).split('-').reverse().join('/'); %>
                  - <%= fechaGeneralVisible %>
                <% } %>
              </button>
            </li>
          <% }) %>
        </ul>

        <div class="tab-content">
          <% partidosPorFecha.forEach((fecha, index) => { %>
            <% const fechaEsActiva = String(fecha.numero_fecha) === String(fechaActivaFixture); %>
            <div class="tab-pane fade <%= fechaEsActiva ? 'show active' : '' %>"
                 id="fecha-<%= fecha.numero_fecha %>"
                 role="tabpanel"
                 aria-labelledby="fecha-<%= fecha.numero_fecha %>-tab">

              <!-- Formulario para asignar fecha y horarios comunes -->
              <form id="formFechaComun-<%= fecha.numero_fecha %>" class="mb-4 partidos-admin-only">
                <input type="hidden" name="numero_fecha" value="<%= fecha.numero_fecha %>">
                <input type="hidden" name="torneo_id" value="<%= torneo.id_torneo %>">
                <% if (grupoSeleccionadoId) { %>
                  <input type="hidden" name="grupo_id" value="<%= grupoSeleccionadoId %>">
                <% } %>
                <div class="row g-3 align-items-end">
                  <div class="col-md-3">
                    <label class="form-label fw-bold text-dark">📅 Fecha común</label>
                    <input type="date" class="form-control" id="fechaComun-<%= fecha.numero_fecha %>" name="fecha_comun" value="<%= fecha.fecha_general ? fecha.fecha_general : '' %>">
                  </div>
                  <div class="col-md-2">
                    <label class="form-label fw-bold text-dark">⏰ Hora inicial</label>
                    <input type="time" class="form-control" id="horaInicial-<%= fecha.numero_fecha %>" name="hora_inicial" placeholder="14:00">
                  </div>
                  <div class="col-md-2">
                    <label class="form-label fw-bold text-dark">⏱️ Intervalo (min)</label>
                    <input type="number" class="form-control" id="intervalo-<%= fecha.numero_fecha %>" name="intervalo_minutos" placeholder="20" min="5" max="120">
                  </div>
                  <div class="col-md-3">
                    <button type="button"
                            class="btn btn-primary w-100 mb-2 abrir-cruce-manual-btn"
                            data-numero-fecha="<%= fecha.numero_fecha %>"
                            data-grupo-id="<%= fecha.partidos && fecha.partidos.length > 0 ? fecha.partidos[0].id_grupo || '' : '' %>">
                      <i class="bi bi-diagram-3"></i> Cruce manual
                    </button>
                    <button type="button" class="btn btn-success w-100 guardar-horarios-btn" data-numero-fecha="<%= fecha.numero_fecha %>">
                      <i class="bi bi-check-circle"></i> Guardar cambios
                    </button>
                  </div>
                  <div class="col-md-2">
                    <small class="fixture-ayuda-horarios">
                      Asigna fecha y horarios espaciados a los encuentros visibles de esta fecha
                    </small>
                  </div>
                </div>
              </form>

              <% if (fecha.partidos && fecha.partidos.length > 0) { %>
                <% const fechaTieneFinalizados = fecha.partidos.some(partido => String(partido.estado || '').trim().toLowerCase() === 'finalizado'); %>
                <% if (fechaTieneFinalizados) { %>
                  <button type="button"
                          class="btn btn-outline-danger btn-sm mb-3 partidos-admin-only"
                          disabled
                          title="No se puede eliminar una fecha con partidos finalizados">
                    <i class="bi bi-calendar-x"></i> Eliminar fecha
                  </button>
                <% } else { %>
                  <form action="/partidos/torneos/<%= torneo.id_torneo %>/fecha/<%= fecha.numero_fecha %>/eliminar"
                        method="POST"
                        class="mb-3 partidos-admin-only form-confirmar-app"
                        data-confirm-title="Eliminar fecha"
                        data-confirm-message="¿Eliminar todos los encuentros de la fecha <%= fecha.numero_fecha %>?"
                        data-confirm-accept="Sí, eliminar fecha"
                        data-confirm-cancel="Cancelar">
                    <% if (grupoSeleccionadoId) { %>
                      <input type="hidden" name="id_grupo" value="<%= grupoSeleccionadoId %>">
                    <% } %>
                    <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&fecha=' + fecha.numero_fecha : '?fecha=' + fecha.numero_fecha %>#partidos">
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                      <i class="bi bi-calendar-x"></i> Eliminar fecha
                    </button>
                  </form>
                <% } %>
              <% } %>

              <% if (fecha.equipos_libres && fecha.equipos_libres.length > 0) { %>
                <div class="alert alert-warning py-2 mb-3">
                  <strong>Equipo(s) libre(s):</strong>
                  <% fecha.equipos_libres.forEach((libre, indexLibre) => { %>
                    <span class="badge bg-secondary me-1 d-inline-flex align-items-center gap-1">
                      <img src="<%= libre.icono || '/images/default_team.png' %>" alt="" style="width: 18px; height: 18px; object-fit: contain;">
                      <span><%= libre.nombre_grupo %>: <%= libre.nombre_equipo %></span>
                      <button type="button"
                              class="btn btn-sm py-0 px-1 partidos-admin-only <%= libre.carga_registrada ? 'btn-success' : 'btn-warning' %>"
                              title="<%= libre.carga_registrada ? 'Carga registrada' : 'Carga pendiente' %>"
                              onclick="abrirCargaEquipoLibre(<%= torneo.id_torneo %>, <%= fecha.numero_fecha %>, <%= libre.id_equipo %>, this)">
                        <i class="bi bi-pencil"></i>
                      </button>
                    </span>
                  <% }) %>
                </div>
              <% } %>

              <!-- Tabla de partidos más ancha -->
              <div class="table-responsive" style="overflow-x: auto;">
                <table class="table table-hover align-middle table-sm" style="font-size: 0.85rem;">
                  <thead class="table-dark">
                    <tr>
                      <th style="width: 20%;">Equipo A</th>
                      <th style="width: 10%; text-align: center;">Marcador</th>
                      <th style="width: 20%;">Equipo B</th>
                      <th style="width: 8%;">Grupo</th>
                      <th style="width: 8%;">Fecha</th>
                      <th style="width: 7%;">Hora</th>
                      <th style="width: 10%;">Cancha</th>
                      <th style="width: 10%;">Estado</th>
                      <th class="partidos-admin-only" style="width: 15%; text-align: center;">Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!fecha.partidos || fecha.partidos.length === 0) { %>
                      <tr>
                        <td colspan="9" class="text-center text-muted py-3">
                          Fecha sin encuentros programados. Use Cruce manual para agregar partidos en esta fecha.
                        </td>
                      </tr>
                    <% } %>
                    <% fecha.partidos.forEach(partido => { %>
                      <tr class="<%= partido.tiene_equipo_inhabilitado ? 'table-secondary partido-inhabilitado' : '' %>">
                        <td>
                          <div class="partidos-equipo">
                            <img src="<%= partido.icono_equipo_a || '/images/default_team.png' %>" alt="" class="partidos-equipo-icono">
                            <strong class="partidos-equipo-nombre" title="<%= partido.nombre_equipo_a || 'Equipo A' %>"><%= partido.nombre_equipo_a || 'Equipo A' %></strong>
                            <% if (partido.estado_equipo_a === false) { %>
                              <span class="badge text-bg-secondary">inhabilitada</span>
                            <% } %>
                            <button type="button"
                                    class="btn btn-sm partidos-equipo-carga partidos-admin-only <%= partido.carga_equipo_a_registrada ? 'btn-success' : 'btn-warning' %>"
                                    title="<%= partido.carga_equipo_a_registrada ? 'Carga registrada' : 'Carga pendiente' %>"
                                    onclick="abrirCargaEquipoPartido(<%= partido.id_partido %>, <%= partido.equipo_a %>, this)">
                              <i class="bi bi-pencil"></i>
                            </button>
                          </div>
                        </td>
                        <td class="text-center fw-bold editar-marcador-btn" style="cursor: pointer;" 
                            data-id="<%= partido.id_partido %>"
                            data-equipo-a-id="<%= partido.equipo_a %>"
                            data-equipo-b-id="<%= partido.equipo_b %>"
                            data-equipo-a="<%= partido.nombre_equipo_a || '' %>"
                            data-equipo-b="<%= partido.nombre_equipo_b || '' %>"
                            data-grupo-id="<%= partido.id_grupo || '' %>"
                            data-estado="<%= String(partido.estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_') %>"
                            data-goles-a="<%= partido.goles_a || 0 %>"
                            data-goles-b="<%= partido.goles_b || 0 %>">
                          <span style="font-weight: bold;"><%= partido.goles_a ?? 0 %> - <%= partido.goles_b ?? 0 %></span>
                        </td>
                        <td>
                          <div class="partidos-equipo">
                            <img src="<%= partido.icono_equipo_b || '/images/default_team.png' %>" alt="" class="partidos-equipo-icono">
                            <strong class="partidos-equipo-nombre" title="<%= partido.nombre_equipo_b || 'Equipo B' %>"><%= partido.nombre_equipo_b || 'Equipo B' %></strong>
                            <% if (partido.estado_equipo_b === false) { %>
                              <span class="badge text-bg-secondary">inhabilitada</span>
                            <% } %>
                            <button type="button"
                                    class="btn btn-sm partidos-equipo-carga partidos-admin-only <%= partido.carga_equipo_b_registrada ? 'btn-success' : 'btn-warning' %>"
                                    title="<%= partido.carga_equipo_b_registrada ? 'Carga registrada' : 'Carga pendiente' %>"
                                    onclick="abrirCargaEquipoPartido(<%= partido.id_partido %>, <%= partido.equipo_b %>, this)">
                              <i class="bi bi-pencil"></i>
                            </button>
                          </div>
                        </td>
                        <td>
                          <small>
                            <%= partido.nombre_grupo_display || partido.nombre_grupo || 'Sin grupo' %>
                            <% if (partido.observaciones === 'Ida' || partido.observaciones === 'Vuelta') { %>
                              - <%= partido.observaciones %>
                            <% } %>
                          </small>
                        </td>
                        <td><small><%= partido.fecha_formateada || '-' %></small></td>
                        <td><small><strong><%= partido.hora || '-' %></strong></small></td>
                        <td><small><%= partido.nombre_cancha || '-' %></small></td>
                        <td>
                          <% const estadoPartidoValor = String(partido.estado || 'programado').trim().toLowerCase().replace(/[\s-]+/g, '_'); %>
                          <% const estadoPartidoTexto = estadoPartidoValor === 'en_curso' ? 'En curso' : (estadoPartidoValor.charAt(0).toUpperCase() + estadoPartidoValor.slice(1)); %>
                          <% const estadoPartidoBadge = estadoPartidoValor === 'en_curso' ? 'estado-badge-en-curso' : (estadoPartidoValor === 'finalizado' ? 'text-bg-success' : (estadoPartidoValor === 'suspendido' ? 'text-bg-secondary' : 'text-bg-light')); %>
                          <select class="form-select form-select-sm estado-select partidos-admin-only <%= estadoPartidoValor === 'en_curso' ? 'estado-en-curso' : '' %>" data-id="<%= partido.id_partido %>">
                            <option value="programado" <%= estadoPartidoValor === 'programado' ? 'selected' : '' %>>Programado</option>
                            <option value="en_curso" <%= estadoPartidoValor === 'en_curso' ? 'selected' : '' %>>En curso</option>
                            <option value="suspendido" <%= estadoPartidoValor === 'suspendido' ? 'selected' : '' %>>Suspendido</option>
                            <option value="finalizado" <%= estadoPartidoValor === 'finalizado' ? 'selected' : '' %>>Finalizado</option>
                          </select>
                          <span class="partidos-public-only badge <%= estadoPartidoBadge %>"><%= estadoPartidoTexto %></span>
                        </td>
                        <td class="partidos-admin-only" style="text-align: center;">
                          <div class="btn-group btn-group-sm" role="group">
                            <!-- Botón guardar estado/marcador -->
                            <button type="button" class="btn btn-outline-success btn-guardar-match"
                                    data-id="<%= partido.id_partido %>"
                                    title="Guardar cambios"
                                    style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                            <i class="bi bi-save"></i>
                            </button>

                            <% if (partido.estado === 'finalizado') { %>
                              <button type="button" class="btn btn-outline-secondary" disabled
                                      title="No se puede intercambiar un partido finalizado"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-arrow-left-right"></i>
                              </button>
                            <% } else { %>
                              <form action="/partidos/<%= partido.id_partido %>/intercambiar" method="POST"
                                    class="form-intercambiar-equipos"
                                    style="display:inline-block;">
                                <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&fecha=' + fecha.numero_fecha : '?fecha=' + fecha.numero_fecha %>#partidos">
                                <button type="submit" class="btn btn-outline-secondary"
                                        title="Intercambiar Equipo A y Equipo B"
                                        style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                  <i class="bi bi-arrow-left-right"></i>
                                </button>
                              </form>
                            <% } %>

                            <!-- Botón editar horario -->
                            <% if (partido.estado === 'finalizado') { %>
                              <button type="button" class="btn btn-outline-primary" disabled
                                      title="No se puede editar un partido finalizado"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-pencil"></i>
                              </button>
                            <% } else { %>
                              <button type="button" class="btn btn-outline-primary editar-horario-btn"
                                      data-id="<%= partido.id_partido %>"
                                      data-equipo-a="<%= partido.nombre_equipo_a || '' %>"
                                      data-equipo-b="<%= partido.nombre_equipo_b || '' %>"
                                      data-fecha="<%= partido.fecha_input || partido.fecha || '' %>"
                                      data-hora="<%= partido.hora || '' %>"
                                      data-cancha-id="<%= partido.id_cancha || '' %>"
                                      data-torneo-id="<%= torneo.id_torneo %>"
                                      title="Editar horario"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-pencil"></i>
                              </button>
                            <% } %>
                            
                            <!-- Botón administración -->
                            <button type="button" class="btn btn-outline-secondary"
                                    title="Administración"
                                    style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                              <i class="bi bi-gear-fill"></i>
                            </button>

                            <% if (partido.estado === 'finalizado') { %>
                              <button type="button" class="btn btn-outline-danger" disabled
                                      title="No se puede eliminar un partido finalizado"
                                      style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                <i class="bi bi-trash"></i>
                              </button>
                            <% } else { %>
                              <form action="/partidos/<%= partido.id_partido %>/eliminar" method="POST"
                                    class="form-eliminar-encuentro"
                                    style="display:inline-block;">
                                <input type="hidden" name="redirect_url" value="/torneos/gestionar/<%= torneo.id_torneo %><%= grupoSeleccionadoId ? '?grupo_id=' + grupoSeleccionadoId + '&fecha=' + fecha.numero_fecha : '?fecha=' + fecha.numero_fecha %>#partidos">
                                <button type="submit" class="btn btn-outline-danger"
                                        title="Eliminar encuentro"
                                        style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                  <i class="bi bi-trash"></i>
                                </button>
                              </form>
                            <% } %>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="alert alert-info">No hay partidos generados aún para este torneo.</div>
      <% } %>
    </div>
  </div>

  <!-- pestaña Estadísticas -->
  <% if (rol_id != 1) { %>
  <div class="tab-pane fade" id="finanzas">
    <div class="p-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-white mb-0">Finanzas</h3>
        <% if (rol_id == 3 || rol_id == 99) { %>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-light" id="btnVistaPublicaFinanzas" title="Vista usuario">
              <i class="bi bi-eye"></i> Vista usuario
            </button>
            <button type="button" class="btn btn-outline-warning d-none" id="btnVistaAdminFinanzas" title="Habilitar administracion">
              <i class="bi bi-tools"></i> Habilitar admin
            </button>
          </div>
        <% } %>
      </div>
      <div class="card bg-light bg-opacity-75 shadow finanzas-panel">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 finanzas-table">
              <thead class="table-light">
                <tr>
                  <th class="finanzas-equipo-col">Equipo</th>
                  <th class="finanzas-grupo-col">Grupo</th>
                  <th class="text-center finanzas-estado-col">Estado</th>
                  <th class="text-end finanzas-saldo-col finanzas-admin-only">Saldo actual</th>
                  <th class="text-end finanzas-acciones-col">Acciones</th>
                </tr>
              </thead>
              <tbody id="finanzasResumenTbody">
                <% if (finanzasResumen && finanzasResumen.length > 0) { %>
                  <% finanzasResumen.forEach(equipoFinanza => { %>
                    <tr data-finanzas-equipo-id="<%= equipoFinanza.id_equipo %>">
                      <td data-label="Equipo">
                        <div class="d-flex align-items-center gap-2">
                          <img src="<%= equipoFinanza.icono || '/images/default_team.png' %>"
                               alt=""
                               style="width:28px;height:28px;object-fit:cover;border-radius:50%;">
                          <strong class="text-dark"><%= equipoFinanza.nombre %></strong>
                        </div>
                      </td>
                      <td class="text-dark" data-label="Grupo"><%= equipoFinanza.nombre_grupo || 'Sin grupo' %></td>
                      <td class="text-center finanzas-estado-cell" data-label="Estado">
                        <% if (equipoFinanza.adeuda) { %>
                          <span class="fw-bold text-danger" title="Equipo con deuda">‼️‼️</span>
                        <% } else { %>
                          <span class="badge text-bg-success">Al dia</span>
                        <% } %>
                      </td>
                      <td class="text-end fw-bold finanzas-admin-only finanzas-saldo-cell <%= equipoFinanza.adeuda ? 'text-danger' : 'text-dark' %>" data-label="Saldo">
                        <%= Number(equipoFinanza.saldo_actual || 0).toLocaleString('es-PY') %>
                      </td>
                      <td class="text-end" data-label="Acciones">
                        <button type="button"
                                class="btn btn-sm btn-outline-dark"
                                onclick="abrirDetalleFinanzas('<%= equipoFinanza.id_equipo %>')">
                          Detalles
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center text-muted py-3">No hay equipos cargados para este torneo.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
  </div>
</div>
  <% } %>

  <div class="tab-pane fade" id="estadisticas">
    <div class="p-3">
      <h3 class="text-white mb-3">Estadisticas</h3>

      <div class="row g-2 align-items-end mb-3">
        <div class="col-md-4">
          <label class="form-label text-white mb-1">Filtrar por grupo</label>
          <select class="form-select form-select-sm" onchange="window.location = '<%= '/torneos/gestionar/' + torneo.id_torneo %>' + (this.value ? '?grupo_id=' + this.value : '') + '#estadisticas'">
            <option value="">Vista general</option>
            <% (grupos || []).forEach(grupo => { %>
              <option value="<%= grupo.id_grupo %>" <%= String(grupoSeleccionadoId || '') === String(grupo.id_grupo) ? 'selected' : '' %>>
                <%= grupo.nombre_grupo %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <% if (torneo.portada) { %>
        <div class="torneo-portada mb-3">
          <img src="<%= torneo.portada %>" alt="Portada de <%= torneo.nombre_torneo %>">
        </div>
      <% } %>

      <ul class="nav nav-tabs mb-3" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#estadisticasTablaPosiciones" type="button" role="tab">
            Tabla de posiciones
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#estadisticasRankingGoles" type="button" role="tab">
            Ranking de goles
          </button>
        </li>
      </ul>

      <div class="tab-content">
        <div class="tab-pane fade show active" id="estadisticasTablaPosiciones" role="tabpanel">
          <div class="table-responsive mb-4">
            <table class="table table-sm table-striped table-hover align-middle bg-white">
              <thead class="table-dark">
                <tr>
                  <th style="width: 38%;">Equipo</th>
                  <th>Grupo</th>
                  <th>PJ</th>
                  <th class="estadisticas-col-detalle">G</th>
                  <th class="estadisticas-col-detalle">E</th>
                  <th class="estadisticas-col-detalle">P</th>
                  <th class="estadisticas-col-detalle">GF</th>
                  <th class="estadisticas-col-detalle">GC</th>
                  <th>DG</th>
                  <th>PTS</th>
                </tr>
              </thead>
              <tbody id="estadisticasTbody">
                <% ((grupoSeleccionadoId ? estadisticasFiltradas : estadisticasGeneral) || []).forEach((item, index) => { %>
                  <tr data-equipo-id="<%= item.id_equipo %>"
                      data-nombre="<%= item.nombre %>"
                      data-icono="<%= item.icono || '/images/default_team.png' %>"
                      data-grupo-nombre="<%= item.nombre_grupo %>">
                    <td>
                      <div class="estadisticas-equipo">
                        <span class="estadisticas-pos"><%= index + 1 %></span>
                        <img src="<%= item.icono || '/images/default_team.png' %>" alt="" class="estadisticas-icono">
                        <strong class="estadisticas-nombre" title="<%= item.nombre %>"><%= item.nombre %></strong>
                      </div>
                    </td>
                    <td><small><%= item.nombre_grupo %></small></td>
                    <td><%= item.pj %>/<%= item.pj_total %></td>
                    <td class="estadisticas-col-detalle"><%= item.pg %></td>
                    <td class="estadisticas-col-detalle"><%= item.pe %></td>
                    <td class="estadisticas-col-detalle"><%= item.pp %></td>
                    <td class="estadisticas-col-detalle"><%= item.gf %></td>
                    <td class="estadisticas-col-detalle"><%= item.gc %></td>
                    <td><%= item.gf - item.gc %></td>
                    <td><strong><%= item.puntos %></strong></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="tab-pane fade" id="estadisticasRankingGoles" role="tabpanel">
          <div class="table-responsive mb-4">
            <table class="table table-sm table-striped table-hover align-middle bg-white">
              <thead class="table-dark">
                <tr>
                  <th>Nombre</th>
                  <th>Equipo actual</th>
                  <th class="text-end">Goles marcados</th>
                </tr>
              </thead>
              <tbody>
                <% if (rankingGoles && rankingGoles.length > 0) { %>
                  <% rankingGoles.forEach(jugador => { %>
                    <tr>
                      <td><strong><%= [jugador.nombre, jugador.apellido].filter(Boolean).join(' ') %></strong></td>
                      <td><%= jugador.equipo || 'Libre' %></td>
                      <td class="text-end fw-bold"><%= jugador.goles %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="3" class="text-center text-muted py-3">Todavia no hay goles cargados para este torneo.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

  </div>
</div>

  <!-- pestaña Items -->
  <div class="tab-pane fade" id="items">
    <div class="p-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-white mb-0">Items</h3>
        <div class="btn-group">
          <button type="button" class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#modalReglaTarjetas">
            <i class="bi bi-shield-exclamation"></i> Regla tarjetas
          </button>
          <button type="button" class="btn btn-outline-light" data-bs-toggle="modal" data-bs-target="#modalCanchas">
            <i class="bi bi-geo-alt"></i> Sedes/canchas
          </button>
          <button type="button" class="btn btn-primary btn-item-nuevo">
            <i class="bi bi-plus-circle"></i> Nuevo item
          </button>
        </div>
      </div>

      <div class="table-responsive">
        <table class="table table-sm table-striped table-hover align-middle bg-white">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Descripción</th>
              <th>Monto</th>
              <th style="width: 160px;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% (items || []).forEach(item => { %>
              <tr>
                <td><strong><%= item.nombre %></strong></td>
                <td><%= item.descripcion || '-' %></td>
                <td><%= Number(item.monto).toFixed(2) %></td>
                <td>
                  <div class="btn-group btn-group-sm" role="group">
                    <button type="button"
                            class="btn btn-outline-primary btn-item-editar"
                            data-id="<%= item.id_item %>"
