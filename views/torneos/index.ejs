


<!DOCTYPE html>
<html>
<head>
  <title>Gestión de Torneos</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const hash = window.location.hash;
      const rolId = Number(<%= Number(rol_id || 0) %>);
      const hashesBloqueados = rolId === 1
        ? ['#grupos', '#equipos', '#items', '#usuarios', '#finanzas']
        : (rolId === 2 ? ['#grupos', '#items', '#usuarios'] : []);

      if (hashesBloqueados.includes(hash)) {
        window.location.hash = '#torneos';
        return;
      }

      if (hash) {
        const triggerEl = document.querySelector(`a[href="${hash}"]`);
        if (triggerEl) {
          const tab = new bootstrap.Tab(triggerEl);
          tab.show();
        }
      }

      const fechaActiva = new URLSearchParams(window.location.search).get('fecha');
      if (fechaActiva) {
        const fechaTrigger = document.getElementById(`fecha-${fechaActiva}-tab`);
        if (fechaTrigger) {
          const fechaTab = new bootstrap.Tab(fechaTrigger);
          fechaTab.show();
        }
      }
    });
  </script>
</head>

<body class="bg-stadium">

  <!-- Barra superior fija -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
    <div class="container-fluid">
      <div class="navbar-brand fw-bold me-4 py-0">
        <div>Panel de Torneos</div>
        <div class="small fw-normal text-warning lh-sm">
          <i class="bi bi-building"></i>
          <%= entidadActual ? (entidadActual.codigo || ('Entidad #' + entityId)) : ('Entidad #' + entityId) %>
        </div>
      </div>
      <ul class="nav nav-tabs me-auto" role="tablist">


        <li class="nav-item">
          <a class="nav-link <%= (rol_id == 1 || rol_id == 2) ? 'active' : '' %>" 
             id="torneos-tab" data-bs-toggle="tab" href="#torneos" role="tab">TORNEOS</a>
        </li>


        <% if (rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link active" 
               id="grupos-tab" data-bs-toggle="tab" href="#grupos" role="tab">Grupos</a>
          </li>
        <% } %>

        <li class="nav-item">
          <a class="nav-link" id="jugadores-tab" data-bs-toggle="tab" href="#jugadores" role="tab">Jugadores</a>
        </li>
        <% if (rol_id == 2 || rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" id="equipos-tab" data-bs-toggle="tab" href="#equipos" role="tab">Equipos</a>
          </li>
        <% } %>
        <li class="nav-item">
          <a class="nav-link" id="partidos-tab" data-bs-toggle="tab" href="#partidos" role="tab">Partidos</a>
        </li>
        <% if (rol_id != 1) { %>
          <li class="nav-item">
            <a class="nav-link" id="finanzas-tab" data-bs-toggle="tab" href="#finanzas" role="tab">Finanzas</a>
          </li>
        <% } %>
        <li class="nav-item">
          <a class="nav-link" id="estadisticas-tab" data-bs-toggle="tab" href="#estadisticas" role="tab">Estadísticas</a>
        </li>
        <% if (rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" id="items-tab" data-bs-toggle="tab" href="#items" role="tab">Items</a>
          </li>
        <% } %>
        <% if (rol_id == 3 || rol_id == 99) { %>
          <li class="nav-item">
            <a class="nav-link" id="usuarios-tab" data-bs-toggle="tab" href="#usuarios" role="tab">Usuarios</a>
          </li>
        <% } %>
      </ul>

      <!-- Botones de navegación a la derecha -->
      <div class="d-flex ms-auto">
        <% if (rol_id != 1) { %>
          <a href="/entidad/gestionar/<%= entityId %>" class="btn btn-success btn-sm me-2">Ir a Torneos</a>
        <% } %>
        <% if (rol_id == 99) { %>
          <a href="/admin" class="btn btn-success btn-sm me-2">Ir a Entidades</a>
        <% } %>
        <a href="/logout" class="btn btn-success btn-sm">Cerrar sesión</a>
      </div>
    </div>
  </nav>

  <!-- Bloque de alertas arriba -->
 <% if (messages.danger && messages.danger.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.danger[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.success && messages.success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.success[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.info && messages.info.length > 0) { %>
  <div class="alert alert-info alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.info[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.warning && messages.warning.length > 0) { %>
  <div class="alert alert-warning alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.warning[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>


  <!-- Contenido de pestañas -->
  <div class="container mt-5 tab-content">

  <!-- TORNEOS -->

    <div class="tab-pane fade <%= (rol_id == 1 || rol_id == 2) ? 'show active' : '' %>" 
     id="torneos" role="tabpanel">

      <h3 class="text-white">Selección de Torneos</h3>
      <ul class="list-group mb-3">
        <li class="list-group-item fw-bold text-muted">Todos los torneos</li>
        <% torneos.forEach(function(t) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center <%= (selectedTorneo == t.id_torneo ? 'active' : '') %>">
            <a href="/torneos/gestionar/<%= t.id_torneo %>" class="text-decoration-none <%= (selectedTorneo == t.id_torneo ? 'text-white' : 'text-dark') %>">
              <strong><%= t.nombre_torneo %></strong> - <%= t.temporada %>
            </a>
            <% if (rol_id == 3 || rol_id == 99) { %>
              <button type="button"
                      class="btn btn-sm <%= (selectedTorneo == t.id_torneo ? 'btn-light' : 'btn-outline-primary') %>"
                      data-id="<%= t.id_torneo %>"
                      data-nombre="<%= t.nombre_torneo %>"
                      data-portada="<%= t.portada || '' %>"
                      onclick="abrirModalPersonalizarTorneo(this)">
                <i class="bi bi-image"></i> Personalizar
              </button>
            <% } %>
          </li>
        <% }); %>
      </ul>
      <% if (selectedTorneo) { %>
        <p class="text-white">Torneo seleccionado: <%= torneo.nombre_torneo %> (<%= torneo.temporada %>)</p>
        <% if (torneo.descripcion) { %>
          <p class="text-muted"><%= torneo.descripcion %></p>
        <% } %>
      <% } else { %>
        <p class="text-muted">Seleccione un torneo para ver detalles.</p>
      <% } %>
    </div>


    
    <!-- Grupos -->
    <!-- Grupos -->
<div class="tab-pane fade <%= (rol_id == 3 || rol_id == 99) ? 'show active' : '' %>" 
     id="grupos" role="tabpanel">
  <h3 class="text-white">Grupos del Torneo</h3>

  <!-- Crear grupo -->
  <form action="/grupos/crear" method="POST" class="mb-3">
    <div class="input-group">
      <input type="text" name="nombre_grupo" class="form-control text-uppercase"
             placeholder="Nuevo grupo" required
             oninput="this.value = this.value.toUpperCase()">
      <input type="hidden" name="id_torneo" value="<%= torneo.id_torneo %>">
      <button type="submit" class="btn btn-success">Agregar Grupo</button>
    </div>
  </form>

  <% if (grupos && grupos.length > 0) { %>
    <div class="row">
      <% grupos.forEach(grupo => { %>
        <div class="col-md-6 mb-4">
          <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
              <strong><%= grupo.nombre_grupo %></strong>
              <% if (grupo.Equipos && grupo.Equipos.length > 0) { %>
                <form action="/grupos/eliminar/<%= grupo.id_grupo %>" method="POST"
                      onsubmit="return confirm('¿Seguro que quiere eliminar? Este grupo contiene equipos');">
                  <button type="submit" class="btn btn-sm btn-danger">✖</button>
                </form>
              <% } else { %>
                <form action="/grupos/eliminar/<%= grupo.id_grupo %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-danger">✖</button>
                </form>
              <% } %>
            </div>

            <div class="card-body">
              <!-- Mostrar nombre sin edición -->
              <p class="fw-bold">Nombre personalizado: <%= grupo.nombre_grupo %></p>

              <% if (grupo.Equipos && grupo.Equipos.length > 0) { %>
                <h6>Equipos en este grupo:</h6>
                <ul class="list-group">
                  <% grupo.Equipos.forEach(equipo => { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center 
                               <%= !equipo.estado ? 'text-muted bg-light' : '' %>">
                      <span><%= equipo.nombre %></span>
                      <div class="btn-group">
                        <form action="/equipos/eliminar/<%= equipo.id_equipo %>" method="POST" style="display:inline;">
                          <input type="hidden" name="redirect_hash" value="#grupos">
                          <button type="submit" class="btn btn-sm btn-danger">✖</button>
                        </form>
                      </div>
                      <% if (!equipo.estado) { %>
                        <small class="badge text-bg-secondary">Equipo inactivo - deshabilitada</small>
                      <% } %>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="text-muted">No hay equipos asignados a este grupo.</p>
              <% } %>

              <% if (grupo.movimientos_salida && grupo.movimientos_salida.length > 0) { %>
                <div class="mt-2">
                  <% grupo.movimientos_salida.forEach(mov => { %>
                    <div class="alert alert-warning py-1 px-2 mb-1">
                      <strong><%= mov.Equipo ? mov.Equipo.nombre : 'Equipo' %></strong>
                      <strong>Pasó a otro grupo/fase</strong>
                      <% if (mov.GrupoDestino) { %>
                        <small class="text-muted">(<%= mov.GrupoDestino.nombre_grupo %>)</small>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <!-- Agregar equipo -->
              <form action="/equipos/crear" method="POST" class="mt-2 form-agregar-equipo">
                <div class="input-group">
                  <input type="text" name="nombre_equipo" class="form-control text-uppercase" 
                         placeholder="Nuevo equipo" required 
                         oninput="this.value = this.value.toUpperCase()">
                  <input type="hidden" name="id_grupo" value="<%= grupo.id_grupo %>">
                  <input type="hidden" name="id_torneo" value="<%= torneo.id_torneo %>">
                  <button type="submit" class="btn btn-success">Agregar</button>
                </div>
              </form>

              <!-- Botón para sortear encuentros -->
              <% if (grupo.encuentros_sorteados) { %>
                <button class="btn btn-secondary mt-3" disabled>
                  <i class="bi bi-lock-fill"></i> Sortear Encuentros
                </button>
                <div class="mt-2 small text-warning">Encuentros ya sorteados</div>
              <% } else if (grupo.Equipos && grupo.Equipos.length > 1) { %>
                <button class="btn btn-primary mt-3 abrir-sorteo-btn" 
                        data-bs-toggle="modal" 
                        data-bs-target="#modalSorteoFase1"
                        data-id-grupo="<%= grupo.id_grupo %>"
                        data-num-equipos="<%= grupo.Equipos.length %>"
                        data-id-torneo="<%= torneo.id_torneo %>">
                  <i class="fas fa-shuffle"></i> Sortear Encuentros
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-muted">No hay grupos creados aún para este torneo.</p>
  <% } %>

  <!-- ============================================ -->
  <!-- MODAL FASE 1: CONFIRMACIÓN INICIAL -->
  <!-- ============================================ -->
  <div class="modal fade" id="modalSorteoFase1" tabindex="-1" role="dialog" aria-labelledby="modalLabel1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalLabel1">
            <i class="fas fa-shuffle"></i> Sortear Encuentros
          </h5>
          <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <p class="lead">¿Desea sortear los equipos de este grupo?</p>
          <p class="text-muted" id="grupoNombreInfo"></p>
          <div class="alert alert-info" role="alert">
            <i class="fas fa-lightbulb"></i>
            <strong>Total de equipos:</strong> <span id="totalEquiposInfo">-</span>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-times"></i> Cancelar
          </button>
          <button type="button" class="btn btn-primary" onclick="abrirModalFase2()">
            <i class="fas fa-arrow-right"></i> Continuar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MODAL FASE 2: CONFIGURACIÓN DEL SORTEO -->
  <!-- ============================================ -->
  <div class="modal fade" id="modalSorteoFase2" tabindex="-1" role="dialog" aria-labelledby="modalLabel2" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalLabel2">
            <i class="fas fa-cog"></i> Configurar Sorteo
          </h5>
          <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="formSorteo">
            <!-- Tipo de encuentro -->
            <div class="form-group">
              <label for="tipoEncuentro" class="font-weight-bold">
                <i class="fas fa-question-circle"></i> Tipo de encuentro:
              </label>
              <div class="custom-control custom-radio mb-2">
                <input 
                  type="radio" 
                  id="radioSimple" 
                  name="tipo" 
                  value="simple" 
                  class="custom-control-input" 
                  checked 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioSimple">
                  <strong>Simple</strong> - Cada equipo juega una sola vez contra cada otro
                </label>
              </div>
              <div class="custom-control custom-radio mb-3">
                <input 
                  type="radio" 
                  id="radioIdaVuelta" 
                  name="tipo" 
                  value="ida_vuelta" 
                  class="custom-control-input" 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioIdaVuelta">
                  <strong>Ida y Vuelta</strong> - Cada equipo juega dos veces contra cada otro
                </label>
              </div>
              <div class="custom-control custom-radio mb-3">
                <input 
                  type="radio" 
                  id="radioFijo" 
                  name="tipo" 
                  value="fijo" 
                  class="custom-control-input" 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioFijo">
                  <strong>Fijo</strong> - Especificar número de fechas manualmente
                </label>
              </div>
            </div>

            <!-- Campo para número de fechas (solo visible cuando es fijo) -->
            <div class="form-group" id="grupNumFechas" style="display: none;">
              <label for="numFechas" class="font-weight-bold">
                <i class="fas fa-calendar-alt"></i> Número de fechas:
              </label>
              <input 
                type="number" 
                id="numFechas" 
                name="numFechas" 
                class="form-control" 
                min="1" 
                max="50" 
                placeholder="Ej: 3, 5, 10"
                oninput="actualizarValidacion()"
              >
              <small class="text-muted d-block mt-1" id="textNumFechasInfo"></small>
            </div>

            <!-- Validación de fechas -->
            <div id="alertaValidacion" class="alert mt-3" style="display: none;" role="alert"></div>

            <!-- Resumen estimado -->
            <div class="card bg-light mt-3">
              <div class="card-body">
                <h6 class="card-title">
                  <i class="fas fa-chart-bar"></i> Resumen:
                </h6>
                <ul class="list-unstyled small">
                  <li>
                    <strong>Equipos en el grupo:</strong> 
                    <span id="resumenEquipos">-</span>
                  </li>
                  <li>
                    <strong>Partidos por equipo (estimado):</strong> 
                    <span id="resumenPartidosEquipo">-</span>
                  </li>
                  <li>
                    <strong>Total de partidos (estimado):</strong> 
                    <span id="resumenTotalPartidos">-</span>
                  </li>
                  <li>
                    <strong>Número de fechas:</strong> 
                    <span id="resumenFechas">-</span>
                  </li>
                </ul>
              </div>
            </div>
          </form>
          </div>
          <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-arrow-left"></i> Atrás
          </button>
          <button type="button" class="btn btn-success" id="btnConfirmarSorteo" onclick="confirmarSorteo()">
            <i class="fas fa-check"></i> Confirmar Sorteo
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Variables globales para el modal
let grupoActual = null;
let numEquiposActual = 0;
let torneoActual = null;
const equiposPorGrupo = <%- JSON.stringify((equipos || []).reduce((acc, equipo) => {
  const key = String(equipo.id_grupo || '');
  if (!acc[key]) acc[key] = [];
  acc[key].push({
    id_equipo: equipo.id_equipo,
    nombre: equipo.nombre,
    id_grupo: equipo.id_grupo,
    nombre_grupo: equipo.nombre_grupo || 'Sin grupo'
  });
  return acc;
}, {})) %>;
let finanzasResumen = <%- JSON.stringify(finanzasResumen || []).replace(/</g, '\\u003c') %>;

function formatearFechaInput(fecha) {
  if (!fecha) return '';
  return String(fecha).slice(0, 10);
}

function formatoMontoFinanzas(valor) {
  const numero = Number(valor || 0);
  return numero.toLocaleString('es-PY', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  });
}

function formatoFechaFinanzas(fecha) {
  if (!fecha) return '-';
  const valor = String(fecha).slice(0, 10);
  return valor ? valor.split('-').reverse().join('/') : '-';
}

function etiquetaFechaFinanzas(movimiento) {
  const numero = movimiento?.numero_fecha || '-';
  const fechaCalendario = formatoFechaFinanzas(movimiento?.fecha_calendario || movimiento?.fecha_registro);
  const grupo = movimiento?.nombre_grupo_display || movimiento?.nombre_grupo || '';
  return `
    <strong class="d-block">Fecha ${escaparHtml(numero)}</strong>
    ${grupo ? `<span class="badge text-bg-secondary">${escaparHtml(grupo)}</span>` : ''}
    <small class="text-muted">${fechaCalendario}</small>
  `;
}

function renderFinanzasResumen() {
  const tbody = document.getElementById('finanzasResumenTbody');
  if (!tbody) return;

  if (!finanzasResumen.length) {
    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No hay equipos cargados para este torneo.</td></tr>';
    return;
  }

  tbody.innerHTML = finanzasResumen.map(equipo => `
    <tr data-finanzas-equipo-id="${escaparHtml(equipo.id_equipo)}">
      <td>
        <div class="d-flex align-items-center gap-2">
          <img src="${escaparHtml(equipo.icono || '/images/default_team.png')}" alt="" style="width:28px;height:28px;object-fit:cover;border-radius:50%;">
          <strong class="text-dark">${escaparHtml(equipo.nombre || '')}</strong>
        </div>
      </td>
      <td class="text-dark">${escaparHtml(equipo.nombre_grupo || 'Sin grupo')}</td>
      <td class="text-center finanzas-estado-cell">
        ${equipo.adeuda ? '<span class="fw-bold text-danger" title="Equipo con deuda">‼️‼️</span>' : '<span class="badge text-bg-success">Al dia</span>'}
      </td>
      <td class="text-end fw-bold finanzas-admin-only finanzas-saldo-cell ${equipo.adeuda ? 'text-danger' : 'text-dark'}">${formatoMontoFinanzas(equipo.saldo_actual)}</td>
      <td class="text-end finanzas-admin-only">
        <button type="button" class="btn btn-sm btn-outline-dark" onclick="abrirDetalleFinanzas('${escaparHtml(equipo.id_equipo)}')">Detalles</button>
      </td>
    </tr>
  `).join('');
}

async function sincronizarFinanzasDesdeServidor() {
  try {
    const response = await fetch(`/torneos/<%= torneo.id_torneo %>/finanzas/resumen`, {
      headers: { 'Accept': 'application/json' }
    });
    const data = await response.json();
    if (!data.success) return;
    finanzasResumen = data.finanzasResumen || [];
    renderFinanzasResumen();
  } catch (error) {
    console.error('No se pudo actualizar finanzas:', error);
  }
}

function abrirDetalleFinanzas(idEquipo) {
  const equipo = finanzasResumen.find(item => String(item.id_equipo) === String(idEquipo));
  if (!equipo) return;

  document.getElementById('finanzasDetalleTitulo').textContent = `Detalle financiero - ${equipo.nombre}`;
  document.getElementById('finanzasDetalleSubtitulo').textContent = `${equipo.nombre_grupo || 'Sin grupo'} · Saldo actual: ${formatoMontoFinanzas(equipo.saldo_actual)}`;

  const tbody = document.getElementById('finanzasDetalleTbody');
  tbody.innerHTML = '';

  if (!equipo.movimientos || equipo.movimientos.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Sin movimientos financieros registrados.</td></tr>';
  } else {
    equipo.movimientos.forEach(movimiento => {
      const fila = document.createElement('tr');
      fila.innerHTML = `
