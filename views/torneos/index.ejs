                              data-nombre="<%= u.nombre || '' %>"
                              data-documento="<%= u.documento || '' %>"
                              data-correo="<%= u.correo || '' %>">
                        <i class="bi bi-pencil-square"></i> Editar datos
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

  <% if (rol_id == 3 || rol_id == 99) { %>
  <div class="tab-pane fade" id="auditoria">
    <div class="p-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h3 class="text-white mb-0">Auditoría</h3>
          <small class="text-white-50">
            <%= (contextoAuditoria || {}).entidad || '' %> · <%= (contextoAuditoria || {}).torneo || '' %>
          </small>
        </div>
        <span class="badge text-bg-light">Últimos <%= (auditoria || []).length %> movimientos</span>
      </div>

