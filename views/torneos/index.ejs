                <td><%= registro.pantalla || '-' %></td>
                <td><%= registro.afectado || '-' %></td>
                <td>
                  <span class="badge <%= registro.accion === 'DELETE' ? 'text-bg-danger' : (registro.accion === 'UPDATE' ? 'text-bg-primary' : (registro.accion === 'INGRESO' ? 'text-bg-dark' : 'text-bg-success')) %>">
                    <%= registro.accion %>
                  </span>
                </td>
                <td>
                  <strong><%= registro.usuario_display || 'Sistema' %></strong>
                  <% if (registro.usuario_documento_display) { %>
                    <br><small class="text-muted"><%= registro.usuario_documento_display %></small>
                  <% } %>
                </td>
                <td><%= registro.detalle_legible || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

