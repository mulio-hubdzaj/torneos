    const button = form.querySelector('.guardar-horarios-btn');
    const campos = ['fecha_comun', 'hora_inicial', 'intervalo_minutos']
      .map(nombre => form.querySelector(`[name="${nombre}"]`))
      .filter(Boolean);
    const actualizarEstadoBoton = () => {
      const fechaComun = form.querySelector('[name="fecha_comun"]')?.value || '';
      const horaInicial = form.querySelector('[name="hora_inicial"]')?.value || '';
