const estadoPortadaAjuste = {
  url: '',
  x: 0,
  y: 0,
  zoom: 1,
  dragging: false,
  startX: 0,
  startY: 0,
  baseX: 0,
  baseY: 0
};

function aplicarTransformPortada() {
  const img = document.getElementById('portadaAjusteImagen');
  if (!img) return;
  img.style.transform = `translate(${estadoPortadaAjuste.x}px, ${estadoPortadaAjuste.y}px) scale(${estadoPortadaAjuste.zoom})`;
}

function reiniciarAjustePortada() {
  const bloque = document.getElementById('portadaAjuste');
  const img = document.getElementById('portadaAjusteImagen');
  const hidden = document.getElementById('portadaAjustada');
  const zoom = document.getElementById('portadaZoom');

  if (estadoPortadaAjuste.url) URL.revokeObjectURL(estadoPortadaAjuste.url);
  estadoPortadaAjuste.url = '';
  estadoPortadaAjuste.x = 0;
  estadoPortadaAjuste.y = 0;
  estadoPortadaAjuste.zoom = 1;

  if (bloque) bloque.classList.remove('activo');
  if (img) img.removeAttribute('src');
  if (hidden) hidden.value = '';
  if (zoom) zoom.value = '1';
  aplicarTransformPortada();
}

function prepararCanvasPortada() {
  const img = document.getElementById('portadaAjusteImagen');
  const hidden = document.getElementById('portadaAjustada');
  if (!img || !hidden || !img.naturalWidth || !img.naturalHeight) return true;

  const canvas = document.createElement('canvas');
  const canvasWidth = 1600;
  const canvasHeight = Math.max(120, Math.round(canvasWidth * (img.naturalHeight / img.naturalWidth)));
  canvas.width = canvasWidth;
  canvas.height = canvasHeight;
  const ctx = canvas.getContext('2d');
  const marco = document.getElementById('portadaAjusteMarco');
  const rect = marco.getBoundingClientRect();
  const baseScale = canvas.width / img.naturalWidth;
  const displayToCanvasX = canvas.width / rect.width;
  const displayToCanvasY = rect.height ? canvas.height / rect.height : displayToCanvasX;
  const drawWidth = img.naturalWidth * baseScale * estadoPortadaAjuste.zoom;
  const drawHeight = img.naturalHeight * baseScale * estadoPortadaAjuste.zoom;
  const drawX = (canvas.width - drawWidth) / 2 + (estadoPortadaAjuste.x * displayToCanvasX);
  const drawY = (canvas.height - drawHeight) / 2 + (estadoPortadaAjuste.y * displayToCanvasY);

  ctx.fillStyle = '#111827';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.drawImage(img, drawX, drawY, drawWidth, drawHeight);
  hidden.value = canvas.toDataURL('image/jpeg', 0.9);
  return true;
}

document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('portadaTorneo');
  const bloque = document.getElementById('portadaAjuste');
  const img = document.getElementById('portadaAjusteImagen');
  const marco = document.getElementById('portadaAjusteMarco');
  const zoom = document.getElementById('portadaZoom');
  const form = document.getElementById('formPortadaTorneo');

  input?.addEventListener('change', () => {
    const file = input.files?.[0];
    reiniciarAjustePortada();
    if (!file || !file.type.startsWith('image/')) return;
    estadoPortadaAjuste.url = URL.createObjectURL(file);
    img.src = estadoPortadaAjuste.url;
    bloque.classList.add('activo');
  });

  zoom?.addEventListener('input', () => {
    estadoPortadaAjuste.zoom = Number(zoom.value || 1);
    aplicarTransformPortada();
  });

  marco?.addEventListener('pointerdown', event => {
    estadoPortadaAjuste.dragging = true;
    estadoPortadaAjuste.startX = event.clientX;
    estadoPortadaAjuste.startY = event.clientY;
    estadoPortadaAjuste.baseX = estadoPortadaAjuste.x;
    estadoPortadaAjuste.baseY = estadoPortadaAjuste.y;
    marco.setPointerCapture(event.pointerId);
  });

  marco?.addEventListener('pointermove', event => {
    if (!estadoPortadaAjuste.dragging) return;
    estadoPortadaAjuste.x = estadoPortadaAjuste.baseX + (event.clientX - estadoPortadaAjuste.startX);
    estadoPortadaAjuste.y = estadoPortadaAjuste.baseY + (event.clientY - estadoPortadaAjuste.startY);
    aplicarTransformPortada();
  });

  marco?.addEventListener('pointerup', () => {
    estadoPortadaAjuste.dragging = false;
  });

  form?.addEventListener('submit', () => {
    prepararCanvasPortada();
  });
});

function actualizarOpcionesCruceManual() {
  const selectGrupoEquipoA = document.getElementById('manualGrupoEquipoA');
  const selectGrupoEquipoB = document.getElementById('manualGrupoEquipoB');
  const selectEquipoA = document.getElementById('manualEquipoA');
  const selectEquipoB = document.getElementById('manualEquipoB');

  if (!selectGrupoEquipoA || !selectGrupoEquipoB || !selectEquipoA || !selectEquipoB) return;

  const equiposGrupoA = obtenerEquiposGrupo(selectGrupoEquipoA.value);
  const equiposGrupoB = obtenerEquiposGrupo(selectGrupoEquipoB.value);
  const equipoASeleccionado = selectEquipoA.value;
  const equipoBSeleccionado = selectEquipoB.value;

  const renderOptions = (equipos, seleccionExcluida) => {
    return ['<option value="">Seleccione un equipo</option>']
      .concat(
        equipos
          .filter(equipo => String(equipo.id_equipo) !== String(seleccionExcluida))
          .map(equipo => `<option value="${equipo.id_equipo}">${equipo.nombre}</option>`)
      )
      .join('');
  };

  selectEquipoA.innerHTML = renderOptions(equiposGrupoA, equipoBSeleccionado);
  selectEquipoB.innerHTML = renderOptions(equiposGrupoB, equipoASeleccionado);

  if (equipoASeleccionado && equiposGrupoA.some(e => String(e.id_equipo) === String(equipoASeleccionado))) {
    selectEquipoA.value = equipoASeleccionado;
  }
  if (equipoBSeleccionado && equiposGrupoB.some(e => String(e.id_equipo) === String(equipoBSeleccionado))) {
    selectEquipoB.value = equipoBSeleccionado;
  }
}

// Validar fechas según cantidad de equipos
function validarFechas(numEquipos, fechasIngresadas) {
  const maxSimple = numEquipos % 2 === 1 ? numEquipos : numEquipos - 1;
  const maxIdaVuelta = maxSimple * 2;
  const equilibrado = numEquipos % 2 === 0 || fechasIngresadas % numEquipos === 0;

  let valido = false;
  let mensaje = "";
  let tipo = "";

  if (fechasIngresadas > 0 && equilibrado) {
    valido = true;
    tipo = "success";
    mensaje = `✅ Excelente! Con ${fechasIngresadas} fechas, todos los equipos juegan ${fechasIngresadas} encuentros de forma balanceada.`;
  } else if (fechasIngresadas === maxIdaVuelta && equilibrado) {
    valido = true;
    tipo = "success";
    mensaje = `✅ Excelente! Con ${fechasIngresadas} fechas, todos los equipos juegan ida y vuelta (${maxIdaVuelta} encuentros) de forma balanceada.`;
  } else if (fechasIngresadas > 0) {
    valido = true;
    tipo = "danger";
    mensaje = `⚠️ Atención: con ${numEquipos} equipos y ${fechasIngresadas} fechas, el torneo quedará disparejo. 
    Se sugiere ${maxSimple} (simple) o ${maxIdaVuelta} (ida/vuelta). El sistema generará encuentros aleatorios.`;
  } else {
    valido = false;
    tipo = "danger";
    mensaje = `❌ Error: el número de fechas debe ser mayor a 0.`;
  }

  return { valido, mensaje, tipo };
}

