  if (!selectGrupo || !selectEquipoA || !selectEquipoB) return;

  selectGrupo.value = grupoId || '';
  actualizarOpcionesCruceManual();
}

function abrirModalCruceManual(numeroFecha, grupoId = '') {
  const inputFecha = document.getElementById('manualNumeroFecha');
  const selectGrupo = document.getElementById('manualGrupoId');
  const redirectInput = document.getElementById('manualRedirectUrl');
  if (inputFecha) inputFecha.value = numeroFecha;
  if (redirectInput) {
    const params = new URLSearchParams(window.location.search);
    params.set('fecha', numeroFecha);
    redirectInput.value = `${window.location.pathname}?${params.toString()}#partidos`;
  }
  if (selectGrupo) {
    if (grupoId) {
      selectGrupo.value = grupoId;
      poblarCruceManualGrupo(grupoId);
    } else if (selectGrupo.options.length > 0) {
      const primerGrupo = selectGrupo.options[0].value || selectGrupo.options[1]?.value || '';
      selectGrupo.value = primerGrupo;
      poblarCruceManualGrupo(primerGrupo);
    }
  }
  const modal = new bootstrap.Modal(document.getElementById('modalCruceManual'));
  modal.show();
}

// Cambiar estado de un partido
async function cambiarEstado(selectElement) {
  const partidoId = selectElement.dataset.id;
  const nuevoEstado = selectElement.value;

  try {
    const response = await fetch(`/partidos/${partidoId}/estado`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        partido_id: partidoId,
        nuevoEstado: nuevoEstado
      })
    });

    const data = await response.json();
    if (!data.success) {
      alert('Error: ' + data.message);
    } else {
      const marcador = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a-id]`);
      if (marcador) marcador.dataset.estado = nuevoEstado;
      recalcularEstadisticasCliente();
    }
  } catch (error) {
    console.error('Error:', error);
  }
}

// Guardar marcador
async function guardarMarcador() {
  const partidoId = document.getElementById('marcadorPartidoId').value;
  const golesA = document.getElementById('marcadorGolesA').value;
  const golesB = document.getElementById('marcadorGolesB').value;

  if (golesA === '' || golesB === '') {
    alert('Por favor ingresa ambos marcadores.');
    return;
  }

  if (!marcadorValido(golesA) || !marcadorValido(golesB)) {
    alert('El marcador debe ser un numero entero entre 0 y 99, sin negativos ni ceros a la izquierda.');
    return;
  }

  try {
    const response = await fetch(`/partidos/${partidoId}/marcador`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        partido_id: partidoId,
        goles_a: golesA,
        goles_b: golesB,
        estado: 'finalizado'
      })
    });

    const data = await response.json();
    if (data.success) {
      const resultCell = document.querySelector(`td[data-id="${partidoId}"][data-equipo-a]`);
      if (resultCell) {
        resultCell.setAttribute('data-goles-a', golesA);
        resultCell.setAttribute('data-goles-b', golesB);
        resultCell.setAttribute('data-estado', 'finalizado');
        const span = resultCell.querySelector('span');
        if (span) {
          span.textContent = `${golesA} - ${golesB}`;
        }
      }
      const selectEstado = document.querySelector(`.estado-select[data-id="${partidoId}"]`);
      if (selectEstado) {
        selectEstado.value = 'finalizado';
      }
      actualizarAccionesPartido(partidoId, 'finalizado');
      recalcularEstadisticasCliente();
      cerrarModalBootstrapSeguro('modalEditarMarcador');
    } else {
      alert('Error: ' + data.message);
    }
  } catch (error) {
    console.error('Error:', error);
    alert('Error al actualizar marcador');
  }
}

async function guardarEstadoPartido(pidoId, nuevoEstado) {
  try {
    const res = await fetch(`/partidos/${pidoId}/estado`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ partido_id: pidoId, nuevoEstado: nuevoEstado })
    });
    const data = await res.json();
    if (data.success) {
      const selectEl = document.querySelector(`.estado-select[data-id="${pidoId}"]`);
      if (selectEl) selectEl.value = nuevoEstado;
      const marcador = document.querySelector(`td[data-id="${pidoId}"][data-equipo-a-id]`);
      if (marcador) marcador.dataset.estado = nuevoEstado;
      actualizarAccionesPartido(pidoId, nuevoEstado);
      recalcularEstadisticasCliente();
      return true;
    } else {
      alert('Error: ' + data.message);
      return false;
    }
  } catch (e) {
    console.error(e);
    return false;
  }
}

