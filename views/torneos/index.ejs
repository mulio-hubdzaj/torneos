        <% } %>
      </ul>

      <!-- Botones de navegación a la derecha -->
      <div class="d-flex ms-auto app-nav-actions" id="appNavActions">
        <% if (!esVistaPublica && (rol_id == 3 || rol_id == 99)) { %>
          <a href="/entidad/gestionar/<%= entityId %>" class="btn btn-success btn-sm me-2">Ir a Torneos</a>
        <% } %>
        <% if (!esVistaPublica && rol_id == 99) { %>
          <a href="/admin" class="btn btn-success btn-sm me-2">Ir a Entidades</a>
        <% } %>
        <% if (esVistaPublica) { %>
          <a href="/login" class="btn btn-success btn-sm">Iniciar sesion</a>
        <% } else { %>
          <a href="/logout" class="btn btn-success btn-sm">Cerrar sesión</a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- Bloque de alertas arriba -->
 <% if (messages.danger && messages.danger.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.danger[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.success && messages.success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.success[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.info && messages.info.length > 0) { %>
  <div class="alert alert-info alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.info[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (messages.warning && messages.warning.length > 0) { %>
  <div class="alert alert-warning alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3"
       style="z-index:1050; max-width:600px;" role="alert">
    <%= messages.warning[0] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>


  <!-- Contenido de pestañas -->
  <div class="container mt-5 tab-content">

  <!-- TORNEOS -->

    <div class="tab-pane fade<%= paneActiva('torneos') %>"
     id="torneos" role="tabpanel">

      <h3 class="text-white">Selección de Torneos</h3>
      <ul class="list-group mb-3">
        <li class="list-group-item fw-bold text-muted">Todos los torneos</li>
        <% torneos.forEach(function(t) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center <%= (selectedTorneo == t.id_torneo ? 'active' : '') %>">
            <a href="<%= esVistaPublica ? '/publico/torneo/' + t.id_torneo : '/torneos/gestionar/' + t.id_torneo %>" class="text-decoration-none <%= (selectedTorneo == t.id_torneo ? 'text-white' : 'text-dark') %>">
              <strong><%= t.nombre_torneo %></strong> - <%= t.temporada %>
            </a>
            <% if (!esVistaPublica && (rol_id == 3 || rol_id == 99)) { %>
              <button type="button"
                      class="btn btn-sm <%= (selectedTorneo == t.id_torneo ? 'btn-light' : 'btn-outline-primary') %>"
                      data-id="<%= t.id_torneo %>"
                      data-nombre="<%= t.nombre_torneo %>"
                      data-portada="<%= t.portada || '' %>"
                      onclick="abrirModalPersonalizarTorneo(this)">
                <i class="bi bi-image"></i> Personalizar
              </button>
            <% } %>
          </li>
        <% }); %>
      </ul>
      <% if (selectedTorneo) { %>
        <p class="text-white">Torneo seleccionado: <%= torneo.nombre_torneo %> (<%= torneo.temporada %>)</p>
        <% if (torneo.descripcion) { %>
          <p class="text-muted"><%= torneo.descripcion %></p>
        <% } %>
        <%
          const dashboardTablaTop = ((dashboardInicio || {}).tablaTop || []);
          const dashboardGoleadoresTop = ((dashboardInicio || {}).goleadoresTop || []);
          const dashboardPartidosEnCurso = ((dashboardInicio || {}).partidosEnCurso || []);
          const dashboardUltimosResultados = ((dashboardInicio || {}).ultimosResultados || []);
          const dashboardProximosPartidos = ((dashboardInicio || {}).proximosPartidos || []);
          const dashboardTieneDatos =
            dashboardTablaTop.length ||
            dashboardGoleadoresTop.length ||
            dashboardPartidosEnCurso.length ||
            dashboardUltimosResultados.length ||
            dashboardProximosPartidos.length;
        %>
        <div class="row g-3 mt-1">
          <% if (dashboardTablaTop.length) { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong>Tabla de posiciones</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#estadisticas" data-target-subtab="#estadisticasTablaPosiciones">Ver</button>
              </div>
              <div class="table-responsive bg-white dashboard-scroll-area">
                <table class="table table-sm align-middle mb-0">
                  <tbody>
                    <% dashboardTablaTop.forEach((item, index) => { %>
                      <tr>
                        <td style="width:40px;"><strong><%= index + 1 %></strong></td>
                        <td>
                          <img src="<%= item.icono || '/images/default_team.png' %>" alt="" style="width:24px;height:24px;object-fit:contain;">
                          <strong><%= item.nombre %></strong>
                        </td>
                        <td class="text-end"><strong><%= item.puntos %> pts</strong></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <% } %>

          <% if (dashboardGoleadoresTop.length) { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong>Goleadores</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#estadisticas" data-target-subtab="#estadisticasRankingGoles">Ver</button>
              </div>
              <div class="table-responsive bg-white dashboard-scroll-area">
                <table class="table table-sm align-middle mb-0">
                  <tbody>
                    <% dashboardGoleadoresTop.forEach(jugador => { %>
                      <tr>
                        <td><strong><%= [jugador.nombre, jugador.apellido].filter(Boolean).join(' ') %></strong></td>
                        <td><small><%= jugador.equipo || 'Libre' %></small></td>
                        <td class="text-end"><strong><%= jugador.goles %></strong></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          <% } %>

          <% if (dashboardPartidosEnCurso.length) { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0 dashboard-en-curso-card">
              <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <strong>En curso</strong>
                <button type="button" class="btn btn-sm btn-outline-dark dashboard-tab-link" data-target-tab="#partidos">Fixture</button>
              </div>
              <div class="list-group list-group-flush dashboard-scroll-area">
                <% dashboardPartidosEnCurso.forEach(partido => { %>
                  <div class="list-group-item" data-dashboard-en-curso-partido="<%= partido.id_partido %>">
                    <div class="dashboard-en-curso-header">
                      <div class="dashboard-en-curso-main">
                        <strong class="d-block dashboard-score-line">
                          <span class="dashboard-score-team"><%= partido.nombre_equipo_a || 'Equipo A' %></span>
                          <span class="dashboard-score-box"><%= partido.goles_a ?? 0 %> - <%= partido.goles_b ?? 0 %></span>
                          <span class="dashboard-score-team"><%= partido.nombre_equipo_b || 'Equipo B' %></span>
                        </strong>
                        <small class="text-muted">Fecha <%= partido.numero_fecha || '-' %><% if (partido.fecha_formateada && partido.fecha_formateada !== '-') { %> | <%= partido.fecha_formateada %><% } %><% if (partido.hora && partido.hora !== '-') { %> | <%= partido.hora %><% } %></small>
                      </div>
                      <span class="badge estado-badge-en-curso">En curso</span>
                    </div>
                    <small>
                      Fecha <%= partido.numero_fecha || '-' %> Â· <%= partido.fecha_formateada || '-' %> Â· <%= partido.hora || '-' %>
                    </small>
                    <div class="dashboard-live-stats mt-2" data-dashboard-en-curso-stats="<%= partido.id_partido %>">
                      <% const eventosEnCurso = (partido.estadisticas || []).filter(j => Number(j.goles || 0) > 0 || Number(j.tarjetas_amarillas || 0) > 0 || Number(j.tarjetas_rojas || 0) > 0); %>
                      <% const eventosEquipoA = eventosEnCurso.filter(j => String(j.id_equipo || '') === String(partido.equipo_a || '')); %>
                      <% const eventosEquipoB = eventosEnCurso.filter(j => String(j.id_equipo || '') === String(partido.equipo_b || '')); %>
                      <% if (eventosEnCurso.length) { %>
                        <div class="dashboard-live-columns">
                          <div class="dashboard-live-team">
                            <div class="dashboard-live-team-title"><%= partido.nombre_equipo_a || 'Equipo A' %></div>
                            <% if (eventosEquipoA.length) { %>
                              <% eventosEquipoA.forEach(jugador => { %>
                                <div class="dashboard-live-stat-item">
                                  <span><%= [jugador.nombre, jugador.apellido].filter(Boolean).join(' ') || 'Jugador' %></span>
                                  <span class="dashboard-live-eventos">
                                    <% if (Number(jugador.goles || 0) > 0) { %>
                                      <span><%= Number(jugador.goles || 0) %> <%= Number(jugador.goles || 0) === 1 ? 'gol' : 'goles' %></span>
                                    <% } %>
                                    <% for (let i = 0; i < Number(jugador.tarjetas_amarillas || 0); i++) { %>
                                      <span class="tarjeta-mini tarjeta-mini-amarilla" title="Tarjeta amarilla"></span>
                                    <% } %>
                                    <% for (let i = 0; i < Number(jugador.tarjetas_rojas || 0); i++) { %>
                                      <span class="tarjeta-mini tarjeta-mini-roja" title="Tarjeta roja"></span>
                                    <% } %>
                                  </span>
                                </div>
                              <% }) %>
                            <% } else { %>
                              <small class="text-muted">Sin eventos.</small>
                            <% } %>
                          </div>
                          <div class="dashboard-live-team">
                            <div class="dashboard-live-team-title"><%= partido.nombre_equipo_b || 'Equipo B' %></div>
                            <% if (eventosEquipoB.length) { %>
                              <% eventosEquipoB.forEach(jugador => { %>
                                <div class="dashboard-live-stat-item">
                                  <span><%= [jugador.nombre, jugador.apellido].filter(Boolean).join(' ') || 'Jugador' %></span>
                                  <span class="dashboard-live-eventos">
                                    <% if (Number(jugador.goles || 0) > 0) { %>
                                      <span><%= Number(jugador.goles || 0) %> <%= Number(jugador.goles || 0) === 1 ? 'gol' : 'goles' %></span>
                                    <% } %>
                                    <% for (let i = 0; i < Number(jugador.tarjetas_amarillas || 0); i++) { %>
                                      <span class="tarjeta-mini tarjeta-mini-amarilla" title="Tarjeta amarilla"></span>
                                    <% } %>
                                    <% for (let i = 0; i < Number(jugador.tarjetas_rojas || 0); i++) { %>
                                      <span class="tarjeta-mini tarjeta-mini-roja" title="Tarjeta roja"></span>
                                    <% } %>
                                  </span>
                                </div>
                              <% }) %>
                            <% } else { %>
                              <small class="text-muted">Sin eventos.</small>
                            <% } %>
                          </div>
                        </div>
                      <% } else { %>
                        <small class="text-muted">Sin goles ni tarjetas cargadas.</small>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <% if (dashboardUltimosResultados.length) { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong id="dashboardUltimosPartidos">Últimos resultados</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#partidos">Fixture</button>
              </div>
              <div class="list-group list-group-flush dashboard-scroll-area">
                <% dashboardUltimosResultados.forEach(partido => { %>
                  <div class="list-group-item d-flex justify-content-between align-items-start gap-2">
                    <span class="dashboard-match-title dashboard-match-score-line">
                      <span class="dashboard-match-team"><%= partido.nombre_equipo_a %></span>
                      <strong class="dashboard-match-score-box"><%= partido.goles_a %> - <%= partido.goles_b %></strong>
                      <span class="dashboard-match-team"><%= partido.nombre_equipo_b %></span>
                    </span>
                    <div class="dashboard-match-actions">
                      <button type="button"
                              class="btn btn-sm btn-outline-primary dashboard-match-stats-btn"
                              title="Ver estadisticas del encuentro"
                              aria-label="Ver estadisticas del encuentro"
                              onclick="abrirModalEstadisticasEncuentro(<%= partido.id_partido %>)">
                        <i class="bi bi-bar-chart-line"></i>
                      </button>
                      <small class="text-muted dashboard-match-date">Fecha <%= partido.numero_fecha || '-' %></small>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <% if (dashboardProximosPartidos.length) { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 border-0">
              <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <strong id="dashboardProximosEncuentros">Próximos encuentros</strong>
                <button type="button" class="btn btn-sm btn-outline-light dashboard-tab-link" data-target-tab="#partidos">Fixture</button>
              </div>
              <div class="list-group list-group-flush dashboard-scroll-area">
                <% dashboardProximosPartidos.forEach(partido => { %>
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                      <strong class="dashboard-match-title"><%= partido.nombre_equipo_a %> vs <%= partido.nombre_equipo_b %></strong>
                      <small class="text-muted dashboard-match-date">Fecha <%= partido.numero_fecha || '-' %></small>
                    </div>
                    <small>
                      <%= partido.fecha_formateada || '-' %> · <%= partido.hora || '-' %><%= partido.nombre_cancha ? ' · ' + partido.nombre_cancha : '' %>
                    </small>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>

          <% if (!dashboardTieneDatos) { %>
            <div class="col-12">
              <div class="alert alert-light border mb-0">Todavia no hay datos para mostrar en el resumen del torneo.</div>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <p class="text-muted">Seleccione un torneo para ver detalles.</p>
      <% } %>
    </div>


    
    <!-- Grupos -->
    <!-- Grupos -->
<div class="tab-pane fade<%= paneActiva('grupos') %>"
     id="grupos" role="tabpanel">
  <h3 class="text-white">Grupos del Torneo</h3>

  <!-- Crear grupo -->
  <form action="/grupos/crear" method="POST" class="mb-3">
    <div class="input-group">
      <input type="text" name="nombre_grupo" class="form-control text-uppercase"
             placeholder="Nuevo grupo" required
             oninput="this.value = this.value.toUpperCase()">
      <input type="hidden" name="id_torneo" value="<%= torneo.id_torneo %>">
      <button type="submit" class="btn btn-success">Agregar Grupo</button>
    </div>
  </form>

  <% const gruposDisponiblesCombinado = (grupos || []).filter(grupo => !grupo.encuentros_sorteados && grupo.Equipos && grupo.Equipos.length > 1); %>
  <% if (grupos && grupos.length > 0) { %>
    <% if (rol_id == 3 || rol_id == 99) { %>
      <div class="d-flex justify-content-center mb-3">
        <button type="button"
                class="btn btn-warning fw-bold"
                <%- gruposDisponiblesCombinado.length > 1 ? 'data-bs-toggle="modal" data-bs-target="#modalSorteoCombinado"' : 'disabled title="Debe haber al menos dos grupos sin sorteo y con equipos suficientes"' %>>
          <i class="bi bi-shuffle"></i> Sorteos combinados
        </button>
      </div>
    <% } %>
    <div class="row">
      <% grupos.forEach(grupo => { %>
        <div class="col-md-6 mb-4">
          <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
              <strong><%= grupo.nombre_grupo %></strong>
              <% if (true) { %>
                <form action="/grupos/eliminar/<%= grupo.id_grupo %>" method="POST"
                      class="form-confirmar-app"
                      data-confirm-title="Eliminar grupo"
                      data-confirm-message="Este grupo contiene equipos. ¿Seguro que quiere eliminarlo?"
                      data-confirm-accept="Sí, eliminar"
                      data-confirm-cancel="Cancelar">
                  <button type="submit" class="btn btn-sm btn-danger">✖</button>
                </form>
              <% } else if (false) { %>
                <form action="/grupos/eliminar/<%= grupo.id_grupo %>" method="POST">
                  <button type="submit" class="btn btn-sm btn-danger">✖</button>
                </form>
              <% } %>
            </div>

            <div class="card-body">
              <!-- Mostrar nombre sin edición -->
              <p class="fw-bold">Nombre personalizado: <%= grupo.nombre_grupo %></p>

              <% if (grupo.Equipos && grupo.Equipos.length > 0) { %>
                <h6>Equipos en este grupo:</h6>
                <ul class="list-group">
                  <% grupo.Equipos.forEach(equipo => { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center 
                               <%= !equipo.estado ? 'text-muted bg-light' : '' %>">
                      <span>
                        <%= equipo.nombre %>
                        <% if (equipo.cruce_manual) { %>
                          <span class="badge text-bg-warning ms-2">cruce manual</span>
                        <% } %>
                      </span>
                      <div class="btn-group">
                        <form action="/equipos/eliminar/<%= equipo.id_equipo %>" method="POST" style="display:inline;">
                          <input type="hidden" name="redirect_hash" value="#grupos">
                          <button type="submit" class="btn btn-sm btn-danger">✖</button>
                        </form>
                      </div>
                      <% if (!equipo.estado) { %>
                        <small class="badge text-bg-secondary">Equipo inactivo - deshabilitada</small>
                      <% } %>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="text-muted">No hay equipos asignados a este grupo.</p>
              <% } %>

              <% if (grupo.movimientos_salida && grupo.movimientos_salida.length > 0) { %>
                <div class="mt-2">
                  <% grupo.movimientos_salida.forEach(mov => { %>
                    <div class="alert alert-warning py-1 px-2 mb-1">
                      <strong><%= mov.Equipo ? mov.Equipo.nombre : 'Equipo' %></strong>
                      <strong>paso a siguiente grupo/fase</strong>
                      <% if (mov.GrupoDestino) { %>
                        <small class="text-muted">(<%= mov.GrupoDestino.nombre_grupo %>)</small>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <!-- Agregar equipo -->
              <form action="/equipos/crear" method="POST" class="mt-2 form-agregar-equipo">
                <div class="input-group">
                  <input type="text" name="nombre_equipo" class="form-control text-uppercase" 
                         data-grupo-equipo-input="<%= grupo.id_grupo %>"
                         placeholder="Nuevo equipo" required 
                         oninput="this.value = this.value.toUpperCase()">
                  <input type="hidden" name="id_grupo" value="<%= grupo.id_grupo %>">
                  <input type="hidden" name="id_torneo" value="<%= torneo.id_torneo %>">
                  <button type="submit" class="btn btn-success">Agregar</button>
                </div>
              </form>

              <% if (rol_id == 3 || rol_id == 99) { %>
                <% const grupoVisibleFixture = grupo.visible_fixture !== false; %>
                <form action="/grupos/fixture-visibilidad/<%= grupo.id_grupo %>"
                      method="POST"
                      class="mt-2 form-confirmar-app"
                      data-confirm-title="<%= grupoVisibleFixture ? 'Ocultar grupo del Fixture' : 'Mostrar grupo en Fixture' %>"
                      data-confirm-message="<%= grupoVisibleFixture ? 'El historico de este grupo seguira en dashboard y estadisticas, pero dejara de verse en Fixture. ¿Desea continuar?' : 'Este grupo volvera a verse en Fixture. ¿Desea continuar?' %>"
                      data-confirm-accept="<%= grupoVisibleFixture ? 'Dejar de ver' : 'Volver a ver' %>"
                      data-confirm-cancel="Cancelar">
                  <input type="hidden" name="visible_fixture" value="<%= grupoVisibleFixture ? '0' : '1' %>">
                  <button type="submit"
                          class="btn btn-sm <%= grupoVisibleFixture ? 'btn-outline-secondary' : 'btn-outline-success' %> w-100 text-start">
                    <i class="bi <%= grupoVisibleFixture ? 'bi-eye-slash' : 'bi-eye' %>"></i>
                    <%= grupoVisibleFixture ? 'Dejar de ver en Fixture' : 'Volver a ver en Fixture' %>
                  </button>
                  <small class="text-muted d-block mt-1">
                    <%= grupoVisibleFixture
                      ? 'Se vera el historico en dashboard, pero no en Fixture.'
                      : 'Actualmente no aparece en Fixture; el historico sigue disponible.' %>
                  </small>
                </form>
              <% } %>

              <!-- Botón para sortear encuentros -->
              <% if (grupo.encuentros_sorteados) { %>
                <button class="btn btn-secondary mt-3" disabled>
                  <i class="bi bi-lock-fill"></i> Sortear Encuentros
                </button>
                <div class="mt-2 small text-warning">Encuentros ya sorteados</div>
              <% } else if (grupo.Equipos && grupo.Equipos.length > 1) { %>
                <button class="btn btn-primary mt-3 abrir-sorteo-btn" 
                        data-bs-toggle="modal" 
                        data-bs-target="#modalSorteoFase1"
                        data-id-grupo="<%= grupo.id_grupo %>"
                        data-num-equipos="<%= grupo.Equipos.length %>"
                        data-id-torneo="<%= torneo.id_torneo %>">
                  <i class="fas fa-shuffle"></i> Sortear Encuentros
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-muted">No hay grupos creados aún para este torneo.</p>
  <% } %>

  <div class="modal fade" id="modalSorteoCombinado" tabindex="-1" aria-labelledby="modalSorteoCombinadoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header bg-warning text-dark">
          <h5 class="modal-title" id="modalSorteoCombinadoLabel">
            <i class="bi bi-shuffle"></i> Sorteos combinados
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
        </div>
        <div class="modal-body">
          <p class="text-dark mb-3">
            Seleccione grupos sin sorteo. Se genera el fixture de cada grupo y los libres de la misma fecha se cruzan como <strong>conv</strong>.
          </p>

          <div class="mb-3">
            <% (typeof gruposDisponiblesCombinado !== 'undefined' ? gruposDisponiblesCombinado : []).forEach(grupo => { %>
              <div class="form-check border rounded px-5 py-2 mb-2">
                <input class="form-check-input sorteo-combinado-grupo"
                       type="checkbox"
                       value="<%= grupo.id_grupo %>"
                       id="sorteoCombinadoGrupo<%= grupo.id_grupo %>"
                       data-equipos="<%= grupo.Equipos ? grupo.Equipos.length : 0 %>"
                       data-nombre="<%= grupo.nombre_grupo %>"
                       onchange="reiniciarFechasSorteoCombinado()">
                <label class="form-check-label text-dark w-100" for="sorteoCombinadoGrupo<%= grupo.id_grupo %>">
                  <strong><%= grupo.nombre_grupo %></strong>
                  <span class="text-muted">- <%= grupo.Equipos ? grupo.Equipos.length : 0 %> integrantes</span>
                </label>
              </div>
            <% }) %>
          </div>

          <div class="mb-3">
            <label class="form-label text-dark fw-bold">Modalidad</label>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="tipoCombinado" id="tipoCombinadoSimple" value="simple" checked onchange="reiniciarFechasSorteoCombinado()">
              <label class="form-check-label text-dark" for="tipoCombinadoSimple">Solo ida</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="radio" name="tipoCombinado" id="tipoCombinadoIdaVuelta" value="ida_vuelta" onchange="reiniciarFechasSorteoCombinado()">
              <label class="form-check-label text-dark" for="tipoCombinadoIdaVuelta">Ida y vuelta</label>
            </div>
          </div>

          <div class="mb-3">
            <label for="numFechasCombinado" class="form-label text-dark fw-bold">Cantidad de fechas a generar</label>
            <input type="number"
                   class="form-control"
                   id="numFechasCombinado"
                   min="1"
                   max="50"
                   placeholder="Ej: 5"
                   readonly
                   oninput="this.dataset.editado = '1'; actualizarResumenSorteoCombinado()">
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="usarFechasExactasCombinado" onchange="alternarFechasExactasCombinado()">
              <label class="form-check-label text-dark" for="usarFechasExactasCombinado">
                Agregar cantidad exacta de fechas
              </label>
            </div>
          </div>

          <div id="resumenSorteoCombinado" class="alert alert-info mb-0">
            Seleccione al menos dos grupos.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-success" id="btnConfirmarSorteoCombinado" onclick="confirmarSorteoCombinado()">
            <i class="bi bi-check2"></i> Confirmar sorteo
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MODAL FASE 1: CONFIRMACIÓN INICIAL -->
  <!-- ============================================ -->
  <div class="modal fade" id="modalSorteoFase1" tabindex="-1" role="dialog" aria-labelledby="modalLabel1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalLabel1">
            <i class="fas fa-shuffle"></i> Sortear Encuentros
          </h5>
          <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <p class="lead">¿Desea sortear los equipos de este grupo?</p>
          <p class="text-muted" id="grupoNombreInfo"></p>
          <div class="alert alert-info" role="alert">
            <i class="fas fa-lightbulb"></i>
            <strong>Total de equipos:</strong> <span id="totalEquiposInfo">-</span>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-times"></i> Cancelar
          </button>
          <button type="button" class="btn btn-primary" onclick="abrirModalFase2()">
            <i class="fas fa-arrow-right"></i> Continuar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- MODAL FASE 2: CONFIGURACIÓN DEL SORTEO -->
  <!-- ============================================ -->
  <div class="modal fade" id="modalSorteoFase2" tabindex="-1" role="dialog" aria-labelledby="modalLabel2" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="modalLabel2">
            <i class="fas fa-cog"></i> Configurar Sorteo
          </h5>
          <button type="button" class="close text-white" data-bs-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <form id="formSorteo">
            <!-- Tipo de encuentro -->
            <div class="form-group">
              <label for="tipoEncuentro" class="font-weight-bold">
                <i class="fas fa-question-circle"></i> Tipo de encuentro:
              </label>
              <div class="custom-control custom-radio mb-2">
                <input 
                  type="radio" 
                  id="radioSimple" 
                  name="tipo" 
                  value="simple" 
                  class="custom-control-input" 
                  checked 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioSimple">
                  <strong>Simple</strong> - Cada equipo juega una sola vez contra cada otro
                </label>
              </div>
              <div class="custom-control custom-radio mb-3">
                <input 
                  type="radio" 
                  id="radioIdaVuelta" 
                  name="tipo" 
                  value="ida_vuelta" 
                  class="custom-control-input" 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioIdaVuelta">
                  <strong>Ida y Vuelta</strong> - Cada equipo juega dos veces contra cada otro
                </label>
              </div>
              <div class="custom-control custom-radio mb-3">
                <input 
                  type="radio" 
                  id="radioFijo" 
                  name="tipo" 
                  value="fijo" 
                  class="custom-control-input" 
                  onchange="actualizarValidacion()"
                >
                <label class="custom-control-label text-dark" for="radioFijo">
                  <strong>Fijo</strong> - Especificar número de fechas manualmente
                </label>
              </div>
            </div>

            <!-- Campo para número de fechas (solo visible cuando es fijo) -->
            <div class="form-group" id="grupNumFechas" style="display: none;">
              <label for="numFechas" class="font-weight-bold">
                <i class="fas fa-calendar-alt"></i> Número de fechas:
              </label>
              <input 
                type="number" 
                id="numFechas" 
                name="numFechas" 
                class="form-control" 
                min="1" 
                max="50" 
                placeholder="Ej: 3, 5, 10"
                oninput="actualizarValidacion()"
              >
              <small class="text-muted d-block mt-1" id="textNumFechasInfo"></small>
            </div>

            <!-- Validación de fechas -->
            <div id="alertaValidacion" class="alert mt-3" style="display: none;" role="alert"></div>

            <!-- Resumen estimado -->
            <div class="card bg-light mt-3">
              <div class="card-body">
                <h6 class="card-title">
                  <i class="fas fa-chart-bar"></i> Resumen:
                </h6>
                <ul class="list-unstyled small">
                  <li>
                    <strong>Equipos en el grupo:</strong> 
                    <span id="resumenEquipos">-</span>
                  </li>
                  <li>
                    <strong>Partidos por equipo (estimado):</strong> 
                    <span id="resumenPartidosEquipo">-</span>
                  </li>
                  <li>
                    <strong>Total de partidos (estimado):</strong> 
                    <span id="resumenTotalPartidos">-</span>
                  </li>
                  <li>
                    <strong>Número de fechas:</strong> 
                    <span id="resumenFechas">-</span>
                  </li>
                </ul>
              </div>
            </div>
          </form>
          </div>
          <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="fas fa-arrow-left"></i> Atrás
          </button>
          <button type="button" class="btn btn-success" id="btnConfirmarSorteo" onclick="confirmarSorteo()">
            <i class="fas fa-check"></i> Confirmar Sorteo
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Variables globales para el modal
let grupoActual = null;
let numEquiposActual = 0;
let torneoActual = null;
let dashboardInicioDesactualizado = false;
const equiposPorGrupo = <%- JSON.stringify((equipos || []).reduce((acc, equipo) => {
  const key = String(equipo.id_grupo || '');
  if (!acc[key]) acc[key] = [];
  acc[key].push({
    id_equipo: equipo.id_equipo,
    nombre: equipo.nombre,
    id_grupo: equipo.id_grupo,
    nombre_grupo: equipo.nombre_grupo || 'Sin grupo'
  });
  return acc;
}, {})) %>;
let finanzasResumen = <%- JSON.stringify(finanzasResumen || []).replace(/</g, '\\u003c') %>;
let finanzasDetalleEquipoActual = null;
const finanzasPdfTorneoNombre = <%- JSON.stringify([torneo.nombre_torneo, torneo.temporada].filter(Boolean).join(' - ')).replace(/</g, '\\u003c') %>;
const dashboardEnCursoResumenUrl = '<%= esVistaPublica ? '/publico/torneo/' : '/torneos/' %><%= torneo.id_torneo %>/en-curso/resumen';
let dashboardPartidosEstadisticas = <%- JSON.stringify(((dashboardInicio || {}).ultimosResultados || []).map(partido => ({
  id_partido: partido.id_partido,
  equipo_a: partido.equipo_a,
  equipo_b: partido.equipo_b,
  nombre_equipo_a: partido.nombre_equipo_a || 'Equipo A',
  nombre_equipo_b: partido.nombre_equipo_b || 'Equipo B',
  goles_a: partido.goles_a || 0,
  goles_b: partido.goles_b || 0,
  numero_fecha: partido.numero_fecha || null,
  estadisticas: partido.estadisticas || [],
  cambios: partido.cambios || []
}))).replace(/</g, '\\u003c') %>;

function marcarDashboardInicioDesactualizado() {
  dashboardInicioDesactualizado = true;
}

function refrescarDashboardInicioSiNecesario() {
  if (!dashboardInicioDesactualizado) return;
  dashboardInicioDesactualizado = false;
  const url = new URL(window.location.href);
  url.searchParams.set('tab', 'torneos');
  url.hash = '#torneos';
  window.location.href = url.toString();
}

function formatearFechaInput(fecha) {
  if (!fecha) return '';
  return String(fecha).slice(0, 10);
}

function formatoMontoFinanzas(valor) {
  const numero = Number(valor || 0);
  return numero.toLocaleString('es-PY', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0
  });
}

function formatoFechaFinanzas(fecha) {
  if (!fecha) return '-';
  const valor = String(fecha).slice(0, 10);
  return valor ? valor.split('-').reverse().join('/') : '-';
}

function etiquetaFechaFinanzas(movimiento) {
  const numero = movimiento?.numero_fecha || '-';
  const fechaCalendario = formatoFechaFinanzas(movimiento?.fecha_calendario || movimiento?.fecha_registro);
  const grupo = movimiento?.nombre_grupo_display || movimiento?.nombre_grupo || '';
  const grupoVisible = grupo && grupo !== 'Sin grupo';
  const titulo = grupoVisible ? `${grupo} - Fecha ${numero}` : `Fecha ${numero}`;
  return `
    <strong class="d-block">${escaparHtml(titulo)}</strong>
    <small class="text-muted">${fechaCalendario}</small>
  `;
}

function conceptoVisibleFinanzas(movimiento) {
  return movimiento?.concepto_display || movimiento?.concepto || 'Movimiento';
}

function renderFinanzasResumen() {
  const tbody = document.getElementById('finanzasResumenTbody');
  if (!tbody) return;

  if (!finanzasResumen.length) {
    tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No hay equipos cargados para este torneo.</td></tr>';
    aplicarBusquedaFinanzas();
    return;
  }

  tbody.innerHTML = finanzasResumen.map(equipo => `
    <tr data-finanzas-equipo-id="${escaparHtml(equipo.id_equipo)}" data-finanzas-equipo-nombre="${escaparHtml(equipo.nombre || '')}">
      <td data-label="Equipo">
        <div class="d-flex align-items-center gap-2">
          <img src="${escaparHtml(equipo.icono || '/images/default_team.png')}" alt="" style="width:28px;height:28px;object-fit:cover;border-radius:50%;">
          <strong class="text-dark">${escaparHtml(equipo.nombre || '')}</strong>
        </div>
      </td>
      <td class="text-dark" data-label="Grupo">${escaparHtml(equipo.nombre_grupo || 'Sin grupo')}</td>
      <td class="text-center finanzas-estado-cell" data-label="Estado">
        ${equipo.adeuda ? '<span class="fw-bold text-danger" title="Equipo con deuda">‼️‼️</span>' : '<span class="badge text-bg-success">Al dia</span>'}
      </td>
      <td class="text-end fw-bold finanzas-admin-only finanzas-saldo-cell ${equipo.adeuda ? 'text-danger' : 'text-dark'}" data-label="Saldo">${equipo.puede_ver_detalle === false ? '-' : formatoMontoFinanzas(equipo.saldo_actual)}</td>
      <td class="text-end" data-label="Acciones">
        ${equipo.puede_ver_detalle === false
          ? '<span class="text-muted small">Sin detalle</span>'
          : `<button type="button" class="btn btn-sm btn-outline-dark" onclick="abrirDetalleFinanzas('${escaparHtml(equipo.id_equipo)}')">Detalles</button>`}
      </td>
    </tr>
  `).join('');
  aplicarBusquedaFinanzas();
}

async function sincronizarFinanzasDesdeServidor() {
  try {
    const response = await fetch(`/torneos/<%= torneo.id_torneo %>/finanzas/resumen`, {
      headers: { 'Accept': 'application/json' }
    });
    const data = await response.json();
    if (!data.success) return;
    finanzasResumen = data.finanzasResumen || [];
    renderFinanzasResumen();
  } catch (error) {
    console.error('No se pudo actualizar finanzas:', error);
  }
}

function abrirDetalleFinanzas(idEquipo) {
  const equipo = finanzasResumen.find(item => String(item.id_equipo) === String(idEquipo));
  if (!equipo) return;
  if (equipo.puede_ver_detalle === false) return;
  finanzasDetalleEquipoActual = equipo;

  document.getElementById('finanzasDetalleTitulo').textContent = `Detalle financiero - ${equipo.nombre}`;
  document.getElementById('finanzasDetalleSubtitulo').textContent = `${equipo.nombre_grupo || 'Sin grupo'} · Saldo actual: ${formatoMontoFinanzas(equipo.saldo_actual)}`;

  const tbody = document.getElementById('finanzasDetalleTbody');
  tbody.innerHTML = '';

  if (!equipo.movimientos || equipo.movimientos.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Sin movimientos financieros registrados.</td></tr>';
  } else {
    equipo.movimientos.forEach(movimiento => {
      const items = movimiento.items || [];
      const fila = document.createElement('tr');
      fila.className = `finanzas-detalle-movimiento-row${items.length ? '' : ' finanzas-detalle-movimiento-unico'}`;
      fila.innerHTML = `
        <td>${etiquetaFechaFinanzas(movimiento)}</td>
        <td>${escaparHtml(conceptoVisibleFinanzas(movimiento))}</td>
        <td class="text-end">${formatoMontoFinanzas(movimiento.deuda_inicial)}</td>
        <td class="text-end">${formatoMontoFinanzas(movimiento.total_items)}</td>
        <td class="text-end">${formatoMontoFinanzas(movimiento.entrega)}</td>
        <td class="text-end fw-bold">${formatoMontoFinanzas(movimiento.saldo)}</td>
      `;
      tbody.appendChild(fila);

      if (items.length > 0) {
        const filaItems = document.createElement('tr');
        filaItems.className = 'finanzas-detalle-items-row';
        filaItems.innerHTML = `
          <td></td>
          <td colspan="5">
            <div class="small text-dark">
              ${items.map(item => `
                <div class="d-flex justify-content-between border-bottom py-1">
                  <span>${escaparHtml(item.nombre || 'Item')} x${item.cantidad || 0}${item.observaciones ? ` · ${escaparHtml(item.observaciones)}` : ''}</span>
                  <strong>${formatoMontoFinanzas(item.total)}</strong>
                </div>
              `).join('')}
            </div>
          </td>
        `;
        tbody.appendChild(filaItems);
      }
    });
  }

  document.getElementById('finanzasDetalleTotalItems').textContent = formatoMontoFinanzas(equipo.total_items);
  document.getElementById('finanzasDetalleTotalEntregado').textContent = formatoMontoFinanzas(equipo.total_entregado);
  document.getElementById('finanzasDetalleSaldo').textContent = formatoMontoFinanzas(equipo.saldo_actual);
  document.getElementById('finanzasDetalleAlerta').classList.toggle('d-none', !equipo.adeuda);

  bootstrap.Modal.getOrCreateInstance(document.getElementById('modalDetalleFinanzas')).show();
}

function normalizarTextoPdf(valor) {
  return String(valor ?? '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^\x20-\x7E]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

function escaparTextoPdf(valor) {
  return normalizarTextoPdf(valor)
    .replace(/\\/g, '\\\\')
    .replace(/\(/g, '\\(')
    .replace(/\)/g, '\\)');
}

function dividirLineaPdf(texto, max = 92) {
  const limpio = normalizarTextoPdf(texto);
  if (limpio.length <= max) return [limpio];
  const palabras = limpio.split(' ');
  const lineas = [];
  let actual = '';
  palabras.forEach(palabra => {
    const candidata = actual ? `${actual} ${palabra}` : palabra;
    if (candidata.length > max && actual) {
      lineas.push(actual);
      actual = palabra;
    } else {
      actual = candidata;
    }
  });
  if (actual) lineas.push(actual);
  return lineas;
}

function separadorPdf() {
  return '------------------------------------------------------------';
}

function escaparRegex(valor) {
  return String(valor ?? '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function limpiarConceptoFinanzasPdf(concepto, equipoNombre) {
  let texto = normalizarTextoPdf(concepto || 'Movimiento');
  const equipo = normalizarTextoPdf(equipoNombre || '');
  if (equipo) {
    texto = texto.replace(new RegExp(` - ${escaparRegex(equipo)}(?= vs |$)`, 'i'), '');
  }
  texto = texto.replace(/^Encuentro\s+/, '').replace(/^Fecha libre\s+/, 'Fecha libre ');
  return texto.trim();
}

function crearPdfTexto(lineas) {
  const lineasPorPagina = 48;
  const paginas = [];
  for (let i = 0; i < lineas.length; i += lineasPorPagina) {
    paginas.push(lineas.slice(i, i + lineasPorPagina));
  }
  if (!paginas.length) paginas.push(['Sin datos.']);

  const fontId = 3 + (paginas.length * 2);
  const objetos = [];
  const agregarObjeto = (id, contenido) => {
    objetos.push({ id, contenido });
  };

  const pageIds = paginas.map((_, index) => 3 + (index * 2));
  agregarObjeto(1, '<< /Type /Catalog /Pages 2 0 R >>');
  agregarObjeto(2, `<< /Type /Pages /Kids [${pageIds.map(id => `${id} 0 R`).join(' ')}] /Count ${paginas.length} >>`);

  paginas.forEach((pagina, index) => {
    const pageId = 3 + (index * 2);
    const contentId = pageId + 1;
    const comandos = [
      'BT',
      `/F1 ${index === 0 ? 14 : 10} Tf`,
      '40 800 Td',
      '14 TL'
    ];
    pagina.forEach((linea, lineaIndex) => {
      if (lineaIndex > 0) comandos.push('T*');
      comandos.push(`(${escaparTextoPdf(linea)}) Tj`);
      if (lineaIndex === 0 && index === 0) {
        comandos.push('/F1 10 Tf');
        comandos.push('T*');
      }
    });
    comandos.push('ET');
    const stream = comandos.join('\n');
    agregarObjeto(pageId, `<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] /Resources << /Font << /F1 ${fontId} 0 R >> >> /Contents ${contentId} 0 R >>`);
    agregarObjeto(contentId, `<< /Length ${stream.length} >>\nstream\n${stream}\nendstream`);
  });

  agregarObjeto(fontId, '<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>');

  let pdf = '%PDF-1.4\n';
  const offsets = [0];
  objetos.sort((a, b) => a.id - b.id).forEach(objeto => {
    offsets[objeto.id] = pdf.length;
    pdf += `${objeto.id} 0 obj\n${objeto.contenido}\nendobj\n`;
  });
  const xrefOffset = pdf.length;
  pdf += `xref\n0 ${fontId + 1}\n`;
  pdf += '0000000000 65535 f \n';
  for (let id = 1; id <= fontId; id += 1) {
    pdf += `${String(offsets[id] || 0).padStart(10, '0')} 00000 n \n`;
  }
  pdf += `trailer\n<< /Size ${fontId + 1} /Root 1 0 R >>\nstartxref\n${xrefOffset}\n%%EOF`;
  return pdf;
}

function descargarBlob(nombreArchivo, contenido, tipo) {
  const blob = new Blob([contenido], { type: tipo });
  const url = URL.createObjectURL(blob);
  const link = document.createElement('a');
  link.href = url;
  link.download = nombreArchivo;
  document.body.appendChild(link);
  link.click();
  link.remove();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function esAndroidWebViewApp() {
  return /Android/i.test(navigator.userAgent || '') || Boolean(window.Capacitor);
}

async function abrirUrlExternaPdf(url) {
  const androidDownloader = window.AndroidDownloader;
  if (androidDownloader?.open) {
    androidDownloader.open(url);
    return;
  }

  const capacitorBrowser = window.Capacitor?.Plugins?.Browser;
  if (capacitorBrowser?.open) {
    await capacitorBrowser.open({ url });
    return;
  }

  const nuevaVentana = window.open(url, '_blank', 'noopener,noreferrer');
  if (nuevaVentana) {
    return;
  }

  if (/Android/i.test(navigator.userAgent || '')) {
    const parsedUrl = new URL(url);
    window.location.href = `intent://${parsedUrl.host}${parsedUrl.pathname}${parsedUrl.search}#Intent;scheme=${parsedUrl.protocol.replace(':', '')};end`;
    return;
  }

  window.location.href = url;
}

async function descargarUrlPdfApp(url) {
  const androidDownloader = window.AndroidDownloader;
  if (androidDownloader?.download) {
    androidDownloader.download(url);
    return;
  }

  const link = document.createElement('a');
  link.href = url;
  link.download = '';
  link.target = '_blank';
  document.body.appendChild(link);
  link.click();
  link.remove();

  setTimeout(() => {
    window.location.href = url;
  }, 250);
}

function descargarPdfDesdeServidor(nombreArchivo, contenidoPdf) {
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = `/torneos/<%= torneo.id_torneo %>/finanzas/pdf-descarga`;
  form.style.display = 'none';

  const inputNombre = document.createElement('input');
  inputNombre.type = 'hidden';
  inputNombre.name = 'nombre_archivo';
  inputNombre.value = nombreArchivo;

  const inputPdf = document.createElement('input');
  inputPdf.type = 'hidden';
  inputPdf.name = 'pdf_base64';
  inputPdf.value = btoa(contenidoPdf);

  form.appendChild(inputNombre);
  form.appendChild(inputPdf);
  document.body.appendChild(form);
  form.submit();
  setTimeout(() => form.remove(), 3000);
}

function mostrarEnlacePdfApp(url, downloadUrl) {
  const modalEl = document.getElementById('modalAvisoApp');
  const mensajeEl = document.getElementById('modalAvisoAppMensaje');
  if (!modalEl || !mensajeEl) return;

  limpiarBotonesExtraModalAviso();
  document.getElementById('modalAvisoAppTitulo').textContent = 'PDF listo';
  mensajeEl.classList.add('text-dark');
  mensajeEl.classList.remove('text-danger', 'fw-bold');
  mensajeEl.innerHTML = '';
  const texto = document.createElement('div');
  texto.className = 'mb-2';
  texto.textContent = 'Si el PDF no se abrio automaticamente, toque Abrir PDF.';
  const btnAbrir = document.createElement('button');
  btnAbrir.type = 'button';
  btnAbrir.className = 'btn btn-primary w-100';
  btnAbrir.textContent = 'Abrir PDF';
  btnAbrir.addEventListener('click', async () => {
    try {
      await abrirUrlExternaPdf(url);
    } catch (error) {
      console.error(error);
      window.location.href = url;
    }
  });
  const btnDescargar = document.createElement('button');
  btnDescargar.type = 'button';
  btnDescargar.className = 'btn btn-success w-100 mt-2';
  btnDescargar.textContent = 'Descargar PDF';
  btnDescargar.addEventListener('click', async () => {
    try {
      await descargarUrlPdfApp(downloadUrl || url);
    } catch (error) {
      console.error(error);
      window.location.href = downloadUrl || url;
    }
  });
  mensajeEl.appendChild(texto);
  mensajeEl.appendChild(btnAbrir);
  mensajeEl.appendChild(btnDescargar);

  const btnCancelar = document.getElementById('modalAvisoAppCancelar');
  const btnAceptar = document.getElementById('modalAvisoAppAceptar');
  btnCancelar.classList.add('d-none');
  btnAceptar.textContent = 'Cerrar';
  btnAceptar.className = 'btn btn-secondary';
  btnAceptar.onclick = () => bootstrap.Modal.getOrCreateInstance(modalEl).hide();
  bootstrap.Modal.getOrCreateInstance(modalEl).show();
}

async function abrirPdfDesdeServidor(nombreArchivo, contenidoPdf) {
  const response = await fetch(`/torneos/<%= torneo.id_torneo %>/finanzas/pdf-preparar`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    },
    body: JSON.stringify({
      nombre_archivo: nombreArchivo,
      pdf_base64: btoa(contenidoPdf)
    })
  });
  const data = await response.json();
  if (!data.success || !data.url) {
    throw new Error(data.message || 'No se pudo preparar el PDF');
  }

  const url = new URL(data.url, window.location.origin).toString();
  const downloadUrl = new URL(data.downloadUrl || data.url, window.location.origin).toString();
  mostrarEnlacePdfApp(url, downloadUrl);
}

async function descargarPdfArchivo(nombreArchivo, contenidoPdf) {
  if (esAndroidWebViewApp()) {
    await abrirPdfDesdeServidor(nombreArchivo, contenidoPdf);
    return;
  }

  descargarBlob(nombreArchivo, contenidoPdf, 'application/pdf');
}

function tituloMovimientoFinanzasPdf(movimiento) {
  return normalizarTextoPdf(conceptoVisibleFinanzas(movimiento))
    .replace(/^Encuentro #?([0-9]+)\s*-\s*/i, '#$1 ')
    .replace(/^Fecha libre #?([0-9]+)\s*-\s*/i, 'Fecha libre #$1 ');
}

function crearPdfDesdePaginas(paginas) {
  const fontRegularId = 3 + (paginas.length * 2);
  const fontBoldId = fontRegularId + 1;
  const objetos = [];
  const agregarObjeto = (id, contenido) => objetos.push({ id, contenido });
  const pageIds = paginas.map((_, index) => 3 + (index * 2));

  agregarObjeto(1, '<< /Type /Catalog /Pages 2 0 R >>');
  agregarObjeto(2, `<< /Type /Pages /Kids [${pageIds.map(id => `${id} 0 R`).join(' ')}] /Count ${paginas.length} >>`);

  paginas.forEach((comandos, index) => {
    const pageId = 3 + (index * 2);
    const contentId = pageId + 1;
    const stream = comandos.join('\n');
    agregarObjeto(pageId, `<< /Type /Page /Parent 2 0 R /MediaBox [0 0 595 842] /Resources << /Font << /F1 ${fontRegularId} 0 R /F2 ${fontBoldId} 0 R >> >> /Contents ${contentId} 0 R >>`);
    agregarObjeto(contentId, `<< /Length ${stream.length} >>\nstream\n${stream}\nendstream`);
  });

  agregarObjeto(fontRegularId, '<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>');
  agregarObjeto(fontBoldId, '<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold >>');

  let pdf = '%PDF-1.4\n';
  const offsets = [0];
  objetos.sort((a, b) => a.id - b.id).forEach(objeto => {
    offsets[objeto.id] = pdf.length;
    pdf += `${objeto.id} 0 obj\n${objeto.contenido}\nendobj\n`;
  });
  const xrefOffset = pdf.length;
  pdf += `xref\n0 ${fontBoldId + 1}\n`;
  pdf += '0000000000 65535 f \n';
  for (let id = 1; id <= fontBoldId; id += 1) {
    pdf += `${String(offsets[id] || 0).padStart(10, '0')} 00000 n \n`;
  }
  pdf += `trailer\n<< /Size ${fontBoldId + 1} /Root 1 0 R >>\nstartxref\n${xrefOffset}\n%%EOF`;
  return pdf;
}

function crearPdfDetalleFinanzas(equipo) {
  const paginas = [];
  let comandos = [];
  let y = 805;

  const nuevaPagina = () => {
    if (comandos.length) paginas.push(comandos);
    comandos = [];
    y = 805;
  };
  const asegurarEspacio = altura => {
    if (y - altura < 55) nuevaPagina();
  };
  const texto = (valor, opciones = {}) => {
    const size = opciones.size || 8;
    const font = opciones.bold ? 'F2' : 'F1';
    const x = opciones.x || 55;
    const max = opciones.max || 104;
    dividirLineaPdf(valor, max).forEach(linea => {
      asegurarEspacio(size + 8);
      comandos.push(`BT /${font} ${size} Tf ${x} ${y} Td (${escaparTextoPdf(linea)}) Tj ET`);
      y -= size + 5;
    });
  };
  const linea = () => {
    asegurarEspacio(16);
    y -= 4;
    comandos.push(`50 ${y} m 535 ${y} l S`);
    y -= 13;
  };
  const espacio = (alto = 8) => {
    asegurarEspacio(alto);
    y -= alto;
  };

  const fechaGenerado = new Date().toLocaleString('es-PY', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });

  comandos.push('0.12 w');
  comandos.push('50 746 500 78 re S');
  texto(`Detalle financiero - ${equipo.nombre || 'Equipo'}`, { x: 58, size: 8, max: 92 });
  texto(`Torneo: ${finanzasPdfTorneoNombre || '-'}`, { x: 58, size: 8, max: 92 });
  texto(`Grupo: ${equipo.nombre_grupo || 'Sin grupo'}`, { x: 58, size: 8, max: 92 });
  texto(`Generado: ${fechaGenerado}`, { x: 58, size: 8, max: 92 });
  y = 720;

  texto(`Total items/gastos: ${formatoMontoFinanzas(equipo.total_items)}`, { size: 8 });
  espacio(3);
  texto(`Entregas en efectivo: ${formatoMontoFinanzas(equipo.total_entregado)}`, { size: 8 });
  espacio(3);
  texto(`Deuda actual: ${formatoMontoFinanzas(equipo.saldo_actual)}`, { size: 8 });

  const movimientos = equipo.movimientos || [];
  if (!movimientos.length) {
    linea();
    texto('Sin movimientos financieros registrados.', { bold: true });
  } else {
    movimientos.forEach(movimiento => {
      linea();
      const fecha = formatoFechaFinanzas(movimiento.fecha_calendario || movimiento.fecha_registro);
      const grupoMovimiento = movimiento.nombre_grupo_display || movimiento.nombre_grupo || '';
      const tituloFecha = grupoMovimiento && grupoMovimiento !== 'Sin grupo'
        ? `${grupoMovimiento} - Fecha ${movimiento.numero_fecha || '-'}`
        : `Fecha ${movimiento.numero_fecha || '-'}`;
      texto(tituloFecha, { bold: true, size: 8 });
      texto(fecha, { bold: true, size: 8 });
      espacio(4);
      texto(`${tituloMovimientoFinanzasPdf(movimiento)} (${fecha})`, { size: 8 });
      espacio(4);
      texto(`Deuda anterior: ${formatoMontoFinanzas(movimiento.deuda_inicial)} | Gastos: ${formatoMontoFinanzas(movimiento.total_items)} | Entrega: ${formatoMontoFinanzas(movimiento.entrega)} | Saldo: ${formatoMontoFinanzas(movimiento.saldo)}`, { size: 8, max: 98 });

      (movimiento.items || []).forEach(item => {
        espacio(2);
        texto(`-> ${item.nombre || 'Item'} x${item.cantidad || 0} (${formatoMontoFinanzas(item.total)})`, { size: 8, max: 98 });
      });
    });
  }

  paginas.push(comandos);
  return crearPdfDesdePaginas(paginas);
}

async function descargarPdfDetalleFinanzas() {
  const equipo = finanzasDetalleEquipoActual;
  if (!equipo || equipo.puede_ver_detalle === false) return;

  const pdf = crearPdfDetalleFinanzas(equipo);
  const nombreSeguro = normalizarTextoPdf(equipo.nombre || 'equipo').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'equipo';
  try {
    await descargarPdfArchivo(`detalle-deuda-${nombreSeguro}.pdf`, pdf);
  } catch (error) {
    console.error(error);
    mostrarAvisoApp('No se pudo abrir el PDF. Intenta nuevamente.', 'PDF');
  }
}

function textoPdf(comandos, valor, x, y, opciones = {}) {
  const size = opciones.size || 8;
  const font = opciones.bold ? 'F2' : 'F1';
  comandos.push(`BT /${font} ${size} Tf ${x} ${y} Td (${escaparTextoPdf(valor)}) Tj ET`);
}

function lineaPdf(comandos, x1, y1, x2, y2) {
  comandos.push(`${x1} ${y1} m ${x2} ${y2} l S`);
}

function rectPdf(comandos, x, y, width, height) {
  comandos.push(`${x} ${y} ${width} ${height} re S`);
}

function textoPdfEnCaja(comandos, valor, x, y, maxCaracteres, opciones = {}) {
  const lineas = dividirLineaPdf(valor, maxCaracteres);
  const altoLinea = opciones.altoLinea || 9;
  lineas.slice(0, opciones.maxLineas || 2).forEach((linea, index) => {
    textoPdf(comandos, linea, x, y - (index * altoLinea), opciones);
  });
}

function crearPdfListaJugadoresPartido(lista) {
  const paginas = [];
  let comandos = [];
  let y = 805;

  const columnas = [
    { titulo: '#', x: 32, w: 32, max: 3 },
    { titulo: 'Documento', x: 64, w: 70, max: 13 },
    { titulo: 'F. nac.', x: 134, w: 58, max: 10 },
    { titulo: 'Nombre y apellido', x: 192, w: 178, max: 34 },
    { titulo: 'Estado', x: 370, w: 65, max: 12 },
    { titulo: 'Firma jugador', x: 435, w: 128, max: 18 }
  ];

  const nuevaPagina = () => {
    if (comandos.length) paginas.push(comandos);
    comandos = ['0.12 w'];
    y = 805;
  };

  const encabezado = () => {
    textoPdf(comandos, 'Lista de jugadores', 40, y, { size: 14, bold: true });
    textoPdf(comandos, `Torneo: ${lista.torneo || '-'}`, 340, y, { size: 8 });
    y -= 20;
    rectPdf(comandos, 32, y - 70, 531, 78);
    textoPdf(comandos, `Equipo: ${lista.equipo?.nombre || '-'}`, 42, y - 10, { size: 10, bold: true });
    textoPdf(comandos, `Fecha Nro: ${lista.numero_fecha || '-'}`, 340, y - 10, { size: 9, bold: true });
    textoPdf(comandos, `Partido: ${lista.partido?.equipo_a || '-'} vs ${lista.partido?.equipo_b || '-'}`, 42, y - 30, { size: 9, bold: true });
    textoPdf(comandos, `Fecha de juego: ${lista.fecha_juego || '-'}${lista.hora ? ` ${lista.hora}` : ''}`, 42, y - 50, { size: 9 });
    textoPdf(comandos, `Generado: ${new Date().toLocaleString('es-PY')}`, 340, y - 50, { size: 8 });
    y -= 95;
  };

  const encabezadoTabla = () => {
    rectPdf(comandos, 32, y - 18, 531, 18);
    columnas.forEach(col => {
      textoPdf(comandos, col.titulo, col.x + 4, y - 12, { size: 7, bold: true });
      if (col.x > 32) lineaPdf(comandos, col.x, y, col.x, y - 18);
    });
    y -= 18;
  };

  nuevaPagina();
  encabezado();
  encabezadoTabla();

  const jugadores = lista.jugadores || [];
  jugadores.forEach(jugador => {
    if (y < 95) {
      nuevaPagina();
      encabezado();
      encabezadoTabla();
    }

    const altoFila = 26;
    rectPdf(comandos, 32, y - altoFila, 531, altoFila);
    columnas.forEach(col => {
      if (col.x > 32) lineaPdf(comandos, col.x, y, col.x, y - altoFila);
    });

    const nombre = `${jugador.nombre || ''} ${jugador.apellido || ''}${jugador.capitan ? ' (C)' : ''}`;
    textoPdf(comandos, jugador.numero_camiseta || '', 38, y - 16, { size: 8 });
    textoPdfEnCaja(comandos, jugador.documento || '', 70, y - 11, 12, { size: 7, maxLineas: 2 });
    textoPdf(comandos, jugador.fecha_nacimiento || '-', 140, y - 16, { size: 7 });
    textoPdfEnCaja(comandos, nombre, 198, y - 10, 27, { size: 7, maxLineas: 2 });
    textoPdf(comandos, jugador.habilitado ? 'Habilitado' : '**Inhabilitado', 376, y - 16, { size: 7 });
    y -= altoFila;
  });

  if (!jugadores.length) {
    textoPdf(comandos, 'Sin jugadores vinculados a este equipo.', 42, y - 18, { size: 9, bold: true });
    y -= 35;
  }

  if (y < 145) {
    nuevaPagina();
    encabezado();
  }

  y -= 24;
  textoPdf(comandos, 'Firma de delegados', 40, y, { size: 10, bold: true });
  y -= 30;
  const delegados = lista.delegados && lista.delegados.length
    ? lista.delegados
    : [{ nombre: 'Delegado', documento: '', rol: 'delegado' }];
  delegados.forEach(delegado => {
    if (y < 70) {
      nuevaPagina();
      encabezado();
      textoPdf(comandos, 'Firma de delegados', 40, y, { size: 10, bold: true });
      y -= 30;
    }
    lineaPdf(comandos, 42, y, 245, y);
    textoPdfEnCaja(comandos, delegado.nombre || 'Delegado', 42, y - 14, 32, { size: 8, maxLineas: 1 });
    textoPdf(comandos, delegado.documento ? `Doc: ${delegado.documento}` : '', 42, y - 26, { size: 7 });
    y -= 52;
  });

  paginas.push(comandos);
  return crearPdfDesdePaginas(paginas);
}

async function imprimirListaJugadoresPartido(partidoId, equipoId) {
  try {
    const response = await fetch(`/torneos/<%= torneo.id_torneo %>/partidos/${partidoId}/equipos/${equipoId}/lista-jugadores`, {
      headers: { 'Accept': 'application/json' }
    });
    const data = await response.json();
    if (!data.success || !data.lista) {
      throw new Error(data.message || 'No se pudo preparar la lista');
    }

    const lista = data.lista;
    const pdf = crearPdfListaJugadoresPartido(lista);
    const equipoSeguro = normalizarTextoPdf(lista.equipo?.nombre || 'equipo').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'equipo';
    const fechaSeguro = normalizarTextoPdf(`fecha-${lista.numero_fecha || 'x'}`).toLowerCase().replace(/[^a-z0-9]+/g, '-');
    await descargarPdfArchivo(`lista-jugadores-${fechaSeguro}-${equipoSeguro}.pdf`, pdf);
  } catch (error) {
    console.error(error);
    mostrarAvisoApp(error.message || 'No se pudo imprimir la lista.', 'Lista de jugadores');
  }
}

function nombreJugadorPlanilla(jugador) {
  return `${jugador.numero_camiseta ? `#${jugador.numero_camiseta} ` : ''}${[jugador.nombre, jugador.apellido].filter(Boolean).join(' ')}`.trim() || 'Jugador';
}

function nombreJugadorPlanillaSinNumero(jugador) {
  return [jugador.nombre, jugador.apellido].filter(Boolean).join(' ').trim() || 'Jugador';
}

function minutosPlanilla(valor) {
  return normalizarMinutosEvento(valor).join(', ') || '-';
}

function minutosPlanillaCompacto(valor) {
  const minutos = normalizarMinutosEvento(valor);
  return minutos.length ? minutos.join(', ') : '-';
}

function crearPdfPlanillaFinalEquipo(data) {
  const paginas = [];
  const comandos = ['0.12 w', '0.12 0.18 0.28 RG'];
  const partido = data.partido || {};
  const equipo = data.equipo || {};
  const jugadores = data.jugadores || [];
  const items = data.itemsCargados || [];
  const jugadorPorId = jugadores.reduce((acc, jugador) => {
    acc[String(jugador.id_jugador)] = jugador;
    return acc;
  }, {});
  const cambios = (data.cambios || []).map(cambio => ({
    ...cambio,
    sale: nombreJugadorPlanillaSinNumero(jugadorPorId[String(cambio.jugador_sale_id)] || {}),
    entra: nombreJugadorPlanillaSinNumero(jugadorPorId[String(cambio.jugador_entra_id)] || {})
  }));

  const x = {
    n: 32,
    jugador: 54,
    goles: 224,
    amarillas: 282,
    rojas: 340,
    gastos: 472
  };
  const fillRect = (x0, y0, width, height, color = '0.96 0.98 1') => {
    comandos.push(`q ${color} rg ${x0} ${y0} ${width} ${height} re f Q`);
  };
  const sectionTitle = (titulo, x0, y0, width) => {
    fillRect(x0, y0 - 18, width, 18, '0.90 0.95 1');
    rectPdf(comandos, x0, y0 - 18, width, 18);
    textoPdf(comandos, titulo, x0 + 8, y0 - 12, { size: 8, bold: true });
  };

  let y = 805;
  fillRect(32, 734, 531, 78, '0.94 0.97 1');
  rectPdf(comandos, 32, 734, 531, 78);
  fillRect(32, 784, 531, 28, '0.82 0.90 1');
  textoPdf(comandos, 'PLANILLA FINAL DEL ENCUENTRO', 174, 793, { size: 14, bold: true });
  textoPdf(comandos, `${equipo.nombre || 'Equipo'} vs ${equipo.rival || 'Rival'}`, 52, 766, { size: 11, bold: true });
  textoPdf(comandos, `Marcador final: ${Number(partido.goles_a || 0)} - ${Number(partido.goles_b || 0)}`, 330, 766, { size: 10, bold: true });
  textoPdf(comandos, `Torneo: ${partido.torneo || '-'}`, 52, 756, { size: 8, bold: true });
  textoPdf(comandos, `Fecha: ${partido.numero_fecha || '-'}  |  Juego: ${partido.fecha || '-'}  |  Hora: ${partido.hora || '-'}`, 52, 748, { size: 8 });
  textoPdf(comandos, `Generado: ${new Date().toLocaleString('es-PY')}`, 382, 748, { size: 7 });
  y = 712;

  sectionTitle(`DETALLE DE JUGADORES (${equipo.nombre || 'Equipo'})`, 32, y, 430);
  y -= 22;
  fillRect(32, y - 18, 430, 18, '0.88 0.93 0.98');
  rectPdf(comandos, 32, y - 18, 430, 18);
  ['NRO', 'Jugador', 'Goles', 'Amarillas', 'Rojas'].forEach((titulo, index) => {
    const pos = [x.n, x.jugador, x.goles, x.amarillas, x.rojas][index];
    textoPdf(comandos, titulo, pos + 4, y - 12, { size: 7, bold: true });
    if (index > 0) lineaPdf(comandos, pos, y, pos, y - 18);
  });
  y -= 18;

  jugadores.forEach((jugador, index) => {
    if (y < 270) return;
    const alto = 30;

    if (index % 2 === 0) fillRect(32, y - alto, 430, alto, '0.985 0.99 1');
    rectPdf(comandos, 32, y - alto, 430, alto);
    [x.jugador, x.goles, x.amarillas, x.rojas].forEach(pos => lineaPdf(comandos, pos, y, pos, y - alto));
    textoPdf(comandos, jugador.numero_camiseta || '', 38, y - 18, { size: 7 });
    textoPdfEnCaja(comandos, nombreJugadorPlanillaSinNumero(jugador), 58, y - 10, 30, { size: 7, maxLineas: 2 });
    textoPdfEnCaja(comandos, minutosPlanillaCompacto(jugador.goles_minutos), 228, y - 10, 12, { size: 6, maxLineas: 3 });
    textoPdfEnCaja(comandos, minutosPlanillaCompacto(jugador.amarillas_minutos), 286, y - 10, 12, { size: 6, maxLineas: 3 });
    textoPdfEnCaja(comandos, minutosPlanillaCompacto(jugador.rojas_minutos), 344, y - 10, 12, { size: 6, maxLineas: 3 });
    y -= alto;
  });

  const cambiosY = y - 18;
  sectionTitle('CAMBIOS REALIZADOS', 32, cambiosY, 430);
  let cy = cambiosY - 24;
  if (cambios.length) {
    cambios.forEach((cambio, index) => {
      if (cy < 158) return;
      const saleJugador = jugadorPorId[String(cambio.jugador_sale_id)] || {};
      const entraJugador = jugadorPorId[String(cambio.jugador_entra_id)] || {};
      const saleNum = saleJugador.numero_camiseta || '-';
      const entraNum = entraJugador.numero_camiseta || '-';
      if (index % 2 === 0) fillRect(32, cy - 24, 430, 24, '0.985 0.99 1');
      rectPdf(comandos, 32, cy - 24, 430, 24);
      textoPdf(comandos, `Min ${cambio.minuto || '-'}`, 42, cy - 15, { size: 8, bold: true });
      textoPdf(comandos, `Sale ${saleNum}`, 112, cy - 15, { size: 8, bold: true });
      textoPdfEnCaja(comandos, cambio.sale || '-', 168, cy - 9, 28, { size: 7, maxLineas: 2 });
      textoPdf(comandos, `Entra ${entraNum}`, 302, cy - 15, { size: 8, bold: true });
      textoPdfEnCaja(comandos, cambio.entra || '-', 370, cy - 9, 18, { size: 7, maxLineas: 2 });
      cy -= 24;
    });
  } else {
    rectPdf(comandos, 32, cy - 24, 430, 24);
    textoPdf(comandos, 'Sin cambios cargados.', 42, cy - 15, { size: 8 });
    cy -= 24;
  }

  fillRect(x.gastos, 304, 91, 390, '0.98 0.99 1');
  rectPdf(comandos, x.gastos, 304, 91, 390);
  fillRect(x.gastos, 676, 91, 18, '0.90 0.95 1');
  textoPdf(comandos, 'GASTOS FECHA', x.gastos + 11, 681, { size: 8, bold: true });
  let gy = 656;
  if (items.length) {
    items.forEach(item => {
      if (gy < 340) return;
      const total = Number(item.monto || 0) * Number(item.cantidad || 0);
      fillRect(x.gastos + 5, gy - 30, 81, 30, '1 1 1');
      rectPdf(comandos, x.gastos + 5, gy - 30, 81, 30);
      textoPdfEnCaja(comandos, `${item.nombre || 'Item'} x${item.cantidad || 0}`, x.gastos + 7, gy - 8, 18, { size: 7, maxLineas: 2 });
      textoPdf(comandos, formatoMonto(total), x.gastos + 52, gy - 22, { size: 7, bold: true });
      gy -= 36;
    });
  } else {
    textoPdf(comandos, 'Sin gastos cargados', x.gastos + 8, gy, { size: 7 });
    gy -= 24;
  }
  const totalItems = items.reduce((total, item) => total + (Number(item.monto || 0) * Number(item.cantidad || 0)), 0);
  lineaPdf(comandos, x.gastos + 6, gy, x.gastos + 85, gy);
  fillRect(x.gastos + 6, gy - 24, 79, 18, '0.94 0.97 1');
  textoPdf(comandos, `Total: ${formatoMonto(totalItems)}`, x.gastos + 8, gy - 18, { size: 8, bold: true });
  textoPdf(comandos, `Entrega: ${formatoMonto(data.montoAportado || 0)}`, x.gastos + 8, gy - 34, { size: 7 });

  y = Math.min(cy - 24, 110);
  const textoCentradoPdf = (valor, centroX, y0, opciones = {}) => {
    const size = opciones.size || 9;
    const anchoEstimado = normalizarTextoPdf(valor).length * size * 0.46;
    textoPdf(comandos, valor, centroX - (anchoEstimado / 2), y0, opciones);
  };
  const firmaSimple = (x0, y0, width, titulo) => {
    const centroX = x0 + (width / 2);
    const lineaWidth = 116;
    comandos.push('[2 2] 0 d');
    lineaPdf(comandos, centroX - (lineaWidth / 2), y0, centroX + (lineaWidth / 2), y0);
    comandos.push('[] 0 d');
    textoCentradoPdf(titulo, centroX, y0 - 18, { size: 9 });
  };
  const firmaTop = 96;
  const firmaWidth = 150;
  firmaSimple(38, firmaTop, firmaWidth, 'Firma delegado');
  firmaSimple(222, firmaTop, firmaWidth, 'Firma arbitro');
  firmaSimple(406, firmaTop, firmaWidth, 'Firma mesa de control');

  paginas.push(comandos);
  return crearPdfDesdePaginas(paginas);
}

async function imprimirPlanillaFinalPartidoEquipo(lado) {
  const modal = document.getElementById('modalDocsPartido');
  if (!modal) return;

  const partidoId = modal.dataset.partidoId;
  const equipoId = lado === 'b' ? modal.dataset.equipoBId : modal.dataset.equipoAId;
  if (!partidoId || !equipoId) return;

  try {
    const response = await fetch(`/partidos/${partidoId}/equipo/${equipoId}/carga`, { headers: { 'Accept': 'application/json' } });
    const data = await response.json();
    if (!data.success) throw new Error(data.message || 'No se pudo preparar la planilla final');
    const pdf = crearPdfPlanillaFinalEquipo(data);
    const equipoSeguro = normalizarTextoPdf(data.equipo?.nombre || 'equipo').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'equipo';
    await descargarPdfArchivo(`planilla-final-${partidoId}-${equipoSeguro}.pdf`, pdf);
  } catch (error) {
    console.error(error);
    mostrarAvisoApp(error.message || 'No se pudo imprimir la planilla final.', 'Planilla final');
  }
}

