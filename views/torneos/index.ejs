function abrirModalEstadisticasEncuentro(partidoId) {
  const partido = (dashboardPartidosEstadisticas || []).find(item => String(item.id_partido) === String(partidoId));
  if (!partido) return;

  document.getElementById('modalStatsEquipoA').textContent = partido.nombre_equipo_a || 'Equipo A';
  document.getElementById('modalStatsEquipoB').textContent = partido.nombre_equipo_b || 'Equipo B';
  document.getElementById('modalStatsMarcador').textContent = `${partido.goles_a || 0} - ${partido.goles_b || 0}`;

  const detalle = document.getElementById('modalStatsDetalle');
  const estadisticas = Array.isArray(partido.estadisticas) ? partido.estadisticas : [];
  const cambios = Array.isArray(partido.cambios) ? partido.cambios : [];
  const conEventos = estadisticas.filter(jugador =>
    Number(jugador.goles || 0) > 0 ||
    Number(jugador.tarjetas_amarillas || 0) > 0 ||
    Number(jugador.tarjetas_rojas || 0) > 0
  );

  const ordenarJugadores = (a, b) => {
    return [a.nombre || '', a.apellido || ''].join(' ').localeCompare([b.nombre || '', b.apellido || ''].join(' '), 'es');
  };
  const equipoAId = String(partido.equipo_a || '');
  const equipoBId = String(partido.equipo_b || '');
  const jugadoresEquipoA = conEventos.filter(jugador => String(jugador.id_equipo || '') === equipoAId).sort(ordenarJugadores);
  const jugadoresEquipoB = conEventos.filter(jugador => String(jugador.id_equipo || '') === equipoBId).sort(ordenarJugadores);
  const jugadoresSinEquipo = conEventos.filter(jugador => {
    const equipo = String(jugador.id_equipo || '');
    return equipo !== equipoAId && equipo !== equipoBId;
  }).sort(ordenarJugadores);
  const cambiosEquipoA = cambios.filter(cambio => String(cambio.equipo_id || '') === equipoAId);
  const cambiosEquipoB = cambios.filter(cambio => String(cambio.equipo_id || '') === equipoBId);
  const cambiosSinEquipo = cambios.filter(cambio => {
    const equipo = String(cambio.equipo_id || '');
    return equipo !== equipoAId && equipo !== equipoBId;
  });

  detalle.innerHTML = (conEventos.length || cambios.length)
    ? `
      <div class="encuentro-stats-columnas">
        ${renderColumnaEstadisticasEquipo(partido.nombre_equipo_a || 'Equipo A', jugadoresEquipoA)}
        ${renderColumnaEstadisticasEquipo(partido.nombre_equipo_b || 'Equipo B', jugadoresEquipoB)}
      </div>
      ${jugadoresSinEquipo.length ? `<div class="mt-2">${renderColumnaEstadisticasEquipo('Sin equipo asignado', jugadoresSinEquipo)}</div>` : ''}
      <div class="encuentro-stats-seccion">Cambios</div>
      <div class="encuentro-stats-columnas">
        ${renderColumnaCambiosEquipo(partido.nombre_equipo_a || 'Equipo A', cambiosEquipoA)}
        ${renderColumnaCambiosEquipo(partido.nombre_equipo_b || 'Equipo B', cambiosEquipoB)}
      </div>
      ${cambiosSinEquipo.length ? `<div class="mt-2">${renderColumnaCambiosEquipo('Sin equipo asignado', cambiosSinEquipo)}</div>` : ''}
    `
    : '<div class="text-center text-muted py-3">No hay goles, tarjetas ni cambios cargados para este encuentro.</div>';

  bootstrap.Modal.getOrCreateInstance(document.getElementById('modalEstadisticasEncuentro')).show();
}

function renderDashboardEventoJugador(jugador) {
  const goles = Number(jugador.goles || 0);
  const amarillas = Number(jugador.tarjetas_amarillas || 0);
  const rojas = Number(jugador.tarjetas_rojas || 0);
