<!DOCTYPE html>
<html>
<head>
  <title>Crear Torneo</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex justify-content-center align-items-center vh-100">

  <div class="card shadow p-4" style="min-width: 350px;">
    <h1 class="mb-4 text-center">Crear Torneo</h1>

    <!-- Mensajes flash -->
    <% if (messages.success && messages.success.length > 0) { %>
      <div class="alert alert-success text-center"><%= messages.success[0] %></div>
    <% } %>
    <% if (messages.error && messages.error.length > 0) { %>
      <div class="alert alert-danger text-center"><%= messages.error[0] %></div>
    <% } %>

    <form action="/torneos/crear" method="POST">
      <input type="hidden" name="entity_id" value="<%= entityId %>">

      <div class="mb-3">
        <label for="nombre_torneo" class="form-label">Nombre del torneo</label>
        <input type="text" class="form-control" id="nombre_torneo" name="nombre_torneo" required>
      </div>

      <div class="mb-3">
        <label for="temporada" class="form-label">Temporada</label>
        <input type="text" class="form-control" id="temporada" name="temporada" required>
      </div>

      <div class="mb-3">
        <label for="fecha_inicio" class="form-label">Fecha de inicio</label>
        <input type="date" class="form-control" id="fecha_inicio" name="fecha_inicio">
      </div>

      <button type="submit" class="btn btn-success w-100">Guardar torneo</button>
    </form>
  </div>

</body>
</html>
