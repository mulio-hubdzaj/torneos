
<!-- entidad/index.ejs -->
<!DOCTYPE html>
<html>
<head>
  <title>Entidad <%= entidad.codigo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="entity-index-page app-responsive-page">

  <main class="container-fluid app-page-shell entity-page-shell">
  <div class="card shadow p-4 entity-card entity-tournaments-card">
    <header class="entity-title-block">
      <h1 class="mb-1">Entidad: <%= entidad.codigo %></h1>
      <p class="text-muted mb-0"><%= entidad.descripcion %></p>
    </header>

<!-- Bloque de mensajes flash -->
<% if (messages) { %>
  <% if (messages.success && messages.success.length > 0) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages.danger && messages.danger.length > 0) { %>
    <div class="alert alert-danger"><%= messages.danger[0] %></div>
  <% } %>
  <% if (messages.info && messages.info.length > 0) { %>
    <div class="alert alert-info"><%= messages.info[0] %></div>
  <% } %>
<% } %>



    <!-- Sección de torneos -->
    <div class="entity-section-title">
      <h3 class="mb-0">Torneos</h3>
    </div>
    <% if (torneos && torneos.length > 0) { %>
      <div class="app-search-bar entity-search-bar">
        <label class="form-label mb-1" for="buscarTorneosEntidad">Buscar torneo</label>
        <input type="search"
               class="form-control"
               id="buscarTorneosEntidad"
               placeholder="Nombre, temporada o estado"
               autocomplete="off">
      </div>
      <ul class="list-group mb-3 entity-tournament-list" id="listaTorneosEntidad">
        <% torneos.forEach(t => { %>
          <% const torneoTextoBusqueda = `${t.nombre_torneo || ''} ${t.temporada || ''} ${t.estado ? 'activo' : 'inactivo'}`; %>
          <li class="list-group-item entity-tournament-item" data-search="<%= torneoTextoBusqueda.toUpperCase() %>">
            <div class="entity-tournament-main">
              <strong class="entity-tournament-name"><%= t.nombre_torneo %></strong>
              <span class="entity-tournament-season"><%= t.temporada || 'Sin temporada' %></span>
              <% if (t.estado) { %>
                <span class="badge bg-success entity-status-badge">Activo</span>
              <% } else { %>
                <span class="badge bg-secondary entity-status-badge">Inactivo</span>
              <% } %>
            </div>
            <div class="entity-row-actions">
              <!-- Botón cambiar estado -->
              <form action="/torneos/cambiar-estado/<%= t.id_torneo %>" method="POST" style="display:inline;">
                <% if (t.estado) { %>
                  <!-- Activo: verde -->
                  <button type="submit" class="btn btn-sm btn-success">
                    Desactivar
                  </button>
                <% } else { %>
                  <!-- Inactivo: azul claro -->
                  <button type="submit" class="btn btn-sm btn-info">
                    Activar
                  </button>
                <% } %>
              </form>

              <!-- Botón ir a torneo -->
              <% if (usuario && (usuario.rol_id == 3 || usuario.rol_id == 99)) { %>
                <% if (t.estado) { %>
                  <a href="/torneos/gestionar/<%= t.id_torneo %>" class="btn btn-sm btn-primary">
                    Ir a torneo
                  </a>
                <% } else { %>
                  <button class="btn btn-sm btn-secondary" disabled>Ir a torneo</button>
                <% } %>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
      <p class="text-muted text-center py-3 mb-3 d-none" id="sinTorneosEntidad">No se encontraron torneos.</p>
    <% } else { %>
      <p class="text-muted">No hay torneos creados aún.</p>
    <% } %>

    <!-- Link corregido: usar entidad.entity_id -->
    <a href="/torneos/crear?entity_id=<%= entidad.entity_id %>" class="btn btn-success w-100">Crear torneo</a>
  </div>
  </main>

<script>
  const buscarTorneosEntidad = document.getElementById('buscarTorneosEntidad');
  const sinTorneosEntidad = document.getElementById('sinTorneosEntidad');

  if (buscarTorneosEntidad && sinTorneosEntidad) {
    buscarTorneosEntidad.addEventListener('input', function() {
      const filtro = (this.value || '').trim().toUpperCase();
      let visibles = 0;

      document.querySelectorAll('#listaTorneosEntidad [data-search]').forEach(item => {
        const coincide = !filtro || (item.dataset.search || '').includes(filtro);
        item.classList.toggle('d-none', !coincide);
        if (coincide) visibles += 1;
      });

      sinTorneosEntidad.classList.toggle('d-none', visibles !== 0);
    });
  }
</script>
<script>
  window.APP_ABANDON_TIMEOUT_MS = <%= typeof abandonTimeoutMs !== 'undefined' ? abandonTimeoutMs : 180000 %>;
</script>
<script src="/js/session-abandon-guard.js"></script>
</body>
</html>
