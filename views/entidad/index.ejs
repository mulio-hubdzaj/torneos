
<!-- entidad/index.ejs -->
<!DOCTYPE html>
<html>
<head>
  <title>Entidad <%= entidad.codigo %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex justify-content-center align-items-center vh-100">

  <div class="card shadow p-4" style="min-width: 400px;">
    <h1 class="mb-4 text-center">Entidad: <%= entidad.codigo %></h1>
    <p class="text-center text-muted"><%= entidad.descripcion %></p>

<!-- Bloque de mensajes flash -->
<% if (messages) { %>
  <% if (messages.success && messages.success.length > 0) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages.danger && messages.danger.length > 0) { %>
    <div class="alert alert-danger"><%= messages.danger[0] %></div>
  <% } %>
  <% if (messages.info && messages.info.length > 0) { %>
    <div class="alert alert-info"><%= messages.info[0] %></div>
  <% } %>
<% } %>



    <!-- Sección de torneos -->
    <h3 class="mt-3">Torneos</h3>
    <% if (torneos && torneos.length > 0) { %>
      <ul class="list-group mb-3">
        <% torneos.forEach(t => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>
              <strong><%= t.nombre_torneo %></strong> - <%= t.temporada %>
              <% if (t.estado) { %>
                <span class="badge bg-success">Activo</span>
              <% } else { %>
                <span class="badge bg-secondary">Inactivo</span>
              <% } %>
            </span>
            <div class="d-flex gap-2">
              <!-- Botón cambiar estado -->
              <form action="/torneos/cambiar-estado/<%= t.id_torneo %>" method="POST" style="display:inline;">
                <% if (t.estado) { %>
                  <!-- Activo: verde -->
                  <button type="submit" class="btn btn-sm btn-success">
                    Desactivar
                  </button>
                <% } else { %>
                  <!-- Inactivo: azul claro -->
                  <button type="submit" class="btn btn-sm btn-info">
                    Activar
                  </button>
                <% } %>
              </form>

              <!-- Botón ir a torneo -->
              <% if (t.estado) { %>
                <a href="/torneos/gestionar/<%= t.id_torneo %>" class="btn btn-sm btn-primary">
                  Ir a torneo
                </a>
              <% } else { %>
                <button class="btn btn-sm btn-secondary" disabled>Ir a torneo</button>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="text-muted">No hay torneos creados aún.</p>
    <% } %>

    <!-- Link corregido: usar entidad.entity_id -->
    <a href="/torneos/crear?entity_id=<%= entidad.entity_id %>" class="btn btn-success w-100">Crear torneo</a>
  </div>

</body>
</html>
