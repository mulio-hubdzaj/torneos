<!DOCTYPE html>
<html>
<head>
  <p>

  </p>
  <title>Registro</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex justify-content-center align-items-center vh-100">

  <div class="card shadow p-4" style="min-width: 350px;">
    <h1 class="mb-4 text-center">Registro</h1>
	

  <!-- Bloque de mensajes flash -->
 <!-- Bloque de mensajes flash -->
<% if (messages) { %>
  <% if (messages.success && messages.success.length > 0) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages.error && messages.error.length > 0) { %>
    <div class="alert alert-danger"><%= messages.error[0] %></div>
  <% } %>
  <% if (messages.danger && messages.danger.length > 0) { %>
    <div class="alert alert-danger"><%= messages.danger[0] %></div>
  <% } %>
  <% if (messages.info && messages.info.length > 0) { %>
    <div class="alert alert-info"><%= messages.info[0] %></div>
  <% } %>
<% } %>





  <!-- Formulario de registro -->
  <form action="/registro" method="POST">
    <div class="mb-3">
      <label for="nombre" class="form-label">Nombre:</label>
      <input type="text" id="nombre" name="nombre"
             pattern="[A-Za-z\s]+"
             title="El nombre solo puede contener letras y espacios"
             required
             style="text-transform: uppercase"
             class="form-control">
      <small class="form-text text-muted">Solo letras y espacios</small>
    </div>

    <div class="mb-3">
      <label for="apellido" class="form-label">Apellido:</label>
      <input type="text" id="apellido" name="apellido"
             pattern="[A-Za-z\s]+"
             title="El apellido solo puede contener letras y espacios"
             required
             style="text-transform: uppercase"
             class="form-control">
      <small class="form-text text-muted">Solo letras y espacios</small>
    </div>

    <div class="mb-3">
      <label for="correo" class="form-label">Correo:</label>
      <input type="email" id="correo" name="correo"
             pattern="^[^\s@]+@[^\s@]+\.[^\s@]{2,}$"
             title="Ingrese un correo valido, por ejemplo usuario@dominio.com"
             required
             class="form-control">
      <small class="form-text text-muted">Ejemplo: usuario@dominio.com</small>
    </div>

    <div class="mb-3">
      <label for="documento" class="form-label">Documento:</label>
      <input type="text" id="documento" name="documento"
             pattern="\d{6,8}"
             title="Debe contener solo números y tener entre 6 y 8 dígitos"
             required
             style="text-transform: uppercase"
             oninput="this.value=this.value.replace(/\s/g,'')"
             class="form-control">
      <small class="form-text text-muted">Solo números, entre 6 y 8 dígitos</small>
    </div>

    <div class="mb-3">
      <label for="contrasena" class="form-label">Contraseña:</label>
      <div class="input-group">
      <input type="password" id="contrasena" name="contrasena"
             pattern="(?=.{8,})(?=(?:.*\d){2,})(?=.*[^A-Za-z0-9\s]).+"
             title="Minimo 8 caracteres, 1 caracter especial y 2 numeros"
             required
             class="form-control password-segura">
        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('contrasena', this)" aria-label="Ver contrasena">
          <i class="bi bi-eye"></i>
        </button>
      </div>
      <div class="progress mt-2" style="height: 8px;">
        <div class="progress-bar bg-danger" id="passwordProgress" style="width: 0%;"></div>
      </div>
      <div class="small mt-2" id="passwordChecklist">
        <div data-req="longitud" class="text-danger">Al menos 8 caracteres</div>
        <div data-req="numeros" class="text-danger">Al menos 2 numeros</div>
        <div data-req="especial" class="text-danger">Al menos 1 caracter especial</div>
      </div>
    </div>

    <div class="mb-3">
      <label for="entidad" class="form-label">Entidad:</label>
      <input type="text" id="entidad" name="entidad"
             required
             style="text-transform: uppercase"
             oninput="this.value=this.value.replace(/\s/g,'')"
             class="form-control">
      <small class="form-text text-muted">Código de la entidad , consulte con su Admin</small>
    </div>

    <button type="submit" class="btn btn-success">Registrarse</button>
  </form>

  <p class="mt-3">¿Ya tienes cuenta? <a href="/login">Iniciar sesión</a></p>
  <script>
    function togglePassword(inputId, button) {
      const input = document.getElementById(inputId);
      const icon = button.querySelector('i');
      const mostrar = input.type === 'password';
      input.type = mostrar ? 'text' : 'password';
      icon.className = mostrar ? 'bi bi-eye-slash' : 'bi bi-eye';
    }

    function actualizarSeguridadPassword() {
      const input = document.getElementById('contrasena');
      const progress = document.getElementById('passwordProgress');
      const valor = input?.value || '';
      const requisitos = {
        longitud: valor.length >= 8,
        numeros: (valor.match(/\d/g) || []).length >= 2,
        especial: /[^A-Za-z0-9\s]/.test(valor)
      };
      const cumplidos = Object.values(requisitos).filter(Boolean).length;
      const porcentaje = Math.round((cumplidos / Object.keys(requisitos).length) * 100);

      Object.entries(requisitos).forEach(([key, ok]) => {
        const item = document.querySelector(`#passwordChecklist [data-req="${key}"]`);
        if (!item) return;
        item.classList.toggle('text-success', ok);
        item.classList.toggle('text-danger', !ok);
        item.textContent = item.textContent.replace(/^(OK|NO)\s*/, '');
      });

      if (progress) {
        progress.style.width = `${porcentaje}%`;
        progress.className = `progress-bar ${porcentaje < 50 ? 'bg-danger' : (porcentaje < 100 ? 'bg-warning' : 'bg-success')}`;
      }
    }

    document.getElementById('contrasena')?.addEventListener('input', actualizarSeguridadPassword);
    actualizarSeguridadPassword();
  </script>
</body>
</html>
