<!DOCTYPE html>
<html>
<head>
  <title>Ver equipo</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    html,
    body {
      max-width: 100%;
      overflow-x: hidden;
    }

    body.equipo-ver-page {
      display: block;
      align-items: initial;
      justify-content: initial;
      color: #102033;
    }

    .equipo-ver-main {
      width: min(100%, 1080px);
      padding-top: 42px;
      padding-bottom: 48px;
    }

    .equipo-ver-card {
      overflow: hidden;
      max-width: none;
      padding: 0;
      text-align: left;
      border-radius: 8px;
    }

    .equipo-ver-header {
      min-width: 0;
    }

    .equipo-logo {
      width: 96px;
      height: 96px;
      object-fit: contain;
      background: #fff;
      border-radius: 8px;
      padding: 8px;
      border: 1px solid rgba(0,0,0,.1);
    }
    .jugador-numero {
      width: 42px;
      height: 42px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      background: #212529;
      color: #fff;
    }

    .equipo-jugadores-scroll {
      max-width: 100%;
      overflow-x: visible;
      -webkit-overflow-scrolling: touch;
    }

    .equipo-jugadores-scroll table {
      min-width: 0;
      width: 100%;
      table-layout: fixed;
    }

    .equipo-ver-jugadores-table th:nth-child(1),
    .equipo-ver-jugadores-table td:nth-child(1) {
      width: 72px;
    }

    .equipo-ver-jugadores-table th:nth-child(3),
    .equipo-ver-jugadores-table td:nth-child(3),
    .equipo-ver-jugadores-table th:nth-child(4),
    .equipo-ver-jugadores-table td:nth-child(4),
    .equipo-ver-jugadores-table th:nth-child(5),
    .equipo-ver-jugadores-table td:nth-child(5) {
      width: 116px;
    }

    .equipo-ver-jugadores-table td {
      vertical-align: middle;
    }

    .equipo-ver-jugadores-table .jugador-nombre-cell {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    @media (max-width: 576px) {
      .navbar .container-fluid {
        gap: 0.5rem;
      }

      .navbar-brand {
        max-width: calc(100vw - 112px);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .equipo-ver-main {
        width: 100%;
        padding: 18px 10px 36px;
      }

      .equipo-ver-card .card-header {
        padding: 0.85rem;
      }

      .equipo-ver-header {
        align-items: flex-start !important;
      }

      .equipo-logo {
        width: 72px;
        height: 72px;
        flex: 0 0 auto;
      }

      .equipo-ver-header h4 {
        font-size: 1.08rem;
        overflow-wrap: anywhere;
      }

      .list-group-item {
        gap: 0.5rem;
      }

      .equipo-jugadores-scroll {
        overflow-x: visible;
      }

      .equipo-ver-jugadores-table {
        min-width: 0;
      }

      .equipo-ver-jugadores-table thead {
        display: none;
      }

      .equipo-ver-jugadores-table,
      .equipo-ver-jugadores-table tbody,
      .equipo-ver-jugadores-table tr,
      .equipo-ver-jugadores-table td {
        display: block;
        width: 100%;
      }

      .equipo-ver-jugadores-table tr {
        display: grid;
        grid-template-columns: 48px minmax(0, 1fr) 64px;
        grid-template-areas:
          "numero jugador estado"
          "numero vinculo capitan";
        gap: 0.28rem 0.55rem;
        align-items: center;
        margin-bottom: 0.55rem;
        padding: 0.58rem;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        background: #fff;
      }

      .equipo-ver-jugadores-table td {
        border: 0;
        padding: 0;
        font-size: 0.78rem;
      }

      .equipo-ver-jugadores-table td::before {
        content: attr(data-label);
        display: block;
        margin-bottom: 0.08rem;
        font-size: 0.5rem;
        font-weight: 800;
        color: #6c757d;
        line-height: 1;
        text-transform: uppercase;
      }

      .equipo-ver-jugadores-table .jugador-numero-cell {
        grid-area: numero;
      }

      .equipo-ver-jugadores-table .jugador-numero-cell::before,
      .equipo-ver-jugadores-table .jugador-nombre-cell::before {
        display: none;
      }

      .equipo-ver-jugadores-table .jugador-nombre-cell {
        grid-area: jugador;
        font-size: 0.86rem;
        line-height: 1.15;
      }

      .equipo-ver-jugadores-table .jugador-vinculo-cell {
        grid-area: vinculo;
      }

      .equipo-ver-jugadores-table .jugador-estado-cell {
        grid-area: estado;
        text-align: center;
      }

      .equipo-ver-jugadores-table .jugador-capitan-cell {
        grid-area: capitan;
        text-align: center;
      }

      .equipo-ver-jugadores-table .badge {
        white-space: normal;
        line-height: 1.05;
        font-size: 0.62rem;
        padding: 0.28rem 0.35rem;
      }

      .jugador-numero {
        width: 38px;
        height: 38px;
      }
    }
  </style>
</head>
<body class="bg-stadium equipo-ver-page">
  <nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid d-flex justify-content-between align-items-center">
      <span class="navbar-brand fw-bold">Ver equipo</span>
      <a href="<%= returnUrl %>" class="btn btn-outline-light btn-sm">
        &larr; Atras
      </a>
    </div>
  </nav>

  <main class="container mt-4 equipo-ver-main">
    <div class="card shadow equipo-ver-card">
      <div class="card-header bg-secondary text-white">
        <div class="d-flex align-items-center gap-3 equipo-ver-header">
          <img src="<%= equipo.icono || '/images/default_team.png' %>" alt="" class="equipo-logo">
          <div>
            <h4 class="mb-1"><%= equipo.nombre %></h4>
            <span class="badge <%= equipo.estado ? 'text-bg-success' : 'text-bg-secondary' %>">
              <%= equipo.estado ? 'Activo' : 'Inactivo' %>
            </span>
          </div>
        </div>
      </div>

      <div class="card-body">
        <h5>Delegados</h5>
        <ul class="list-group mb-4">
          <% if (delegados && delegados.length > 0) { %>
            <% delegados.forEach(del => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= del.Usuario ? del.Usuario.nombre : del.id_usuario %></span>
                <span class="badge text-bg-light border"><%= del.rol || del.rol_equipo || 'delegado' %></span>
              </li>
            <% }) %>
          <% } else { %>
            <li class="list-group-item text-muted">No hay delegados asignados</li>
          <% } %>
        </ul>

        <h5>Jugadores</h5>
        <div class="table-responsive mb-4 equipo-jugadores-scroll">
          <table class="table table-sm align-middle equipo-ver-jugadores-table">
            <thead class="table-light">
              <tr>
                <th style="width: 64px;">Nro.</th>
                <th>Jugador</th>
                <th>Vinculo</th>
                <th>Estado</th>
                <th>Capitan</th>
              </tr>
            </thead>
            <tbody>
              <% if (jugadores && jugadores.length > 0) { %>
                <% jugadores.forEach(j => { %>
                  <% const vinculo = j.JugadorEquipo || {}; %>
                  <tr>
                    <td class="jugador-numero-cell" data-label="Nro."><span class="jugador-numero"><%= vinculo.numero_camiseta || '-' %></span></td>
                    <td class="jugador-nombre-cell" data-label="Jugador">
                      <strong><%= j.nombre %> <%= j.apellido %></strong>
                      <% if (j.documento) { %>
                        <small class="text-muted d-block"><%= j.documento %></small>
                      <% } %>
                    </td>
                    <td class="jugador-vinculo-cell" data-label="Vinculo"><%= vinculo.tipo_vinculo || 'titular' %></td>
                    <td class="jugador-estado-cell" data-label="Estado">
                      <span class="badge <%= vinculo.estado === false ? 'text-bg-warning' : 'text-bg-primary' %>">
                        <%= vinculo.estado === false ? 'Inactivo' : 'Activo' %>
                      </span>
                    </td>
                    <td class="jugador-capitan-cell" data-label="Capitan">
                      <% if (vinculo.capitan) { %>
                        <span class="badge text-bg-success">Capitan</span>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5" class="text-muted">No hay jugadores asignados</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    window.APP_ABANDON_TIMEOUT_MS = <%= typeof abandonTimeoutMs !== 'undefined' ? abandonTimeoutMs : 300000 %>;
  </script>
  <script src="/js/session-abandon-guard.js"></script>
</body>
</html>
