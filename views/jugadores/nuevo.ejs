<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="card bg-light bg-opacity-75 p-4 shadow">
    <h3 class="mb-3">Agregar Jugador</h3>

    <!-- Estilos -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">

    <!-- 🔔 Bloque de mensajes -->
    <% if (messages.danger && messages.danger.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= messages.danger[0] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (messages.success && messages.success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= messages.success[0] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- 👇 importante: coincide con router.post('/crear') -->
    <form action="/jugadores/crear" method="POST">
      <input type="hidden" name="entity_id" value="<%= entity_id %>">
      <input type="hidden" name="torneo_id" value="<%= torneo_id %>">

      <div class="mb-3">
        <label for="nombre" class="form-label">Nombre</label>
        <input type="text" class="form-control text-uppercase" id="nombre" name="nombre" 
               required pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" 
               title="Solo letras y espacios">
      </div>

      <div class="mb-3">
        <label for="apellido" class="form-label">Apellido</label>
        <input type="text" class="form-control text-uppercase" id="apellido" name="apellido" 
               required pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" 
               title="Solo letras y espacios">
      </div>

      <div class="mb-3">
        <label for="documento" class="form-label">Documento</label>
        <input type="text" class="form-control text-uppercase" id="documento" name="documento" 
               required pattern="[0-9]{6,11}" 
               title="Solo números, entre 6 y 11 dígitos">
      </div>

      <div class="mb-3">
        <label for="fecha_nacimiento" class="form-label">Fecha de Nacimiento</label>
        <input type="text"
               class="form-control fecha-manual"
               id="fecha_nacimiento"
               name="fecha_nacimiento"
               inputmode="numeric"
               autocomplete="off"
               maxlength="10"
               placeholder="DD/MM/AAAA"
               pattern="[0-9]{2}/[0-9]{2}/[0-9]{4}"
               title="Ingrese la fecha con formato DD/MM/AAAA"
               required>
        <div class="form-text">Formato: DD/MM/AAAA</div>
      </div>

      <% if (Number(rol_id) === 2) { %>
        <input type="hidden" name="estado" value="true">
        <input type="hidden" name="observaciones" value="">
      <% } else { %>
        <div class="mb-3">
          <label for="estado" class="form-label">Estado</label>
          <select class="form-select" id="estado" name="estado">
            <option value="true" selected>Activo</option>
            <option value="false">Inactivo</option>
          </select>
        </div>

        <div class="mb-3">
          <label for="observaciones" class="form-label">Observaciones</label>
          <textarea class="form-control text-uppercase" id="observaciones" name="observaciones"></textarea>
        </div>
      <% } %>

      <div class="text-end">
        <button type="submit" class="btn btn-success">Guardar</button>
        <a href="/torneos/gestionar/<%= torneo_id %>?tab=jugadores#jugadores" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  // Evitar números en nombre y apellido
  document.getElementById("nombre").addEventListener("input", function() {
    this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ\s]/g, "");
  });
  document.getElementById("apellido").addEventListener("input", function() {
    this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ\s]/g, "");
  });

  // Documento: solo números y máximo 11 dígitos
  document.getElementById("documento").addEventListener("input", function() {
    this.value = this.value.replace(/[^0-9]/g, "");
    if (this.value.length > 11) {
      this.value = this.value.slice(0, 11);
    }
  });

  document.getElementById("fecha_nacimiento").addEventListener("input", function() {
    const numeros = this.value.replace(/\D/g, "").slice(0, 8);
    const partes = [];
    if (numeros.length > 0) partes.push(numeros.slice(0, 2));
    if (numeros.length > 2) partes.push(numeros.slice(2, 4));
    if (numeros.length > 4) partes.push(numeros.slice(4, 8));
    this.value = partes.join("/");
  });
</script>

<%- include('../partials/footer') %>
