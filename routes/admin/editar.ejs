<!DOCTYPE html>
<html>
<head>
  <title>Editar Entidad</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="container mt-4">
  <h1>Editar Entidad</h1>

  <!-- Bloque de mensajes flash -->
  <% if (messages && messages.success && messages.success.length > 0) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages && messages.error && messages.error.length > 0) { %>
    <div class="alert alert-danger"><%= messages.error[0] %></div>
  <% } %>

  <!-- Formulario de edición -->
  <form action="/admin/editar/<%= entidad.entity_id %>" method="POST">
    <div class="mb-3">
      <label for="codigo" class="form-label">Código:</label>
      <input type="text" id="codigo" name="codigo" class="form-control" value="<%= entidad.codigo %>" readonly>
    </div>
    <div class="mb-3">
      <label for="descripcion" class="form-label">Descripción:</label>
      <input type="text" id="descripcion" name="descripcion" class="form-control" value="<%= entidad.descripcion %>" required>
    </div>
    <button type="submit" class="btn btn-success">Guardar cambios</button>
    <a href="/admin" class="btn btn-secondary">Cancelar</a>
  </form>
</body>
</html>
