<!DOCTYPE html>
<html>
<head>
  <title>Administración de Entidades</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-4">
  <h1>Administración de Entidades</h1>

  <% if (messages.success && messages.success.length > 0) { %>
    <div class="alert alert-success"><%= messages.success[0] %></div>
  <% } %>
  <% if (messages.error && messages.error.length > 0) { %>
    <div class="alert alert-danger"><%= messages.error[0] %></div>
  <% } %>
  <% if (messages.danger && messages.danger.length > 0) { %>
    <div class="alert alert-warning"><%= messages.danger[0] %></div>
  <% } %>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Código</th>
        <th>Descripción</th>
        <th>Activo</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% entidades.forEach(ent => { %>
        <tr>
          <td><%= ent.codigo %></td>
          <td><%= ent.descripcion %></td>
          <td>
            <form action="/admin/entidades/toggle/<%= ent.entity_id %>" method="POST" style="display:inline;">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="activo"
                       onchange="this.form.submit()" <%= ent.activo ? 'checked' : '' %>>
              </div>
            </form>
          </td>
          <td>
            <a href="/admin/entidades/editar/<%= ent.entity_id %>" class="btn btn-warning btn-sm">Editar</a>
            <a href="/admin/gestionar/<%= ent.entity_id %>" class="btn btn-primary btn-sm">Administrar</a>

          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
